---
const { title = "DMH Admin", adminName = "Administrador" } = Astro.props;
import AdminSidebar from "../components/admin/AdminSidebar.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0a0a0a;
        --panel: #121212;
        --panel-2: #171717;
        --border: #232323;
        --text: #f5f5f5;
        --muted: #777;
        --accent: #d7ff00;
        --danger: #ff4d4d;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: Arial, Helvetica, sans-serif;
        overflow-x: hidden;
      }

      .admin-layout {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 300px minmax(0, 1fr);
      }

      .main {
        min-width: 0;
        display: flex;
        flex-direction: column;
      }

      .topbar {
        min-height: 78px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0 clamp(20px, 3vw, 38px);
        gap: 18px;
        flex-wrap: wrap;
        background: rgba(10, 10, 10, 0.86);
        backdrop-filter: blur(14px);
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .admin-user {
        color: #b1b1b1;
        font-size: 1rem;
        font-weight: 700;
      }

      .logout {
        appearance: none;
        -webkit-appearance: none;
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 16px;
        border-radius: 12px;
        border: 1px solid #343434;
        background: #171717;
        color: #f0f0f0;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 800;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
      }

      .logout:hover {
        background: #202020;
        border-color: #444;
      }

      .content {
        min-width: 0;
        padding: clamp(20px, 3vw, 38px);
      }

      @media (max-width: 1100px) {
        .admin-layout {
          grid-template-columns: 270px minmax(0, 1fr);
        }
      }

      @media (max-width: 980px) {
        .admin-layout {
          grid-template-columns: 1fr;
        }

        .topbar {
          min-height: auto;
          justify-content: space-between;
          padding: 16px 18px;
          position: static;
        }

        .content {
          padding: 18px;
        }
      }

      @media (max-width: 640px) {
        .topbar {
          align-items: flex-start;
          gap: 12px;
        }

        .admin-user {
          font-size: 0.9rem;
          line-height: 1.35;
        }

        .logout {
          width: 100%;
          min-height: 40px;
        }

        .content {
          padding: 14px;
        }
      }
    </style>
  </head>
  <body>
    <div class="admin-layout" id="adminLayoutRoot">
      <AdminSidebar />
      <main class="main">
        <div class="topbar">
          <div class="admin-user">{adminName} — Admin</div>
          <a class="logout" href="/" id="logoutLink">Cerrar sesión</a>
        </div>

        <section class="content">
          <slot />
        </section>
      </main>
    </div>

    <script>
      const adminLayoutRoot = document.getElementById("adminLayoutRoot");

      if (adminLayoutRoot instanceof HTMLElement) {
        adminLayoutRoot.style.visibility = "hidden";
      }

      async function ensureAdminSession() {
        try {
          const response = await fetch("/backend/session.php", {
            credentials: "include",
          });

          const data = await response.json();
          const isAdmin = Boolean(data?.logueado && data?.usuario?.rol === "admin");

          if (!isAdmin) {
            window.location.href = "/login";
            return;
          }

          if (adminLayoutRoot instanceof HTMLElement) {
            adminLayoutRoot.style.visibility = "visible";
          }
        } catch (_error) {
          window.location.href = "/login";
        }
      }

      void ensureAdminSession();

      document.getElementById("logoutLink")?.addEventListener("click", async (e) => {
        e.preventDefault();

        try {
          const response = await fetch("/backend/logout.php", {
            method: "POST",
            credentials: "include",
          });

          const data = await response.json();

          if (data.ok) {
            localStorage.removeItem("cart");
            window.dispatchEvent(new Event("cart-updated"));
            window.location.href = "/";
          }
        } catch (error) {
          console.error("Error cerrando sesión:", error);
        }
      });
    </script>
  </body>
</html>