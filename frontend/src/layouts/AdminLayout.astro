---
const { title = "DMH Admin", adminName = "Administrador" } = Astro.props;
import AdminSidebar from "../components/admin/AdminSidebar.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0a0a0a;
        --panel: #121212;
        --panel-2: #171717;
        --border: #232323;
        --text: #f5f5f5;
        --muted: #777;
        --accent: #d7ff00;
        --danger: #ff4d4d;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: Arial, Helvetica, sans-serif;
      }

      .admin-layout {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 260px 1fr;
      }

      .main {
        display: flex;
        flex-direction: column;
      }

      .topbar {
        height: 72px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0 28px;
        gap: 18px;
      }

      .admin-user {
        color: #8b8b8b;
        font-size: 0.95rem;
      }

      .logout {
        appearance: none;
        -webkit-appearance: none;
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 14px;
        border-radius: 8px;
        border: 1px solid #2f2f2f;
        background: #171717;
        color: #f0f0f0;
        text-decoration: none;
        font-size: 0.84rem;
        font-weight: 700;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
      }

      .logout:hover {
        background: #1f1f1f;
        border-color: #3a3a3a;
      }

      .content {
        padding: 28px;
      }

      @media (max-width: 980px) {
        .admin-layout {
          grid-template-columns: 1fr;
        }

        .topbar {
          justify-content: space-between;
          padding: 0 18px;
        }

        .content {
          padding: 18px;
        }
      }
    </style>
  </head>
  <body>
    <div class="admin-layout" id="adminLayoutRoot">
      <AdminSidebar />
      <main class="main">
        <div class="topbar">
          <div class="admin-user">{adminName} — Admin</div>
          <a class="logout" href="/" id="logoutLink">Cerrar sesión</a>
        </div>

        <section class="content">
          <slot />
        </section>
      </main>
    </div>

    <script>
      const adminLayoutRoot = document.getElementById("adminLayoutRoot");

      if (adminLayoutRoot instanceof HTMLElement) {
        adminLayoutRoot.style.visibility = "hidden";
      }

      async function ensureAdminSession() {
        try {
          const response = await fetch("/backend/session.php", {
            credentials: "include",
          });

          const data = await response.json();
          const isAdmin = Boolean(data?.logueado && data?.usuario?.rol === "admin");

          if (!isAdmin) {
            window.location.href = "/login";
            return;
          }

          if (adminLayoutRoot instanceof HTMLElement) {
            adminLayoutRoot.style.visibility = "visible";
          }
        } catch (_error) {
          window.location.href = "/login";
        }
      }

      void ensureAdminSession();

      document.getElementById("logoutLink")?.addEventListener("click", async (e) => {
        e.preventDefault();

        try {
          const response = await fetch("/backend/logout.php", {
            method: "POST",
            credentials: "include",
          });

          const data = await response.json();

          if (data.ok) {
            window.location.href = "/";
          }
        } catch (error) {
          console.error("Error cerrando sesión:", error);
        }
      });
    </script>
  </body>
</html>