---
const { title = "DMH Admin", adminName = "Administrador" } = Astro.props;
import AdminSidebar from "../components/admin/AdminSidebar.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0a0a0a;
        --panel: #121212;
        --panel-2: #171717;
        --border: #232323;
        --text: #f5f5f5;
        --muted: #777;
        --accent: #d7ff00;
        --danger: #ff4d4d;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: Arial, Helvetica, sans-serif;
      }

      .admin-layout {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 260px 1fr;
      }

      .main {
        display: flex;
        flex-direction: column;
      }

      .topbar {
        height: 72px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0 28px;
        gap: 18px;
      }

      .admin-user {
        color: #8b8b8b;
        font-size: 0.95rem;
      }

      .logout {
        color: #ff5d5d;
        text-decoration: none;
        font-size: 0.95rem;
      }

      .content {
        padding: 28px;
      }

      @media (max-width: 980px) {
        .admin-layout {
          grid-template-columns: 1fr;
        }

        .topbar {
          justify-content: space-between;
          padding: 0 18px;
        }

        .content {
          padding: 18px;
        }
      }
    </style>
  </head>
  <body>
    <div class="admin-layout">
      <AdminSidebar />
      <main class="main">
        <div class="topbar">
          <div class="admin-user">{adminName} — Admin</div>
          <a class="logout" href="/" id="logoutLink">Cerrar sesión</a>
        </div>

        <section class="content">
          <slot />
        </section>
      </main>
    </div>

    <script>
      document.getElementById("logoutLink")?.addEventListener("click", async (e) => {
        e.preventDefault();

        try {
          const response = await fetch(
            "/backend/logout.php",
            {
              method: "POST",
              credentials: "include",
            }
          );

          const data = await response.json();

          if (data.ok) {
            window.location.href = "/";
          }
        } catch (error) {
          console.error("Error cerrando sesión:", error);
        }
      });
    </script>
  </body>
</html>