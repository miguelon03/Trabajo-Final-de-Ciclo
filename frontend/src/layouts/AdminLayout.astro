---
const { title = "DMH Admin" } = Astro.props;
import AdminSidebar from "../components/admin/AdminSidebar.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="/dmh-utils.js" is:inline></script>

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap');
      :root {
        --bg: #0a0a0a;
        --text: #f5f5f5;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Poppins', sans-serif;
        overflow-x: hidden;
      }

      .admin-layout {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 200px minmax(0, 1fr);
      }

      .main {
        min-width: 0;
      }

      .content {
        min-width: 0;
        padding: clamp(20px, 3vw, 38px);
      }

      @media (max-width: 1100px) {
        .admin-layout {
          grid-template-columns: 190px minmax(0, 1fr);
        }
      }

      @media (max-width: 980px) {
        .admin-layout {
          grid-template-columns: 1fr;
        }

        .content {
          padding: 18px;
        }
      }

      @media (max-width: 640px) {
        .content {
          padding: 14px;
        }
      }
    </style>

    <style is:global>
      .topbar,
      .admin-user {
        display: none !important;
      }

      .admin-section,
      .returns-admin,
      .reviews-admin,
      .users-admin {
        width: 100%;
        min-width: 0;
      }
    </style>
  </head>

  <body>
    <div class="admin-layout" id="adminLayoutRoot">
      <AdminSidebar />

      <main class="main">
        <section class="content">
          <slot />
        </section>
      </main>
    </div>

    <script>
      const adminLayoutRoot = document.getElementById("adminLayoutRoot");

      document.querySelectorAll(".topbar, .admin-user").forEach((el) => {
        if (el instanceof HTMLElement) el.remove();
      });

      if (adminLayoutRoot instanceof HTMLElement) {
        adminLayoutRoot.style.visibility = "hidden";
      }

      async function ensureAdminSession() {
        try {
          const response = await fetch("/backend/session.php", {
            credentials: "include",
          });
          const data = await response.json();
          const isAdmin = Boolean(data?.logueado && data?.usuario?.rol === "admin");

          if (!isAdmin) {
            window.location.href = "/?auth=login";
            return;
          }

          if (adminLayoutRoot instanceof HTMLElement) {
            adminLayoutRoot.style.visibility = "visible";
          }
        } catch (_error) {
          window.location.href = "/?auth=login";
        }
      }

      void ensureAdminSession();

      document.getElementById("logoutLink")?.addEventListener("click", async (e) => {
        e.preventDefault();

        try {
          const response = await fetch("/backend/logout.php", {
            method: "POST",
            credentials: "include",
          });
          const data = await response.json();
          if (data.ok) {
            window.location.href = "/";
          }
        } catch (error) {
          console.error("Error cerrando sesión:", error);
        }
      });
    </script>
  </body>
</html>
