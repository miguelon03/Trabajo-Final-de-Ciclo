---
import { instagramIcon, tiktokIcon } from "./icons";
---

<footer class="site-footer">
  <div class="footer-grid">
    <!-- Columna legal con enlaces de cumplimiento -->
    <div class="footer-column">
      <p class="footer-title">LEGAL</p>
      <a href="/condiciones">Condiciones de uso</a>
      <a href="/privacidad">Política de privacidad</a>
      <a href="/cookies">Política de cookies</a>
    </div>

    <!-- Columna de ayuda y posventa -->
    <div class="footer-column">
      <p class="footer-title">SERVICIOS</p>
      <a href="/ayuda-online">Ayuda Online</a>
      <a href="/faq">FAQ</a>
    </div>

    <!-- Marca en el centro como ancla visual -->
    <div class="footer-brand">
      <img src="/logo-dmh.png" alt="DMH" />
    </div>

    <!-- Datos de contacto directo -->
    <div class="footer-column">
      <p class="footer-title">CONTACTO</p>
      <a href="mailto:dripmodehood@gmail.com">dripmodehood@gmail.com</a>
      
    </div>

    <!-- Enlaces sociales -->
    <div class="footer-column">
      <p class="footer-title">CONECTA</p>
      <div class="social-links">
        <a href="https://www.instagram.com/dripmodehood/" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <span set:html={instagramIcon}></span>
        </a>
        
      </div>
    </div>
  </div>

  <!-- Pie inferior con año dinámico -->
  <div class="footer-copy">
    <p>© {new Date().getFullYear()} DripMode Hood — Todos los derechos reservados</p>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    padding: 3rem 3rem 2rem;
    background: #0f0f0f;
    color: rgba(255, 255, 255, 0.82);
  }

  .footer-grid {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 2rem;
    align-items: start;
  }

  .footer-column {
    display: grid;
    gap: 0.85rem;
  }

  .footer-title {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.75rem;
    color: #C8FF00;
    font-weight: 700;
  }

  .footer-column a,
  .footer-column span {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.95rem;
    text-decoration: none;
  }

  .footer-column a:hover {
    color: #ffffff;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-brand img {
    display: block;
    width: clamp(150px, 18vw, 220px);
    height: auto;
    object-fit: contain;
  }

  .social-links {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: #ffffff;
    text-decoration: none;
    font-size: 0.85rem;
  }

  .social-links a span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .footer-copy {
    width: 100%;
    max-width: 1400px;
    margin: 1.5rem auto 0;
    text-align: center;
    color: rgba(255, 255, 255, 0.54);
    font-size: 0.9rem;
  }

  @media (max-width: 960px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding: 2rem 1.25rem 1.5rem;
    }

    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-copy {
      margin-top: 1.25rem;
    }

    .footer-brand img {
      width: 170px;
    }
  }
</style>
