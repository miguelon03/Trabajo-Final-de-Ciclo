---
const categories = [
  { label: "Todos", active: true },
  { label: "Camisetas" },
  { label: "Sudaderas" },
  { label: "Pantalones" },
  { label: "Accesorios" }
];

const novedades = [
  { title: "DMH Logo Tee Black", category: "Camisetas", price: "34,99€", badge: "NEW" },
  { title: "DMH Oversized Hoodie", category: "Sudaderas", price: "59,99€", badge: "NEW" },
  { title: "DMH Crewneck White", category: "Sudaderas", price: "54,99€" },
  { title: "DMH Cargo Pant", category: "Pantalones", price: "79,99€", note: "Pocas ud." }
];

const destacados = [
  { title: "DMH Cap Logo", category: "Accesorios", price: "24,99€" },
  { title: "DMH Bomber Jacket", category: "Outerwear", price: "129,99€", badge: "NEW" },
  { title: "DMH Track Pant", category: "Pantalones", price: "69,99€" },
  { title: "DMH Beanie Black", category: "Accesorios", price: "19,99€" }
];
---
<section class="products-section">
  <div class="products-section__container">
    <div class="products-section__top">
      <div>
        <p class="section-label">Categorías</p>
        <div class="categories-list">
          {categories.map((category) => (
            <button class={category.active ? "category-pill active" : "category-pill"} type="button">
              {category.label}
            </button>
          ))}
        </div>
      </div>

      <div class="section-heading">
        <p class="section-title">Novedades</p>
        <a class="section-link" href="/categoria/novedades">Ver todo →</a>
      </div>
    </div>

    <div class="products-grid">
      {novedades.map((item) => (
        <article class="product-card">
          <div class="product-card__top">
            {item.badge && <span class="badge">{item.badge}</span>}
            <button class="icon-fav" type="button" aria-label="Añadir a favoritos">♡</button>
          </div>
          <div class="product-card__image" aria-hidden="true">Imagen</div>
          <div class="product-card__content">
            <p class="product-category">{item.category}</p>
            <h3>{item.title}</h3>
            <div class="product-card__footer">
              <span class="product-price">{item.price}</span>
              {item.note && <span class="product-note">{item.note}</span>}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="products-section__heading-row">
      <p class="section-title">Destacados</p>
      <a class="section-link" href="/categoria/destacados">Ver todo →</a>
    </div>

    <div class="products-grid">
      {destacados.map((item) => (
        <article class="product-card">
          <div class="product-card__top">
            {item.badge && <span class="badge">{item.badge}</span>}
            <button class="icon-fav" type="button" aria-label="Añadir a favoritos">♡</button>
          </div>
          <div class="product-card__image" aria-hidden="true">Imagen</div>
          <div class="product-card__content">
            <p class="product-category">{item.category}</p>
            <h3>{item.title}</h3>
            <div class="product-card__footer">
              <span class="product-price">{item.price}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .products-section {
    width: 100%;
    padding: 3rem 3rem 4rem;
    background: #1a1a1a;
  }

  .products-section__container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    gap: 2.25rem;
  }

  .products-section__top,
  .products-section__heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-label {
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #C8FF00;
    font-size: 0.78rem;
  }

  .categories-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .category-pill {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: #f5f5f5;
    border-radius: 999px;
    padding: 0.85rem 1.25rem;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .category-pill.active,
  .category-pill:hover {
    background: rgba(200, 255, 0, 0.12);
    border-color: rgba(200, 255, 0, 0.45);
    color: #ffffff;
  }

  .section-heading,
  .products-section__heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-title {
    margin: 0;
    font-size: 1.4rem;
    letter-spacing: -0.02em;
    font-weight: 800;
    color: #ffffff;
  }

  .section-link {
    color: #C8FF00;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .products-grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
  }

  .product-card {
    background: #111111;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--border-radius-card);
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 1rem;
    padding: 1rem;
    min-height: 420px;
  }

  .product-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .badge {
    display: inline-flex;
    padding: 0.4rem 0.75rem;
    border-radius: var(--border-radius-sm);
    background: #C8FF00;
    color: #090909;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .icon-fav {
    border: none;
    background: rgba(255, 255, 255, 0.04);
    color: #f5f5f5;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .product-card__image {
    height: 260px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(0, 0, 0, 0.22));
    border-radius: 1.2rem;
    display: grid;
    place-items: center;
    color: rgba(255, 255, 255, 0.28);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.95rem;
  }

  .product-card__content {
    display: grid;
    gap: 0.5rem;
  }

  .product-category {
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .product-card h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.4;
  }

  .product-card__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .product-price {
    font-size: 1rem;
    font-weight: 800;
    color: #ffffff;
  }

  .product-note {
    background: rgba(255, 255, 255, 0.08);
    color: #f5f5f5;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 700;
  }

  @media (max-width: 1200px) {
    .products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .products-section {
      padding: 2rem 1.5rem 3rem;
    }

    .promo-banner,
    .products-section__container {
      padding: 0;
    }

    .products-section__top,
    .products-section__heading-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
