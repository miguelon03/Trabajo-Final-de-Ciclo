<style>
  /* Variables de color del diseño */
  :root {
    --bg: #050505;
    --panel: #0b0b0b;
    --input: #141414;
    --border: #2b2b2b;
    --text: #f5f5f5;
    --muted: #6f6f6f;
    --accent: #d9ff00;
    --accent-dark: #111111;
    --error: #ff6b6b;
    --success: #7dff98;
  }

  /* Ajuste global de caja */
  * {
    box-sizing: border-box;
  }

  /* Contenedor general de la página */
  .page {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: Arial, Helvetica, sans-serif;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 40px 16px;
    overflow-x: hidden;
  }

  /* Tarjeta del formulario */
  .login-card {
    width: min(100%, 460px);
  }

  /* Logo */
  .logo {
    text-align: center;
    color: var(--accent);
    font-size: clamp(2.8rem, 8vw, 5rem);
    font-weight: 900;
    letter-spacing: 0.18em;
    line-height: 1;
    margin: 0 0 16px;
  }

  /* Subtítulo */
  .subtitle {
    text-align: center;
    color: #4f4f4f;
    letter-spacing: 0.35em;
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    margin: 0 0 42px;
  }

  /* Cada campo del formulario */
  .field {
    margin-bottom: 28px;
  }

  .label {
    display: block;
    color: #787878;
    font-size: 0.95rem;
    margin-bottom: 10px;
  }

  .input {
    width: 100%;
    height: 52px;
    background: var(--input);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    padding: 0 14px;
    outline: none;
    font-size: 1rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .input:focus {
    border-color: #1597ff;
    box-shadow: 0 0 0 1px #1597ff inset;
  }

  /* Enlace de recuperar contraseña */
  .forgot-wrap {
    display: flex;
    justify-content: flex-end;
    margin-top: -8px;
    margin-bottom: 24px;
  }

  .forgot {
    color: var(--accent);
    font-size: 0.92rem;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Mensaje de éxito o error */
  .message {
    min-height: 24px;
    margin: 0 0 18px;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .message.error {
    color: var(--error);
  }

  .message.success {
    color: var(--success);
  }

  /* Botones */
  .btn {
    width: 100%;
    min-height: 52px;
    border-radius: 4px;
    border: none;
    font-weight: 800;
    font-size: 1rem;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      opacity 0.15s ease;
    text-decoration: none;
  }

  .btn:hover {
    opacity: 0.96;
  }

  .btn:active {
    transform: scale(0.99);
  }

  .btn-primary {
    background: var(--accent);
    color: #111;
    margin-bottom: 14px;
  }

  .divider {
    border: none;
    border-top: 1px solid #242424;
    margin: 38px 0;
  }

  .register-text {
    text-align: center;
    color: #666;
    font-size: 0.96rem;
    line-height: 1.5;
    margin: 0 0 22px;
  }

  .register-text a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #151515;
    color: #ffffff;
    border: 1px solid #313131;
  }

  .btn-home {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 52px;
    margin-top: 0;
    background: transparent;
    color: #d0d0d0;
    border: 1px solid #313131;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.98rem;
    transition:
      transform 0.15s ease,
      opacity 0.15s ease,
      border-color 0.15s ease;
  }

  .btn-home:hover {
    opacity: 0.96;
    border-color: #4a4a4a;
  }

  .btn-home:active {
    transform: scale(0.99);
  }

  .btn-home span {
    margin-right: 8px;
    font-size: 1rem;
  }

  /* Responsive */
  @media (max-width: 1024px), (max-height: 820px) {
    .page {
      padding-top: 28px;
      padding-bottom: 28px;
    }

    .logo {
      font-size: clamp(2.6rem, 7vw, 4rem);
      margin-bottom: 12px;
    }

    .subtitle {
      margin-bottom: 30px;
      letter-spacing: 0.28em;
    }

    .field {
      margin-bottom: 22px;
    }

    .divider {
      margin: 30px 0;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 24px 14px;
    }

    .login-card {
      width: 100%;
    }

    .logo {
      font-size: 2.5rem;
      letter-spacing: 0.14em;
    }

    .subtitle {
      font-size: 0.95rem;
      letter-spacing: 0.18em;
      margin-bottom: 24px;
    }

    .label {
      font-size: 0.92rem;
    }

    .input {
      height: 48px;
      font-size: 0.96rem;
    }

    .forgot-wrap {
      justify-content: center;
      margin-top: -4px;
      margin-bottom: 20px;
    }

    .forgot {
      font-size: 0.9rem;
      text-align: center;
    }

    .btn,
    .btn-home {
      min-height: 48px;
      font-size: 0.96rem;
    }

    .register-text {
      font-size: 0.92rem;
      margin-bottom: 18px;
    }
  }

  @media (max-width: 380px) {
    .page {
      padding: 20px 12px;
    }

    .logo {
      font-size: 2.15rem;
    }

    .subtitle {
      font-size: 0.88rem;
      letter-spacing: 0.14em;
    }

    .input,
    .btn,
    .btn-home {
      min-height: 46px;
    }
  }
</style>

<section class="page">
  <div class="login-card">
    <h1 class="logo">DMH</h1>
    <p class="subtitle">INICIA SESIÓN</p>

    <!-- Formulario de login -->
    <form id="loginForm">
      <div class="field">
        <label class="label" for="email">Email</label>
        <input class="input" type="email" id="email" name="email" />
      </div>

      <div class="field">
        <label class="label" for="contrasena">Contraseña</label>
        <input
          class="input"
          type="password"
          id="contrasena"
          name="contrasena"
        />
      </div>

      <div class="forgot-wrap">
        <a class="forgot" href="#">He olvidado mi contraseña</a>
      </div>

      <!-- Mensaje dinámico -->
      <p id="loginMessage" class="message"></p>

      <button class="btn btn-primary" type="submit">
        INICIAR SESIÓN
      </button>

      <a class="btn-home" href="/">
        <span>←</span> Volver al inicio
      </a>
    </form>

    <hr class="divider" />

    <p class="register-text">
      ¿Aún no tienes una cuenta? <a href="/registro">Regístrate</a>
    </p>

    <a class="btn btn-secondary" href="/registro"> CREAR CUENTA → </a>
  </div>

  <script>
    // Referencias al formulario y al área de mensajes
    const loginForm = document.getElementById("loginForm");
    const loginMessage = document.getElementById("loginMessage");

    if (
      loginForm instanceof HTMLFormElement &&
      loginMessage instanceof HTMLElement
    ) {
      loginForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        // Limpiamos mensaje anterior
        loginMessage.textContent = "";
        loginMessage.className = "message";

        // Recogemos los datos del formulario
        const formData = new FormData(loginForm);

        try {
          // Enviamos el formulario al backend
          const response = await fetch(
            "http://tfc.local/backend/login.php",
            {
              method: "POST",
              body: formData,
              credentials: "include",
            },
          );

          const data = await response.json();

          if (data.ok) {
            // Si el login es correcto, mostramos éxito y redirigimos
            loginMessage.textContent = "Inicio de sesión correcto";
            loginMessage.className = "message success";

            setTimeout(() => {
              window.location.href = data.redirect || "/";
            }, 800);
          } else {
            // Si falla, mostramos el error devuelto por el backend
            loginMessage.textContent =
              data.error || "Error al iniciar sesión";
            loginMessage.className = "message error";
          }
        } catch (error) {
          // Error de red o de conexión con el servidor
          loginMessage.textContent =
            "Error de conexión con el servidor";
          loginMessage.className = "message error";
        }
      });
    }
  </script>
</section>