---
/* Importamos los iconos SVG usados en la cabecera */
import { searchIcon, heartIcon, userIcon, cartIcon } from "./icons.ts";

/* Importamos el JSON de productos para alimentar el buscador */
import productsRaw from "../data/products.json";

/* Transformamos los productos para quedarnos solo con slug y título */
const searchData = (productsRaw as Array<{ slug: string; title: string }>).map(
  (p) => ({
    slug: p.slug,
    title: p.title,
  }),
);

const currentPath = Astro.url.pathname;

function isActivePath(path: string) {
  return currentPath === path || currentPath.startsWith(`${path}/`);
}
---

<header class="site-header">
  <!-- Bloque izquierdo: logo + navegación principal -->
  <div class="site-header__brand-nav">
    <a class="brand" href="/">DMH</a>

    <nav class="site-nav" aria-label="Navegación principal">
      <a class={`site-nav__link ${isActivePath("/catalogo") ? "active" : ""}`} href="/catalogo">Catálogo</a>
      <a class={`site-nav__link ${isActivePath("/novedades") ? "active" : ""}`} href="/novedades">Novedades</a>
      <a class={`site-nav__link ${isActivePath("/accesorios") ? "active" : ""}`} href="/accesorios">Accesorios</a>
      <a class={`site-nav__link ${isActivePath("/ofertas") ? "active" : ""}`} href="/ofertas">Ofertas</a>
    </nav>
  </div>

  <!-- Bloque derecho: búsqueda + favoritos + cuenta + carrito -->
  <div class="site-header__actions">
    <!-- Buscador expandible -->
    <div class="search-wrapper" id="searchWrapper">
      <div class="search-expand" id="searchExpand">
        <input
          type="search"
          id="searchInput"
          class="search-input"
          placeholder="Buscar productos…"
          autocomplete="off"
          aria-label="Buscar productos"
          aria-expanded="false"
        />
      </div>

      <!-- Lista de sugerencias del buscador -->
      <ul class="search-suggestions" id="searchSuggestions" role="listbox"></ul>

      <!-- Botón del buscador -->
      <button
        class="icon-button"
        id="searchBtn"
        type="button"
        aria-label="Buscar"
        set:html={searchIcon}
      />
    </div>

    <!-- Botón de favoritos -->
    <button
      class="icon-button"
      type="button"
      aria-label="Favoritos"
      set:html={heartIcon}
    />

    <!-- Menú de cuenta de usuario -->
    <div class="account-menu" id="accountMenu">
      <button
        id="accountButton"
        class="icon-button"
        type="button"
        aria-label="Cuenta"
        aria-expanded="false"
      >
        <span set:html={userIcon} />
      </button>

      <!-- Desplegable del usuario -->
      <div class="account-dropdown" id="accountDropdown">
        <a id="profileLink" href="/login">Mi perfil</a>
        <a id="ordersLink" href="/login">Mis pedidos</a>
        <a id="favoritesLink" href="/login">Favoritos</a>
        <button id="logoutBtn" type="button">Cerrar sesión</button>
      </div>
    </div>

    <!-- Botón del carrito con contador -->
    <a class="cart-button" href="/carrito" aria-label="Carrito de compras">
      <span class="cart-icon" set:html={cartIcon} />
      <span class="cart-badge" id="cart-badge">0</span>
    </a>
  </div>

  <style>
    /* Contenedor principal del header */
    .site-header {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      color: #f5f5f5;
    }

    /* Logo / marca */
    .brand {
      font-family: Inter, system-ui, sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      color: #d7ff00;
      text-transform: uppercase;
      margin-right: 2rem;
    }

    /* Navegación principal */
    .site-nav {
      display: flex;
      gap: 1.6rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .site-nav__link {
      color: rgba(245, 245, 245, 0.8);
      font-size: 0.95rem;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .site-nav__link:hover,
    .site-nav__link.active {
      color: #ffffff;
    }

    .site-header__brand-nav {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .site-header__actions {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      flex-wrap: wrap;
    }

    /* Botones redondos de iconos */
    .icon-button,
    .cart-button {
      border: none;
      background: rgba(255, 255, 255, 0.04);
      color: #f5f5f5;
      width: 42px;
      height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      cursor: pointer;
      transition:
        background 0.2s ease,
        transform 0.2s ease;
      text-decoration: none;
    }

    .icon-button:hover,
    .cart-button:hover {
      background: rgba(255, 255, 255, 0.12);
      transform: translateY(-1px);
    }

    /* Carrito con badge */
    .cart-button {
      position: relative;
    }

    .cart-badge {
      position: absolute;
      top: -6px;
      right: -6px;
      min-width: 18px;
      height: 18px;
      border-radius: 999px;
      background: #d7ff00;
      color: #090909;
      font-size: 0.75rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 0.35rem;
      transition: transform 0.15s ease;
    }

    /* Animación del badge del carrito al actualizarse */
    @keyframes badge-bump {
      0% { transform: scale(1); }
      40% { transform: scale(1.55); }
      70% { transform: scale(0.9); }
      100% { transform: scale(1); }
    }

    .cart-badge.is-bumping {
      animation: badge-bump 0.35s ease forwards;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .site-header {
        flex-direction: column;
        align-items: flex-start;
        padding: 1rem 1.5rem;
      }

      .site-header__actions {
        width: 100%;
        justify-content: flex-start;
      }
    }

    @media (max-width: 640px) {
      .site-header {
        padding: 0.9rem 1rem;
      }

      .site-nav {
        gap: 1rem;
      }
    }

    /* Buscador */
    .search-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    .search-expand {
      width: 0;
      overflow: hidden;
      transition: width 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-expand.is-open {
      width: 260px;
      margin-right: 0.5rem;
    }

    #searchBtn.is-active {
      color: #c8ff00;
      background: rgba(200, 255, 0, 0.08);
    }

    #searchBtn.is-active svg {
      stroke: #c8ff00;
    }

    .search-input {
      width: 100%;
      height: 42px;
      background: rgba(255, 255, 255, 0.07);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 999px;
      color: #f5f5f5;
      padding: 0 1.1rem;
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.2s;
      white-space: nowrap;
    }

    .search-input:focus {
      border-color: rgba(200, 255, 0, 0.45);
    }

    .search-input::-webkit-search-cancel-button {
      display: none;
    }

    .search-suggestions {
      position: absolute;
      top: calc(100% + 6px);
      right: 42px;
      width: 260px;
      background: #1a1a1a;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      list-style: none;
      padding: 0.35rem 0;
      margin: 0;
      z-index: 200;
      display: none;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
    }

    .search-suggestions :global(li) {
      padding: 0.6rem 1rem;
      cursor: pointer;
      font-size: 0.88rem;
      color: rgba(255, 255, 255, 0.75);
      transition: background 0.15s;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .search-suggestions :global(li:hover) {
      background: rgba(200, 255, 0, 0.07);
      color: #f5f5f5;
    }

    .search-suggestions :global(mark) {
      background: transparent;
      color: #c8ff00;
      font-weight: 600;
    }

    /* Menú de cuenta */
    .account-menu {
      position: relative;
    }

    .account-dropdown {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      min-width: 190px;
      background: #151515;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 14px;
      padding: 0.5rem;
      display: none;
      flex-direction: column;
      gap: 0.3rem;
      z-index: 300;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.45);
    }

    .account-dropdown.is-open {
      display: flex;
    }

    .account-dropdown a,
    .account-dropdown button {
      width: 100%;
      border: none;
      background: transparent;
      color: #f5f5f5;
      text-decoration: none;
      text-align: left;
      padding: 0.8rem 0.9rem;
      border-radius: 10px;
      font-size: 0.92rem;
      cursor: pointer;
      transition:
        background 0.2s ease,
        color 0.2s ease;
    }

    .account-dropdown a:hover,
    .account-dropdown button:hover {
      background: rgba(215, 255, 0, 0.08);
      color: #d7ff00;
    }
  </style>

  <script>
    // Actualiza el contador visual del carrito leyendo localStorage
    function updateCartBadge(bump = false) {
      const cart = JSON.parse(localStorage.getItem("cart") || "[]") as Array<{
        quantity?: number;
      }>;

      const total = cart.reduce(
        (sum: number, item: { quantity?: number }) =>
          sum + (item.quantity || 1),
        0,
      );

      const badge = document.getElementById("cart-badge");

      if (badge) {
        badge.textContent = String(total);
        badge.style.display = total > 0 ? "flex" : "none";

        if (bump && total > 0) {
          badge.classList.remove("is-bumping");
          void badge.offsetWidth;
          badge.classList.add("is-bumping");
          badge.addEventListener(
            "animationend",
            () => badge.classList.remove("is-bumping"),
            { once: true },
          );
        }
      }
    }

    // Consulta la sesión al backend y adapta el menú de usuario
    async function updateSessionUI() {
      const profileLink = document.getElementById(
        "profileLink",
      ) as HTMLAnchorElement | null;
      const ordersLink = document.getElementById(
        "ordersLink",
      ) as HTMLAnchorElement | null;
      const favoritesLink = document.getElementById(
        "favoritesLink",
      ) as HTMLAnchorElement | null;
      const accountButton = document.getElementById(
        "accountButton",
      ) as HTMLButtonElement | null;
      const logoutBtn = document.getElementById(
        "logoutBtn",
      ) as HTMLButtonElement | null;
      const accountDropdown = document.getElementById(
        "accountDropdown",
      ) as HTMLDivElement | null;
      const accountMenu = document.getElementById(
        "accountMenu",
      ) as HTMLDivElement | null;

      if (
        !accountButton ||
        !accountDropdown ||
        !profileLink ||
        !ordersLink ||
        !favoritesLink ||
        !logoutBtn ||
        !accountMenu
      ) {
        return;
      }

      try {
        // Pedimos al backend información de la sesión actual
        const response = await fetch(
          "http://localhost/TrabajoFinalDeCiclo/backend/session.php",
          {
            credentials: "include",
          },
        );

        const data = await response.json();

        // Si hay usuario logueado, activamos el desplegable
        if (data.logueado && data.usuario) {
          const isAdmin = data.usuario.rol === "admin";

          // Las rutas cambian según sea admin o cliente
          profileLink.href = isAdmin ? "/admin" : "/usuario";
          ordersLink.href = isAdmin ? "/admin/pedidos" : "/usuario/pedidos";
          favoritesLink.href = isAdmin ? "/admin" : "/usuario/favoritos";

          // Al pulsar el icono se abre o cierra el menú desplegable
          accountButton.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();

            const isOpen = accountDropdown.classList.toggle("is-open");
            accountButton.setAttribute("aria-expanded", String(isOpen));
          });

          // Si haces clic fuera del menú, se cierra
          document.addEventListener("click", (e) => {
            const target = e.target as Node | null;

            if (accountMenu && target && !accountMenu.contains(target)) {
              accountDropdown?.classList.remove("is-open");
              accountButton?.setAttribute("aria-expanded", "false");
            }
          });

          // Botón para cerrar sesión
          logoutBtn.addEventListener("click", async () => {
            try {
              const logoutResponse = await fetch(
                "http://localhost/TrabajoFinalDeCiclo/backend/logout.php",
                {
                  method: "POST",
                  credentials: "include",
                },
              );

              const logoutData = await logoutResponse.json();

              if (logoutData.ok) {
                window.location.href = "/";
              }
            } catch (error) {
              console.error("Error cerrando sesión:", error);
            }
          });
        } else {
          // Si no hay sesión, el botón de usuario lleva al login
          profileLink.href = "/login";
          ordersLink.href = "/login";
          favoritesLink.href = "/login";

          accountButton.addEventListener("click", () => {
            window.location.href = "/login";
          });

          // Ocultamos el botón de cerrar sesión
          logoutBtn.style.display = "none";
        }
      } catch (error) {
        console.error("Error leyendo sesión:", error);
      }
    }

    // Inicializamos el badge del carrito y el estado de la sesión
    updateCartBadge();
    updateSessionUI();

    // Escuchamos eventos personalizados para refrescar el carrito al añadir productos
    window.addEventListener("cart-updated", () => updateCartBadge(true));
  </script>

  <script define:vars={{ searchData }}>
    // @ts-nocheck

    // Referencias a los elementos del buscador
    const searchWrapper = document.getElementById("searchWrapper");
    const searchExpand = document.getElementById("searchExpand");
    const searchInput = document.getElementById("searchInput");
    const searchBtn = document.getElementById("searchBtn");
    const searchSuggestions = document.getElementById("searchSuggestions");
    let isOpen = false;

    // Abre el buscador expandible
    function openSearch() {
      isOpen = true;
      searchExpand.classList.add("is-open");
      searchBtn.classList.add("is-active");
      searchInput.setAttribute("aria-expanded", "true");
      setTimeout(() => searchInput.focus(), 40);
    }

    // Cierra el buscador y limpia sugerencias
    function closeSearch() {
      isOpen = false;
      searchExpand.classList.remove("is-open");
      searchBtn.classList.remove("is-active");
      searchInput.setAttribute("aria-expanded", "false");
      searchInput.value = "";
      hideSuggestions();
    }

    // Redirige a la página de resultados de búsqueda
    function doSearch() {
      const q = searchInput.value.trim();
      if (q) window.location.href = "/buscar?q=" + encodeURIComponent(q);
    }

    // Escapa caracteres especiales para construir una expresión regular segura
    function escRe(str) {
      return str.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }

    // Muestra sugerencias en tiempo real según el texto escrito
    function renderSuggestions(q) {
      if (!q.trim()) {
        hideSuggestions();
        return;
      }

      const lq = q.toLowerCase();

      const matches = searchData
        .filter((p) => p.title.toLowerCase().includes(lq))
        .slice(0, 6);

      if (!matches.length) {
        hideSuggestions();
        return;
      }

      const re = new RegExp(escRe(q), "gi");

      searchSuggestions.innerHTML = matches
        .map(
          (p) =>
            '<li data-slug="' +
            p.slug +
            '" role="option">' +
            p.title.replace(re, (m) => "<mark>" + m + "</mark>") +
            "</li>",
        )
        .join("");

      searchSuggestions.style.display = "block";

      // Al pulsar una sugerencia, redirige a la página del producto
      searchSuggestions.querySelectorAll("li").forEach((li) => {
        li.addEventListener("click", () => {
          window.location.href = "/producto/" + li.dataset.slug;
        });
      });
    }

    // Oculta y limpia la lista de sugerencias
    function hideSuggestions() {
      searchSuggestions.style.display = "none";
      searchSuggestions.innerHTML = "";
    }

    // Lógica del botón de búsqueda
    searchBtn.addEventListener("click", () => {
      if (!isOpen) {
        openSearch();
        return;
      }

      if (searchInput.value.trim()) {
        doSearch();
      } else {
        closeSearch();
      }
    });

    // Actualiza sugerencias mientras el usuario escribe
    searchInput.addEventListener("input", () =>
      renderSuggestions(searchInput.value),
    );

    // Enter busca, Escape cierra
    searchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        doSearch();
      } else if (e.key === "Escape") {
        closeSearch();
      }
    });

    // Si se hace clic fuera del buscador, se cierra
    document.addEventListener("click", (e) => {
      if (searchWrapper && !searchWrapper.contains(e.target)) {
        closeSearch();
      }
    });
  </script>
</header>