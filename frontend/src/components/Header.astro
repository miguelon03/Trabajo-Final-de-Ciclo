---
import { searchIcon, heartIcon, userIcon, cartIcon } from "./icons.ts";
import productsRaw from "../data/products.json";
const searchData = (productsRaw as Array<{ slug: string; title: string }>).map((p) => ({ slug: p.slug, title: p.title }));
---

<header class="site-header">
  <div class="site-header__brand-nav">
    <a class="brand" href="/">DMH</a>
    <nav class="site-nav" aria-label="Navegación principal">
      <a class="site-nav__link active" href="/catalogo">Catálogo</a>
      <a class="site-nav__link" href="/categoria/novedades">Novedades</a>
      <a class="site-nav__link" href="/categoria/accesorios">Accesorios</a>
      <a class="site-nav__link" href="/categoria/ofertas">Ofertas</a>
    </nav>
  </div>

  <div class="site-header__actions">
    <div class="search-wrapper" id="searchWrapper">
      <div class="search-expand" id="searchExpand">
        <input
          type="search"
          id="searchInput"
          class="search-input"
          placeholder="Buscar productos…"
          autocomplete="off"
          aria-label="Buscar productos"
          aria-expanded="false"
        />
      </div>
      <ul class="search-suggestions" id="searchSuggestions" role="listbox"></ul>
      <button class="icon-button" id="searchBtn" type="button" aria-label="Buscar" set:html={searchIcon}></button>
    </div>
    <button class="icon-button" type="button" aria-label="Favoritos" set:html={heartIcon}></button>
    <button class="icon-button" type="button" aria-label="Cuenta" set:html={userIcon}></button>
    <a class="cart-button" href="/carrito" aria-label="Carrito de compras">
      <span class="cart-icon" set:html={cartIcon}></span>
      <span class="cart-badge" id="cart-badge">0</span>
    </a>
  </div>

  <style>
    .site-header {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      color: #f5f5f5;
    }

    .brand {
      font-family: Inter, system-ui, sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      color: #d7ff00;
      text-transform: uppercase;
      margin-right: 2rem;
    }

    .site-nav {
      display: flex;
      gap: 1.6rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .site-nav__link {
      color: rgba(245, 245, 245, 0.8);
      font-size: 0.95rem;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .site-nav__link:hover,
    .site-nav__link.active {
      color: #ffffff;
    }

    .site-header__brand-nav {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .site-header__actions {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      flex-wrap: wrap;
    }

    .icon-button,
    .cart-button {
      border: none;
      background: rgba(255, 255, 255, 0.04);
      color: #f5f5f5;
      width: 42px;
      height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.2s ease;
      text-decoration: none;
    }

    .icon-button:hover,
    .cart-button:hover {
      background: rgba(255, 255, 255, 0.12);
      transform: translateY(-1px);
    }

    .cart-button {
      position: relative;
    }

    .cart-badge {
      position: absolute;
      top: -6px;
      right: -6px;
      min-width: 18px;
      height: 18px;
      border-radius: 999px;
      background: #d7ff00;
      color: #090909;
      font-size: 0.75rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 0.35rem;
      transition: transform 0.15s ease;
    }

    @keyframes badge-bump {
      0%   { transform: scale(1); }
      40%  { transform: scale(1.55); }
      70%  { transform: scale(0.9); }
      100% { transform: scale(1); }
    }

    .cart-badge.is-bumping {
      animation: badge-bump 0.35s ease forwards;
    }

    @media (max-width: 900px) {
      .site-header {
        flex-direction: column;
        align-items: flex-start;
        padding: 1rem 1.5rem;
      }

      .site-header__actions {
        width: 100%;
        justify-content: flex-start;
      }
    }

    @media (max-width: 640px) {
      .site-header {
        padding: 0.9rem 1rem;
      }

      .site-nav {
        gap: 1rem;
      }
    }

    /* ── Search ── */
    .search-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    .search-expand {
      width: 0;
      overflow: hidden;
      transition: width 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-expand.is-open {
      width: 260px;
      margin-right: 0.5rem;
    }

    #searchBtn.is-active {
      color: #c8ff00;
      background: rgba(200, 255, 0, 0.08);
    }

    #searchBtn.is-active svg {
      stroke: #c8ff00;
    }

    .search-input {
      width: 100%;
      height: 42px;
      background: rgba(255, 255, 255, 0.07);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 999px;
      color: #f5f5f5;
      padding: 0 1.1rem;
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.2s;
      white-space: nowrap;
    }

    .search-input:focus {
      border-color: rgba(200, 255, 0, 0.45);
    }

    .search-input::-webkit-search-cancel-button {
      display: none;
    }

    .search-suggestions {
      position: absolute;
      top: calc(100% + 6px);
      right: 42px;
      width: 260px;
      background: #1a1a1a;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      list-style: none;
      padding: 0.35rem 0;
      margin: 0;
      z-index: 200;
      display: none;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
    }

    .search-suggestions :global(li) {
      padding: 0.6rem 1rem;
      cursor: pointer;
      font-size: 0.88rem;
      color: rgba(255, 255, 255, 0.75);
      transition: background 0.15s;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .search-suggestions :global(li:hover) {
      background: rgba(200, 255, 0, 0.07);
      color: #f5f5f5;
    }

    .search-suggestions :global(mark) {
      background: transparent;
      color: #c8ff00;
      font-weight: 600;
    }
  </style>

<script>
  function updateCartBadge(bump = false) {
    const cart = JSON.parse(localStorage.getItem('cart') || '[]') as Array<{ quantity?: number }>;
    const total = cart.reduce((sum: number, item: { quantity?: number }) => sum + (item.quantity || 1), 0);
    const badge = document.getElementById('cart-badge');
    if (badge) {
      badge.textContent = String(total);
      badge.style.display = total > 0 ? 'flex' : 'none';
      if (bump && total > 0) {
        badge.classList.remove('is-bumping');
        void badge.offsetWidth; // reflow
        badge.classList.add('is-bumping');
        badge.addEventListener('animationend', () => badge.classList.remove('is-bumping'), { once: true });
      }
    }
  }

  updateCartBadge();
  window.addEventListener('cart-updated', () => updateCartBadge(true));
</script>

<script define:vars={{ searchData }}>
  // @ts-nocheck
  const searchWrapper = document.getElementById('searchWrapper');
  const searchExpand = document.getElementById('searchExpand');
  const searchInput = document.getElementById('searchInput');
  const searchBtn = document.getElementById('searchBtn');
  const searchSuggestions = document.getElementById('searchSuggestions');
  let isOpen = false;

  function openSearch() {
    isOpen = true;
    searchExpand.classList.add('is-open');
    searchBtn.classList.add('is-active');
    searchInput.setAttribute('aria-expanded', 'true');
    setTimeout(() => searchInput.focus(), 40);
  }

  function closeSearch() {
    isOpen = false;
    searchExpand.classList.remove('is-open');
    searchBtn.classList.remove('is-active');
    searchInput.setAttribute('aria-expanded', 'false');
    searchInput.value = '';
    hideSuggestions();
  }

  function doSearch() {
    const q = searchInput.value.trim();
    if (q) window.location.href = '/buscar?q=' + encodeURIComponent(q);
  }

  function escRe(str) {
    return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function renderSuggestions(q) {
    if (!q.trim()) { hideSuggestions(); return; }
    const lq = q.toLowerCase();
    const matches = searchData.filter(p => p.title.toLowerCase().includes(lq)).slice(0, 6);
    if (!matches.length) { hideSuggestions(); return; }
    const re = new RegExp(escRe(q), 'gi');
    searchSuggestions.innerHTML = matches
      .map(p => '<li data-slug="' + p.slug + '" role="option">' + p.title.replace(re, m => '<mark>' + m + '</mark>') + '</li>')
      .join('');
    searchSuggestions.style.display = 'block';
    searchSuggestions.querySelectorAll('li').forEach(li => {
      li.addEventListener('click', () => { window.location.href = '/producto/' + li.dataset.slug; });
    });
  }

  function hideSuggestions() {
    searchSuggestions.style.display = 'none';
    searchSuggestions.innerHTML = '';
  }

  searchBtn.addEventListener('click', () => {
    if (!isOpen) { openSearch(); return; }
    if (searchInput.value.trim()) { doSearch(); } else { closeSearch(); }
  });

  searchInput.addEventListener('input', () => renderSuggestions(searchInput.value));

  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { doSearch(); }
    else if (e.key === 'Escape') { closeSearch(); }
  });

  document.addEventListener('click', (e) => {
    if (searchWrapper && !searchWrapper.contains(e.target)) closeSearch();
  });
</script>
