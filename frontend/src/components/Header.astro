---
/* Importamos los iconos SVG usados en la cabecera */
import { searchIcon, userIcon, cartIcon } from "./icons.ts";
import { fetchCatalogData } from "../lib/catalog-api";

/* Cargamos productos desde la API para alimentar el buscador */
const { products: productsRaw } = await fetchCatalogData();

/* Transformamos los productos para quedarnos solo con slug y título */
const searchData = (productsRaw as Array<{ slug: string; title: string }>).map(
  (p) => ({
    slug: p.slug,
    title: p.title,
  }),
);

const currentPath = Astro.url.pathname;

function isActivePath(path: string) {
  return currentPath === path || currentPath.startsWith(`${path}/`);
}
---

<header class="site-header">
  <div class="site-header__brand-nav">
    <a class="brand" href="/" aria-label="Inicio DMH">
      <img src="/logo-dmh.png" alt="DMH" />
    </a>

    <nav id="siteNav" class="site-nav" aria-label="Navegación principal">
      <a class={`site-nav__link ${isActivePath("/catalogo") ? "active" : ""}`} href="/catalogo">Catálogo</a>
      <a class={`site-nav__link ${isActivePath("/novedades") ? "active" : ""}`} href="/novedades">Novedades</a>
      <a class={`site-nav__link ${isActivePath("/accesorios") ? "active" : ""}`} href="/accesorios">Accesorios</a>
      <a class={`site-nav__link ${isActivePath("/ofertas") ? "active" : ""}`} href="/ofertas">Ofertas</a>
    </nav>
  </div>

  <div class="site-header__actions">
    <div class="search-wrapper" id="searchWrapper">
      <div class="search-expand" id="searchExpand">
        <input
          type="search"
          id="searchInput"
          class="search-input"
          placeholder="Buscar productos…"
          autocomplete="off"
          aria-label="Buscar productos"
          aria-expanded="false"
        />
      </div>

      <ul class="search-suggestions" id="searchSuggestions" role="listbox"></ul>

      <button
        class="icon-button"
        id="searchBtn"
        type="button"
        aria-label="Buscar"
        set:html={searchIcon}
      />
    </div>

    <div class="account-menu" id="accountMenu">
      <button
        id="accountButton"
        class="icon-button"
        type="button"
        aria-label="Cuenta"
        aria-expanded="false"
      >
        <span set:html={userIcon} />
      </button>

      <div class="account-dropdown" id="accountDropdown">
        <a id="profileLink" href="/login">Mi perfil</a>
        <a id="ordersLink" href="/login">Mis pedidos</a>
        <a id="favoritesLink" href="/login">Favoritos</a>
        <button id="logoutBtn" type="button">Cerrar sesión</button>
      </div>
    </div>

    <a class="cart-button" href="/carrito" aria-label="Carrito de compras">
      <span class="cart-icon" set:html={cartIcon} />
      <span class="cart-badge" id="cart-badge">0</span>
    </a>

    <button
      id="menuToggle"
      class="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-controls="siteNav"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <style>
    .site-header {
      width: 100%;
      max-width: 1240px;
      margin: 0 auto;
      padding: 1.15rem clamp(1rem, 2.8vw, 2.5rem);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      color: #f5f5f5;
      position: relative;
    }

    .site-header__brand-nav {
      display: flex;
      align-items: center;
      gap: 1.75rem;
      min-width: 0;
      flex: 1 1 auto;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      width: clamp(132px, 12vw, 172px);
      height: clamp(34px, 3vw, 44px);
      overflow: hidden;
      flex-shrink: 0;
    }

    .brand img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    .site-nav {
      display: flex;
      align-items: center;
      gap: 1.8rem;
      min-width: 0;
      flex-wrap: wrap;
    }

    .site-nav__link {
      color: rgba(245, 245, 245, 0.8);
      font-size: 0.95rem;
      text-decoration: none;
      transition: color 0.2s ease;
      white-space: nowrap;
    }

    .site-nav__link:hover,
    .site-nav__link.active {
      color: #ffffff;
    }

    .site-header__actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.75rem;
      min-width: 0;
      flex-shrink: 0;
    }

    .icon-button,
    .cart-button,
    .menu-toggle {
      border: none;
      background: rgba(255, 255, 255, 0.04);
      color: #f5f5f5;
      width: 42px;
      height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      cursor: pointer;
      transition:
        background 0.2s ease,
        transform 0.2s ease;
      text-decoration: none;
      flex-shrink: 0;
    }

    .icon-button:hover,
    .cart-button:hover,
    .menu-toggle:hover {
      background: rgba(255, 255, 255, 0.12);
      transform: translateY(-1px);
    }

    .cart-button {
      position: relative;
    }

    .cart-badge {
      position: absolute;
      top: -6px;
      right: -6px;
      min-width: 18px;
      height: 18px;
      border-radius: 999px;
      background: #d7ff00;
      color: #090909;
      font-size: 0.75rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 0.35rem;
      transition: transform 0.15s ease;
    }

    @keyframes badge-bump {
      0% { transform: scale(1); }
      40% { transform: scale(1.55); }
      70% { transform: scale(0.9); }
      100% { transform: scale(1); }
    }

    .cart-badge.is-bumping {
      animation: badge-bump 0.35s ease forwards;
    }

    .search-wrapper {
      position: relative;
      display: flex;
      align-items: center;
      min-width: 0;
      max-width: 320px;
    }

    .search-expand {
      width: 0;
      min-width: 0;
      overflow: hidden;
      transition: width 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-expand.is-open {
      width: 260px;
      margin-right: 0.5rem;
    }

    #searchBtn.is-active {
      color: #c8ff00;
      background: rgba(200, 255, 0, 0.08);
    }

    #searchBtn.is-active svg {
      stroke: #c8ff00;
    }

    .search-input {
      width: 100%;
      height: 42px;
      background: rgba(255, 255, 255, 0.07);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 999px;
      color: #f5f5f5;
      padding: 0 1.1rem;
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }

    .search-input:focus {
      border-color: rgba(200, 255, 0, 0.45);
    }

    .search-input::-webkit-search-cancel-button {
      display: none;
    }

    .search-suggestions {
      position: absolute;
      top: calc(100% + 6px);
      right: 42px;
      width: 260px;
      max-width: min(260px, calc(100vw - 2rem));
      background: #1a1a1a;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      list-style: none;
      padding: 0.35rem 0;
      margin: 0;
      z-index: 200;
      display: none;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
    }

    .search-suggestions :global(li) {
      padding: 0.6rem 1rem;
      cursor: pointer;
      font-size: 0.88rem;
      color: rgba(255, 255, 255, 0.75);
      transition: background 0.15s;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .search-suggestions :global(li:hover) {
      background: rgba(200, 255, 0, 0.07);
      color: #f5f5f5;
    }

    .search-suggestions :global(mark) {
      background: transparent;
      color: #c8ff00;
      font-weight: 600;
    }

    .account-menu {
      position: relative;
      flex-shrink: 0;
    }

    .account-dropdown {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      min-width: 190px;
      background: #151515;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 14px;
      padding: 0.5rem;
      display: none;
      flex-direction: column;
      gap: 0.3rem;
      z-index: 300;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.45);
    }

    .account-dropdown.is-open {
      display: flex;
    }

    .account-dropdown a,
    .account-dropdown button {
      width: 100%;
      border: none;
      background: transparent;
      color: #f5f5f5;
      text-decoration: none;
      text-align: left;
      padding: 0.8rem 0.9rem;
      border-radius: 10px;
      font-size: 0.92rem;
      cursor: pointer;
      transition:
        background 0.2s ease,
        color 0.2s ease;
    }

    .account-dropdown a:hover,
    .account-dropdown button:hover {
      background: rgba(215, 255, 0, 0.08);
      color: #d7ff00;
    }

    .menu-toggle {
      display: none;
      flex-direction: column;
      gap: 4px;
      padding: 0;
    }

    .menu-toggle span {
      display: block;
      width: 18px;
      height: 2px;
      border-radius: 999px;
      background: #f5f5f5;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .menu-toggle.is-open span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    .menu-toggle.is-open span:nth-child(2) {
      opacity: 0;
    }

    .menu-toggle.is-open span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }

    @media (max-width: 900px) {
      .site-header {
        padding: 1rem 1.25rem;
        align-items: center;
      }

      .menu-toggle {
        display: inline-flex;
      }

      .site-nav {
        display: none;
        position: absolute;
        top: calc(100% - 0.2rem);
        left: 1.25rem;
        right: 1.25rem;
        flex-direction: column;
        align-items: flex-start;
        gap: 0;
        padding: 0.6rem 0.95rem;
        background: #121212;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.45);
        z-index: 250;
      }

      .site-nav.is-open {
        display: flex;
      }

      .site-nav__link {
        width: 100%;
        padding: 0.8rem 0;
        font-size: 0.98rem;
      }
    }

    @media (max-width: 720px) {
      .site-header__brand-nav {
        gap: 1rem;
      }

      .site-header__actions {
        gap: 0.55rem;
      }

      .search-expand.is-open {
        width: min(240px, calc(100vw - 8rem));
      }

      .search-suggestions {
        right: 0;
        width: min(260px, calc(100vw - 2rem));
      }
    }

    @media (max-width: 560px) {
      .site-header {
        padding: 0.9rem 1rem;
      }

      .brand {
        width: 128px;
        height: 32px;
      }

      .icon-button,
      .cart-button,
      .menu-toggle {
        width: 40px;
        height: 40px;
      }

      .site-header__actions {
        gap: 0.5rem;
      }

      .search-expand.is-open {
        width: min(220px, calc(100vw - 6.5rem));
      }

      .search-suggestions {
        right: 0;
        left: auto;
        width: min(250px, calc(100vw - 2rem));
      }

      .account-dropdown {
        right: 0;
        left: auto;
        min-width: 180px;
      }

      .site-nav {
        left: 1rem;
        right: 1rem;
      }
    }

    @media (max-width: 420px) {
      .site-header__brand-nav {
        gap: 0.75rem;
      }

      .site-header__actions {
        gap: 0.42rem;
      }

      .search-expand.is-open {
        width: min(200px, calc(100vw - 6rem));
      }
    }
  </style>

  <script>
    // @ts-nocheck
    function updateCartBadge(bump = false) {
      const cart = JSON.parse(localStorage.getItem("cart") || "[]");
      const total = Array.isArray(cart)
        ? cart.reduce(function(sum, item) {
            return sum + (item && item.quantity ? item.quantity : 1);
          }, 0)
        : 0;

      const badge = document.getElementById("cart-badge");

      if (badge) {
        badge.textContent = String(total);
        badge.style.display = total > 0 ? "flex" : "none";

        if (bump && total > 0) {
          badge.classList.remove("is-bumping");
          void badge.offsetWidth;
          badge.classList.add("is-bumping");
          badge.addEventListener(
            "animationend",
            function() {
              badge.classList.remove("is-bumping");
            },
            { once: true },
          );
        }
      }
    }

    async function updateSessionUI() {
      const profileLink = document.getElementById("profileLink");
      const ordersLink = document.getElementById("ordersLink");
      const favoritesLink = document.getElementById("favoritesLink");
      const accountButton = document.getElementById("accountButton");
      const logoutBtn = document.getElementById("logoutBtn");
      const accountDropdown = document.getElementById("accountDropdown");
      const accountMenu = document.getElementById("accountMenu");

      if (
        !accountButton ||
        !accountDropdown ||
        !profileLink ||
        !ordersLink ||
        !favoritesLink ||
        !logoutBtn ||
        !accountMenu
      ) {
        return;
      }

      try {
        const response = await fetch("/backend/session.php", {
          credentials: "include",
        });

        const data = await response.json();

        if (data.logueado && data.usuario) {
          const isAdmin = data.usuario.rol === "admin";

          profileLink.setAttribute("href", isAdmin ? "/admin" : "/usuario");
          ordersLink.setAttribute("href", isAdmin ? "/admin/pedidos" : "/usuario/pedidos");
          favoritesLink.setAttribute("href", isAdmin ? "/admin" : "/usuario/favoritos");

          accountButton.addEventListener("click", function(e) {
            e.preventDefault();
            e.stopPropagation();

            const isOpen = accountDropdown.classList.toggle("is-open");
            accountButton.setAttribute("aria-expanded", String(isOpen));
          });

          document.addEventListener("click", function(e) {
            const target = e.target;

            if (target instanceof Node && !accountMenu.contains(target)) {
              accountDropdown.classList.remove("is-open");
              accountButton.setAttribute("aria-expanded", "false");
            }
          });

          logoutBtn.addEventListener("click", async function() {
            try {
              const logoutResponse = await fetch("/backend/logout.php", {
                method: "POST",
                credentials: "include",
              });

              const logoutData = await logoutResponse.json();

              if (logoutData.ok) {
                window.showToast?.("Sesión cerrada correctamente", "success");
                setTimeout(function() {
                  window.location.href = "/";
                }, 450);
              } else {
                window.showToast?.(logoutData.error || "No se pudo cerrar sesión", "error");
              }
            } catch (error) {
              window.showToast?.("Error cerrando sesión", "error");
              console.error("Error cerrando sesión:", error);
            }
          });
        } else {
          profileLink.setAttribute("href", "/login");
          ordersLink.setAttribute("href", "/login");
          favoritesLink.setAttribute("href", "/login");

          accountButton.addEventListener("click", function() {
            window.location.href = "/login";
          });

          logoutBtn.style.display = "none";
        }
      } catch (error) {
        console.error("Error leyendo sesión:", error);
      }
    }

    function setupHamburgerMenu() {
      const menuToggle = document.getElementById("menuToggle");
      const siteNav = document.getElementById("siteNav");

      if (!menuToggle || !siteNav) {
        return;
      }

      menuToggle.addEventListener("click", function() {
        const isOpen = siteNav.classList.toggle("is-open");
        menuToggle.classList.toggle("is-open", isOpen);
        menuToggle.setAttribute("aria-expanded", String(isOpen));
      });

      siteNav.querySelectorAll("a").forEach(function(link) {
        link.addEventListener("click", function() {
          if (window.innerWidth <= 900) {
            siteNav.classList.remove("is-open");
            menuToggle.classList.remove("is-open");
            menuToggle.setAttribute("aria-expanded", "false");
          }
        });
      });

      window.addEventListener("resize", function() {
        if (window.innerWidth > 900) {
          siteNav.classList.remove("is-open");
          menuToggle.classList.remove("is-open");
          menuToggle.setAttribute("aria-expanded", "false");
        }
      });
    }

    updateCartBadge();
    updateSessionUI();
    setupHamburgerMenu();

    window.addEventListener("cart-updated", function() {
      updateCartBadge(true);
    });
  </script>

  <script define:vars={{ searchData }}>
    // @ts-nocheck
    const searchWrapper = document.getElementById("searchWrapper");
    const searchExpand = document.getElementById("searchExpand");
    const searchInput = document.getElementById("searchInput");
    const searchBtn = document.getElementById("searchBtn");
    const searchSuggestions = document.getElementById("searchSuggestions");
    let isOpen = false;

    function openSearch() {
      isOpen = true;
      searchExpand.classList.add("is-open");
      searchBtn.classList.add("is-active");
      searchInput.setAttribute("aria-expanded", "true");
      setTimeout(() => searchInput.focus(), 40);
    }

    function closeSearch() {
      isOpen = false;
      searchExpand.classList.remove("is-open");
      searchBtn.classList.remove("is-active");
      searchInput.setAttribute("aria-expanded", "false");
      searchInput.value = "";
      hideSuggestions();
    }

    function doSearch() {
      const q = searchInput.value.trim();
      if (q) window.location.href = "/buscar?q=" + encodeURIComponent(q);
    }

    function escRe(str) {
      return str.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }

    function renderSuggestions(q) {
      if (!q.trim()) {
        hideSuggestions();
        return;
      }

      const lq = q.toLowerCase();

      const matches = searchData
        .filter((p) => p.title.toLowerCase().includes(lq))
        .slice(0, 6);

      if (!matches.length) {
        hideSuggestions();
        return;
      }

      const re = new RegExp(escRe(q), "gi");

      searchSuggestions.innerHTML = matches
        .map(
          (p) =>
            '<li data-slug="' +
            p.slug +
            '" role="option">' +
            p.title.replace(re, (m) => "<mark>" + m + "</mark>") +
            "</li>",
        )
        .join("");

      searchSuggestions.style.display = "block";

      searchSuggestions.querySelectorAll("li").forEach((li) => {
        li.addEventListener("click", () => {
          window.location.href = "/producto/" + li.dataset.slug;
        });
      });
    }

    function hideSuggestions() {
      searchSuggestions.style.display = "none";
      searchSuggestions.innerHTML = "";
    }

    searchBtn.addEventListener("click", () => {
      if (!isOpen) {
        openSearch();
        return;
      }

      if (searchInput.value.trim()) {
        doSearch();
      } else {
        closeSearch();
      }
    });

    searchInput.addEventListener("input", () =>
      renderSuggestions(searchInput.value),
    );

    searchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        doSearch();
      } else if (e.key === "Escape") {
        closeSearch();
      }
    });

    document.addEventListener("click", (e) => {
      if (searchWrapper && !searchWrapper.contains(e.target)) {
        closeSearch();
      }
    });
  </script>
</header>