---
---
<section class="hero">
  <div class="hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">SS26 COLLECTION</span>
      <h1>DRIP<br />MODE<br />HOOD</h1>
      <p>Prendas premium de edición limitada. Diseñadas para durar. Fabricadas en Europa.</p>
      <div class="hero-actions">
        <a class="button primary" href="/categoria/catalogo">VER COLECCIÓN</a>
        <a class="button secondary" href="/categoria/novedades">Novedades</a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="hero-visual__placeholder">
        Imagen de producto
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 140px);
    width: 100%;
    padding: 3.5rem 3rem;
    display: flex;
    align-items: center;
    background: #1a1a1a;
  }

  .hero-grid {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2.5rem;
    align-items: center;
  }

  .hero-copy {
    max-width: 640px;
  }

  .eyebrow {
    display: inline-block;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: #C8FF00;
    margin-bottom: 1.5rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.8rem, 8vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
    font-weight: 900;
    text-transform: uppercase;
  }

  p {
    max-width: 34rem;
    margin: 1.5rem 0 2.5rem;
    color: #d2d2d2;
    font-size: 1rem;
    line-height: 1.9;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .button {
    padding: 1rem 1.8rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .primary {
    background: #C8FF00;
    color: #090909;
  }

  .secondary {
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #f5f5f5;
    background: rgba(255, 255, 255, 0.04);
  }

  .hero-visual {
    display: flex;
    justify-content: flex-end;
  }

  .hero-visual__placeholder {
    width: 100%;
    min-height: 420px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.5rem;
    display: grid;
    place-items: center;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(0, 0, 0, 0.35));
    color: #7c7c7c;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      justify-content: center;
    }

    .hero-visual__placeholder {
      min-height: 300px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2rem 1.2rem;
    }

    .eyebrow {
      margin-bottom: 1rem;
    }
  }
</style>
