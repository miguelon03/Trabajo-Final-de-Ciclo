<section class="returns-admin">
  <div class="returns-admin__head">
    <h1>DEVOLUCIONES</h1>
  </div>

  <div class="returns-admin__tabs" id="returnsTabs">
    <button type="button" class="returns-tab is-active" data-filter="pendiente">
      Pendientes (<span id="tabCountPending">0</span>)
    </button>
    <button type="button" class="returns-tab" data-filter="all">Todas</button>
    <button type="button" class="returns-tab" data-filter="aceptada"
      >Aceptadas</button
    >
    <button type="button" class="returns-tab" data-filter="rechazada"
      >Rechazadas</button
    >
  </div>

  <div id="returnsMessage" class="returns-admin__message" hidden></div>

  <div id="returnsLoading" class="returns-admin__loading" hidden>
    <span class="returns-admin__spinner" aria-hidden="true"></span>
    <span>Cargando devoluciones...</span>
  </div>

  <div class="returns-admin__table-wrap" id="returnsTableWrap" hidden>
    <table class="returns-table">
      <thead>
        <tr>
          <th>Referencia</th>
          <th>Cliente / Pedido</th>
          <th>Producto</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="returnsTableBody"></tbody>
    </table>
  </div>

  <div id="returnsEmpty" class="returns-admin__empty" hidden>
    <h2>No hay devoluciones para mostrar</h2>
    <p>Prueba con otro filtro o espera nuevas solicitudes.</p>
  </div>
  <section id="returnDetailSection" class="return-detail-shell" hidden>
    <div class="return-detail-card">
      <div class="return-detail__header">
        <div>
          <p class="return-detail__eyebrow">Detalle de devolución</p>
          <h2 id="returnDetailTitle">Devolución</h2>
        </div>

        <button
          id="closeReturnDetail"
          class="return-detail__close"
          type="button"
        >
          Cerrar
        </button>
      </div>

      <div id="returnDetailContent" class="return-detail__grid"></div>
    </div>
  </section>

  <div id="rejectModal" class="reject-modal" hidden>
    <div class="reject-modal__backdrop" data-close="reject-modal"></div>
    <div
      class="reject-modal__dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="rejectModalTitle"
    >
      <div class="reject-modal__header">
        <p class="reject-modal__eyebrow">Devoluciones</p>
        <h2 id="rejectModalTitle">Rechazar devolución</h2>
        <button
          type="button"
          class="reject-modal__close"
          id="rejectModalClose"
          aria-label="Cerrar"
        >×</button>
      </div>

      <p class="reject-modal__desc" id="rejectModalRef">
        Indica el motivo del rechazo. El cliente podrá verlo en su pedido.
      </p>

      <label class="reject-modal__label" for="rejectReasonInput">Motivo del rechazo</label>
      <textarea
        id="rejectReasonInput"
        class="reject-modal__textarea"
        rows="4"
        maxlength="400"
        placeholder="Ej. La devolución está fuera del plazo de 30 días."
      ></textarea>

      <p class="reject-modal__error" id="rejectModalError" hidden></p>

      <div class="reject-modal__actions">
        <button type="button" class="reject-btn reject-btn--ghost" id="rejectCancelBtn">
          Cancelar
        </button>
        <button type="button" class="reject-btn reject-btn--danger" id="rejectConfirmBtn">
          Rechazar devolución
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  // @ts-nocheck
  const tabsWrap = document.getElementById("returnsTabs");
  const messageBox = document.getElementById("returnsMessage");
  const loadingBox = document.getElementById("returnsLoading");
  const tableWrap = document.getElementById("returnsTableWrap");
  const tableBody = document.getElementById("returnsTableBody");
  const emptyBox = document.getElementById("returnsEmpty");
  const pendingCount = document.getElementById("tabCountPending");
  const returnDetailSection = document.getElementById("returnDetailSection");
  const returnDetailTitle = document.getElementById("returnDetailTitle");
  const returnDetailContent = document.getElementById("returnDetailContent");
  const closeReturnDetail = document.getElementById("closeReturnDetail");

  const rejectModal = document.getElementById("rejectModal");
  const rejectModalClose = document.getElementById("rejectModalClose");
  const rejectCancelBtn = document.getElementById("rejectCancelBtn");
  const rejectConfirmBtn = document.getElementById("rejectConfirmBtn");
  const rejectReasonInput = document.getElementById("rejectReasonInput");
  const rejectModalError = document.getElementById("rejectModalError");
  const rejectModalRef = document.getElementById("rejectModalRef");

  let activeReturnId = null;
  let allReturns = [];
  let currentFilter = "pendiente";
  const stickyVisibleIds = new Set();

  // Modal para pedir el motivo del rechazo. Devuelve una promesa que se
  // resuelve con el texto del motivo, o con null si se cancela.
  let rejectResolver = null;

  function closeRejectModal(result) {
    if (rejectModal) rejectModal.hidden = true;
    if (rejectModalError) {
      rejectModalError.hidden = true;
      rejectModalError.textContent = "";
    }
    const resolve = rejectResolver;
    rejectResolver = null;
    if (resolve) resolve(result);
  }

  function askRejectionReason(refLabel) {
    return new Promise((resolve) => {
      rejectResolver = resolve;

      if (rejectReasonInput instanceof HTMLTextAreaElement) {
        rejectReasonInput.value = "";
      }
      if (rejectModalError) {
        rejectModalError.hidden = true;
        rejectModalError.textContent = "";
      }
      if (rejectModalRef) {
        rejectModalRef.textContent = refLabel
          ? `Devolución ${refLabel}. Indica el motivo del rechazo; el cliente podrá verlo en su pedido.`
          : "Indica el motivo del rechazo. El cliente podrá verlo en su pedido.";
      }
      if (rejectModal) rejectModal.hidden = false;
      if (rejectReasonInput instanceof HTMLTextAreaElement) {
        rejectReasonInput.focus();
      }
    });
  }

  rejectModalClose?.addEventListener("click", () => closeRejectModal(null));
  rejectCancelBtn?.addEventListener("click", () => closeRejectModal(null));

  rejectModal?.addEventListener("click", (event) => {
    const target = event.target;
    if (target instanceof HTMLElement && target.dataset.close === "reject-modal") {
      closeRejectModal(null);
    }
  });

  rejectConfirmBtn?.addEventListener("click", () => {
    const value =
      rejectReasonInput instanceof HTMLTextAreaElement
        ? rejectReasonInput.value.trim()
        : "";

    if (!value) {
      if (rejectModalError) {
        rejectModalError.textContent =
          "Debes indicar un motivo para rechazar la devolución";
        rejectModalError.hidden = false;
      }
      if (rejectReasonInput instanceof HTMLTextAreaElement) {
        rejectReasonInput.focus();
      }
      return;
    }

    closeRejectModal(value);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && rejectModal && !rejectModal.hidden) {
      closeRejectModal(null);
    }
  });

  async function requestApi(endpoint, options) {
    if (typeof window.dmhFetchJson === "function") {
      return window.dmhFetchJson(endpoint, options || {});
    }

    const response = await fetch(
      `/backend/api/${String(endpoint || "").replace(/^\/+/, "")}`,
      options || {},
    );
    let data = null;

    try {
      data = await response.json();
    } catch (_error) {
      data = null;
    }

    return {
      ok: response.ok,
      status: response.status,
      data,
      error:
        data?.error || (!response.ok ? `Error HTTP ${response.status}` : null),
    };
  }

  function setLoading(loading) {
    if (loadingBox) loadingBox.hidden = !loading;
  }

  function showMessage(text, kind = "info") {
    if (!messageBox) return;
    messageBox.hidden = !text;
    messageBox.className = `returns-admin__message is-${kind}`;
    messageBox.textContent = text || "";
  }

  function escapeHtml(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function getStatusLabel(status) {
    switch (String(status || "").toLowerCase()) {
      case "aceptada":
        return "Aceptada";
      case "rechazada":
        return "Rechazada";
      default:
        return "Pendiente";
    }
  }

  function getStatusClass(status) {
    switch (String(status || "").toLowerCase()) {
      case "aceptada":
        return "is-success";
      case "rechazada":
        return "is-error";
      default:
        return "is-pending";
    }
  }

  function formatDate(value) {
    if (!value) return "-";

    const dt = new Date(value);
    if (Number.isNaN(dt.getTime())) return String(value);

    return dt.toLocaleDateString("es-ES", {
      day: "numeric",
      month: "short",
      year: "numeric",
    });
  }

  function formatPedidoRef(value) {
    const id = Number(value || 0);
    if (!id) return "PED-—";
    return `PED-${String(id).padStart(6, "0")}`;
  }
  function formatMoney(value) {
    return new Intl.NumberFormat("es-ES", {
      style: "currency",
      currency: "EUR",
    }).format(Number(value || 0));
  }

  function updateTabs() {
    const countPending = allReturns.filter(
      (entry) => String(entry?.estado || "").toLowerCase() === "pendiente",
    ).length;

    if (pendingCount) {
      pendingCount.textContent = String(countPending);
    }

    tabsWrap?.querySelectorAll("[data-filter]").forEach((button) => {
      const isActive = button.getAttribute("data-filter") === currentFilter;
      button.classList.toggle("is-active", isActive);
    });
  }

  function getFilteredReturns() {
    if (currentFilter === "all") {
      return [...allReturns];
    }

    return allReturns.filter((entry) => {
      const status = String(entry?.estado || "").toLowerCase();
      const id = Number(entry?.id || 0);

      if (status === currentFilter) {
        return true;
      }

      if (currentFilter === "pendiente" && stickyVisibleIds.has(id)) {
        return true;
      }

      return false;
    });
  }

  function renderActions(entry) {
    const status = String(entry?.estado || "").toLowerCase();

    if (status === "pendiente") {
      return `
      <div class="return-actions">
        <button
          type="button"
          class="btn-action is-accept"
          data-id="${Number(entry.id)}"
          data-state="aceptada"
          aria-label="Aceptar devolución"
          title="Aceptar devolución"
        >
          Aceptar
        </button>

        <button
          type="button"
          class="btn-action is-reject"
          data-id="${Number(entry.id)}"
          data-state="rechazada"
          aria-label="Rechazar devolución"
          title="Rechazar devolución"
        >
          Rechazar
        </button>
      </div>
    `;
    }

    if (status === "aceptada") {
      return `<span class="return-action-text is-stock">Stock restaurado</span>`;
    }

    return `<span class="return-action-text is-muted">Sin acciones</span>`;
  }
  function renderReturnDetail(entry) {
    if (!returnDetailSection || !returnDetailTitle || !returnDetailContent)
      return;

    const productLabel = entry?.talla
      ? `${entry?.nombre_producto || "Producto"} · ${entry.talla}`
      : `${entry?.nombre_producto || "Producto"} · Única`;

    returnDetailTitle.textContent = entry?.slug || "Devolución";

    returnDetailContent.innerHTML = `
    <article class="return-detail__block">
      <h3>Información general</h3>

      <p><strong>Referencia</strong><span>${escapeHtml(entry?.slug || "-")}</span></p>
      <p><strong>Estado</strong><span>${escapeHtml(getStatusLabel(entry?.estado))}</span></p>
      <p><strong>Creada</strong><span>${escapeHtml(formatDate(entry?.creado_en))}</span></p>
      <p><strong>Actualizada</strong><span>${escapeHtml(formatDate(entry?.actualizado_en))}</span></p>
      <p><strong>Motivo</strong><span>${escapeHtml(entry?.motivo || "Sin motivo")}</span></p>
    </article>

    <article class="return-detail__block">
      <h3>Cliente y pedido</h3>

      <p><strong>Cliente</strong><span>${escapeHtml(entry?.usuario_nombre || "-")}</span></p>
      <p><strong>Email</strong><span>${escapeHtml(entry?.usuario_email || "-")}</span></p>
      <p><strong>Pedido</strong><span>${escapeHtml(formatPedidoRef(entry?.pedido_id))}</span></p>
      <p><strong>Estado pedido</strong><span>${escapeHtml(entry?.pedido_estado || "-")}</span></p>
    </article>

    <article class="return-detail__block">
      <h3>Producto</h3>

      <p><strong>Producto</strong><span>${escapeHtml(productLabel)}</span></p>
      <p><strong>Slug</strong><span>${escapeHtml(entry?.producto_slug || "-")}</span></p>
      <p><strong>Talla</strong><span>${escapeHtml(entry?.talla || "Única")}</span></p>
      <p><strong>Color</strong><span>${escapeHtml(entry?.color || "Sin color")}</span></p>
      <p><strong>SKU</strong><span>${escapeHtml(entry?.sku || "-")}</span></p>
    </article>

    <article class="return-detail__block">
      <h3>Cantidades e importe</h3>

      <p><strong>Compradas</strong><span>${Number(entry?.cantidad_comprada || 0)} ud.</span></p>
      <p><strong>Devueltas</strong><span>${Number(entry?.cantidad_devuelta || 0)} ud.</span></p>
      <p><strong>Precio unitario</strong><span>${formatMoney(entry?.precio_unitario)}</span></p>
      <p><strong>Subtotal</strong><span>${formatMoney(entry?.subtotal)}</span></p>
    </article>
  `;

    returnDetailSection.hidden = false;
    returnDetailSection.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function openReturnDetail(returnId) {
    activeReturnId = Number(returnId || 0);

    const entry = allReturns.find(
      (item) => Number(item?.id || 0) === activeReturnId,
    );
    if (!entry) return;

    renderReturnDetail(entry);
  }
  function renderReturns() {
    if (!tableWrap || !tableBody || !emptyBox) return;

    updateTabs();
    const filtered = getFilteredReturns();

    if (!filtered.length) {
      tableWrap.hidden = true;
      tableBody.innerHTML = "";
      emptyBox.hidden = false;
      return;
    }

    emptyBox.hidden = true;

    tableBody.innerHTML = filtered
      .map((entry) => {
        const status = String(entry?.estado || "pendiente").toLowerCase();
        const productLabel = entry?.talla
          ? `${entry?.nombre_producto || "Producto"} · ${entry.talla}`
          : `${entry?.nombre_producto || "Producto"} · Única`;

        return `
    <tr>
      <td data-label="Referencia">
        <button
          type="button"
          class="return-ref-button"
          data-view-return="${Number(entry.id || 0)}"
          title="Ver detalle de la devolución"
        >
          ${escapeHtml(entry.slug || "DEV-")}
        </button>
        <span class="cell-sub">${escapeHtml(formatDate(entry.creado_en))}</span>
      </td>

      <td data-label="Cliente / Pedido">
        <p class="cell-main">${escapeHtml(entry.usuario_nombre || "-")}</p>
        <span class="cell-sub">${escapeHtml(formatPedidoRef(entry.pedido_id))}</span>
      </td>

      <td data-label="Producto">
        <p class="cell-main">${escapeHtml(productLabel)}</p>
      </td>

      <td data-label="Estado">
        <span class="return-status ${getStatusClass(status)}">${getStatusLabel(status)}</span>
      </td>

      <td data-label="Acciones">
        ${renderActions(entry)}
      </td>
    </tr>
  `;
      })
      .join("");
    tableBody.querySelectorAll("[data-view-return]").forEach((button) => {
      button.addEventListener("click", () => {
        const returnId = Number(button.getAttribute("data-view-return") || 0);
        if (!returnId) return;
        openReturnDetail(returnId);
      });
    });
    tableBody.querySelectorAll(".btn-action").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const devolucionId = Number(btn.getAttribute("data-id") || 0);
        const estado = btn.getAttribute("data-state") || "";
        if (!devolucionId || !estado) return;

        let feedback = "";
        if (estado === "rechazada") {
          const entry = allReturns.find(
            (item) => Number(item?.id || 0) === devolucionId,
          );
          const reason = await askRejectionReason(entry?.slug || "");
          // null = el admin canceló el rechazo.
          if (reason === null) return;
          feedback = String(reason).trim();
        }

        try {
          const result = await requestApi("devoluciones.php", {
            method: "POST",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              devolucion_id: devolucionId,
              estado,
              feedback,
            }),
          });

          if (!result.ok) {
            throw new Error(
              result.error || "No se pudo actualizar la devolución",
            );
          }

          if (currentFilter === "pendiente") {
            stickyVisibleIds.add(devolucionId);
          }

          await loadReturns();
          showMessage(
            `Devolución actualizada a ${getStatusLabel(estado)}`,
            "success",
          );
        } catch (error) {
          showMessage(
            error instanceof Error
              ? error.message
              : "No se pudo actualizar la devolución",
            "error",
          );
        }
      });
    });

    tableWrap.hidden = false;
  }
  closeReturnDetail?.addEventListener("click", () => {
    activeReturnId = null;

    if (returnDetailSection) {
      returnDetailSection.hidden = true;
    }
  });
  async function loadReturns() {
    setLoading(true);
    showMessage("");

    try {
      const result = await requestApi("devoluciones.php", {
        credentials: "include",
      });

      if (!result.ok) {
        throw new Error(
          result.error || "No se pudieron cargar las devoluciones",
        );
      }

      allReturns = result.data?.devoluciones || [];
      renderReturns();
    } catch (error) {
      allReturns = [];
      renderReturns();
      showMessage(
        error instanceof Error
          ? error.message
          : "No se pudieron cargar las devoluciones",
        "error",
      );
    } finally {
      setLoading(false);
    }
  }

  tabsWrap?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLButtonElement)) return;

    const nextFilter = target.getAttribute("data-filter");
    if (!nextFilter) return;

    currentFilter = nextFilter;

    if (currentFilter !== "pendiente") {
      stickyVisibleIds.clear();
    }

    renderReturns();
  });

  loadReturns();
</script>

<style is:global>
  .returns-admin {
    display: grid;
    gap: 10px;
  }

  .returns-admin__head h1 {
    font-size: var(--page-title-size);
    font-weight: 900;
    letter-spacing: var(--page-title-letter-spacing);
    color: #f4f4f4;
  }

  .returns-admin__tabs {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
  }

  .returns-tab {
    min-height: 20px;
    padding: 0 11px;
    border-radius: 999px;
    border: 1px solid #272727;
    background: #1a1a1a;
    color: #707070;
    font-size: 0.76rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .returns-tab:hover {
    border-color: #313131;
    color: #9a9a9a;
  }

  .returns-tab.is-active {
    background: #C8FF00;
    border-color: #C8FF00;
    color: #111;
  }

  .returns-admin__message {
    border-radius: 7px;
    border: 1px solid #232323;
    padding: 8px 10px;
    background: #161616;
    font-size: 0.68rem;
  }

  .returns-admin__message.is-error {
    border-color: rgba(116, 38, 38, 0.32);
    color: #c56b6b;
  }

  .returns-admin__message.is-success {
    border-color: rgba(19, 108, 58, 0.28);
    color: #63c78d;
  }

  .returns-admin__loading,
  .returns-admin__empty {
    background: #111;
    border: 1px solid #1b1b1b;
    border-radius: 8px;
    padding: 12px;
  }

  .returns-admin__spinner {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid rgba(200, 255, 0, 0.22);
    border-top-color: #C8FF00;
    display: inline-block;
    margin-right: 7px;
    animation: returns-spin 0.9s linear infinite;
  }

  .returns-admin__table-wrap {
    overflow: hidden;
    border: 1px solid #171717;
    background: transparent;
  }

  .returns-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  .returns-table thead th {
    background: #101010;
    color: #59606a;
    font-size: 0.74rem;
    font-weight: 700;
    text-align: left;
    padding: 12px 12px;
    border-bottom: 1px solid #171717;
  }

  .returns-table tbody tr {
    background: #121212;
  }

  .returns-table tbody tr:nth-child(even) {
    background: #101010;
  }

  .returns-table tbody tr.is-dimmed {
  opacity: 1;
}
  .returns-table td {
    padding: 12px 12px;
    border-bottom: 1px solid #141414;
    vertical-align: middle;
    font-size: 0.88rem;
  }

  .returns-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .cell-ref,
  .cell-main,
  .cell-reason {
    margin: 0;
  }

  .cell-ref {
    color: #C8FF00;
    font-weight: 900;
    font-size: 0.62rem;
    line-height: 1.2;
  }

  .cell-main {
    color: #d7d7d7;
    font-weight: 700;
    line-height: 1.28;
    font-size: 0.92rem;
  }

  .cell-reason {
    color: #626262;
    line-height: 1.28;
    font-style: italic;
  }

  .cell-sub {
    display: block;
    margin-top: 3px;
    color: #4b4b4b;
    font-size: 0.74rem;
    line-height: 1.25;
  }

  .return-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 92px;
    min-height: 28px;
    padding: 0 8px;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 700;
    border: 1px solid transparent;
  }

  .return-status.is-pending {
    background: rgba(122, 86, 10, 0.34);
    border-color: rgba(141, 98, 12, 0.22);
    color: #d0a021;
  }

  .return-status.is-success {
    background: rgba(11, 74, 39, 0.4);
    border-color: rgba(18, 105, 57, 0.2);
    color: #20bc63;
  }

  .return-status.is-error {
    background: rgba(76, 21, 21, 0.38);
    border-color: rgba(111, 33, 33, 0.22);
    color: #b44d4d;
  }

  .return-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .btn-action {
    appearance: none;
    -webkit-appearance: none;
    min-height: 20px;
    padding: 0 10px;
    border-radius: 3px;
    border: 1px solid #2c2c2c;
    background: #151515;
    font-size: 0.46rem;
    font-weight: 700;
    line-height: 1;
    color: #ddd;
    cursor: pointer;
    box-shadow: none;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .btn-action.is-accept {
    color: #23bb64;
    border-color: rgba(17, 114, 61, 0.28);
    background: rgba(11, 74, 39, 0.28);
  }

  .btn-action.is-accept:hover {
    background: rgba(11, 74, 39, 0.42);
  }

  .btn-action.is-reject {
    color: #b34d4d;
    border-color: rgba(111, 33, 33, 0.28);
    background: rgba(76, 21, 21, 0.22);
