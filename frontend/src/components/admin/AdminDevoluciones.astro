		display: grid;
		gap: 1rem;
	}

	.returns-admin__head h1 {
		font-size: 2.1rem;
		letter-spacing: 0.04em;
	}

	.returns-admin__head p {
		margin-top: 0.45rem;
		color: #8f8f8f;
	}

	.returns-admin__controls {
		display: flex;
		gap: 0.7rem;
		flex-wrap: wrap;
	}

	.returns-admin__controls input,
	.returns-admin__controls select {
		min-height: 42px;
		border: 1px solid #2a2a2a;
		background: #151515;
		border-radius: 10px;
		color: #f5f5f5;
		padding: 0 0.8rem;
	}

	.returns-admin__controls input {
		min-width: 260px;
		flex: 1;
	}

	.returns-admin__message {
		border-radius: 10px;
		border: 1px solid #2a2a2a;
		padding: 0.7rem 0.85rem;
		background: #171717;
		font-size: 0.92rem;
	}

	.returns-admin__message.is-error {
		border-color: rgba(255, 102, 102, 0.34);
		background: rgba(255, 102, 102, 0.08);
		color: #ff8e8e;
	}

	.returns-admin__message.is-success {
		border-color: rgba(139, 255, 151, 0.35);
		background: rgba(139, 255, 151, 0.1);
		color: #8bff97;
	}

	.returns-admin__loading,
	.returns-admin__empty {
		background: #111;
		border: 1px solid #222;
		border-radius: 14px;
		padding: 1rem;
	}

	.returns-admin__spinner {
		width: 16px;
		height: 16px;
		border-radius: 50%;
		border: 2px solid rgba(215, 255, 0, 0.28);
		border-top-color: #d7ff00;
		display: inline-block;
		margin-right: 0.55rem;
		animation: returns-spin 0.9s linear infinite;
	}

	.returns-admin__list {
		display: grid;
		gap: 0.85rem;
	}

	.return-card {
		border: 1px solid #242424;
		border-radius: 14px;
		background: #111;
		padding: 1rem;
		display: grid;
		gap: 0.85rem;
	}

	.return-card__head {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.8rem;
	}

	.return-card__slug {
		margin: 0;
		color: #d7ff00;
		font-weight: 800;
		letter-spacing: 0.05em;
	}

	.return-card__meta {
		margin: 0.3rem 0 0;
		color: #8a8a8a;
		font-size: 0.84rem;
	}

	.return-status {
		border-radius: 999px;
		padding: 0.28rem 0.68rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
	}

	.return-status.is-pending {
		background: rgba(255, 196, 71, 0.14);
		border: 1px solid rgba(255, 196, 71, 0.35);
		color: #ffc447;
	}

	.return-status.is-success {
		background: rgba(139, 255, 151, 0.14);
		border: 1px solid rgba(139, 255, 151, 0.4);
		color: #8bff97;
	}

	.return-status.is-error {
		background: rgba(255, 132, 132, 0.14);
		border: 1px solid rgba(255, 132, 132, 0.4);
		color: #ff8484;
	}

	.return-card__grid {
		display: grid;
		gap: 0.8rem;
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.return-card__label {
		margin: 0;
		color: #717171;
		text-transform: uppercase;
