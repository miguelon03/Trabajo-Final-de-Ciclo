	}

	.return-card__hint {
		margin: 0.25rem 0 0;
		color: #8a8a8a;
		font-size: 0.82rem;
	}

	.return-card__reason {
		margin: 0;
		color: #d1d1d1;
		background: #161616;
		border: 1px solid #282828;
		border-radius: 10px;
		padding: 0.65rem 0.8rem;
		font-size: 0.9rem;
		line-height: 1.45;
	}

	.return-actions {
		display: flex;
		gap: 0.55rem;
	}

	.btn-action {
		border-radius: 10px;
		border: 1px solid transparent;
		font-weight: 700;
		cursor: pointer;
		padding: 0.52rem 0.85rem;
		transition: all 0.15s ease;
	}

	.btn-action.is-accept {
		background: rgba(139, 255, 151, 0.16);
		border-color: rgba(139, 255, 151, 0.45);
		color: #8bff97;
	}

	.btn-action.is-accept:hover {
		background: rgba(139, 255, 151, 0.24);
	}

	.btn-action.is-reject {
		background: rgba(255, 132, 132, 0.14);
