<section class="returns-admin">
	<div class="returns-admin__head">
		<h1>DEVOLUCIONES</h1>
		<p>Gestiona las solicitudes de devolucion y actualiza su estado.</p>
	</div>

	<div class="returns-admin__controls">
		<input id="returnsSearch" type="text" placeholder="Buscar por ref, cliente o producto" />
		<select id="returnsStatusFilter">
			<option value="all">Todos los estados</option>
			<option value="pendiente">Pendiente</option>
			<option value="aceptada">Aceptada</option>
			<option value="rechazada">Rechazada</option>
		</select>
	</div>

	<div id="returnsMessage" class="returns-admin__message" hidden></div>

	<div id="returnsLoading" class="returns-admin__loading" hidden>
		<span class="returns-admin__spinner" aria-hidden="true"></span>
		<span>Cargando devoluciones...</span>
	</div>

	<div id="returnsList" class="returns-admin__list" hidden></div>
	<div id="returnsEmpty" class="returns-admin__empty" hidden>
		<h2>No hay devoluciones para mostrar</h2>
		<p>Prueba con otros filtros o espera nuevas solicitudes.</p>
	</div>
</section>

<script>
	// @ts-nocheck
	const searchInput = document.getElementById("returnsSearch");
	const statusFilter = document.getElementById("returnsStatusFilter");
	const messageBox = document.getElementById("returnsMessage");
	const loadingBox = document.getElementById("returnsLoading");
	const listBox = document.getElementById("returnsList");
	const emptyBox = document.getElementById("returnsEmpty");

	let allReturns = [];

	async function requestApi(endpoint, options) {
		if (typeof window.dmhFetchJson === "function") {
			return window.dmhFetchJson(endpoint, options || {});
		}

		const response = await fetch(`/backend/api/${String(endpoint || "").replace(/^\/+/, "")}`, options || {});
		let data = null;
		try {
			data = await response.json();
		} catch (_error) {
			data = null;
		}

		return {
			ok: response.ok,
			status: response.status,
			data,
			error: data?.error || (!response.ok ? `Error HTTP ${response.status}` : null),
		};
	}

	function setLoading(loading) {
		if (loadingBox) loadingBox.hidden = !loading;
	}

	function showMessage(text, kind = "info") {
		if (!messageBox) return;
		messageBox.hidden = !text;
		messageBox.className = `returns-admin__message is-${kind}`;
		messageBox.textContent = text || "";
	}

	function escapeHtml(value) {
		return String(value || "")
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/\"/g, "&quot;")
			.replace(/'/g, "&#39;");
	}

	function euro(value) {
		return Number(value || 0).toFixed(2).replace(".", ",") + " €";
	}

	function getStatusLabel(status) {
		switch (String(status || "").toLowerCase()) {
			case "aceptada":
				return "Aceptada";
			case "rechazada":
				return "Rechazada";
			default:
				return "Pendiente";
		}
	}

	function getStatusClass(status) {
		switch (String(status || "").toLowerCase()) {
			case "aceptada":
				return "is-success";
			case "rechazada":
				return "is-error";
			default:
				return "is-pending";
		}
	}

	function formatDate(value) {
		if (!value) return "-";
		const dt = new Date(value);
		if (Number.isNaN(dt.getTime())) return String(value);
		return dt.toLocaleString("es-ES", {
			day: "2-digit",
			month: "short",
			year: "numeric",
			hour: "2-digit",
			minute: "2-digit",
		});
	}

	function applyFilters(items) {
		const query = String(searchInput?.value || "").trim().toLowerCase();
		const status = String(statusFilter?.value || "all").toLowerCase();

		return (Array.isArray(items) ? items : []).filter((entry) => {
			const entryStatus = String(entry?.estado || "").toLowerCase();
			if (status !== "all" && entryStatus !== status) {
				return false;
			}

			if (!query) {
				return true;
			}

			const text = [
				entry?.slug,
				entry?.usuario_nombre,
				entry?.usuario_email,
				entry?.nombre_producto,
				entry?.producto_slug,
				`#${Number(entry?.pedido_id || 0)}`,
			].join(" ").toLowerCase();

			return text.includes(query);
		});
	}

	function renderReturns() {
		if (!listBox || !emptyBox) return;

		const filtered = applyFilters(allReturns);
		if (!filtered.length) {
			listBox.hidden = true;
			listBox.innerHTML = "";
			emptyBox.hidden = false;
			return;
		}

		emptyBox.hidden = true;

		listBox.innerHTML = filtered.map((entry) => {
			const status = String(entry?.estado || "pendiente").toLowerCase();
			const statusClass = getStatusClass(status);
			const actions = status === "pendiente"
				? `
					<div class="return-actions">
						<button type="button" class="btn-action is-accept" data-id="${Number(entry.id)}" data-state="aceptada">Aceptar</button>
						<button type="button" class="btn-action is-reject" data-id="${Number(entry.id)}" data-state="rechazada">Rechazar</button>
					</div>
				`
				: "";

			return `
				<article class="return-card">
					<header class="return-card__head">
						<div>
							<p class="return-card__slug">${escapeHtml(entry.slug || "DEV-")}</p>
							<p class="return-card__meta">Pedido #${Number(entry.pedido_id || 0)} · ${formatDate(entry.creado_en)}</p>
						</div>
						<span class="return-status ${statusClass}">${getStatusLabel(status)}</span>
					</header>

					<div class="return-card__grid">
						<div>
							<p class="return-card__label">Cliente</p>
							<p class="return-card__value">${escapeHtml(entry.usuario_nombre || "-")}</p>
							<p class="return-card__hint">${escapeHtml(entry.usuario_email || "-")}</p>
						</div>
						<div>
							<p class="return-card__label">Producto</p>
							<p class="return-card__value">${escapeHtml(entry.nombre_producto || "Producto")}</p>
							<p class="return-card__hint">${escapeHtml(entry.talla || "Unica")} · ${escapeHtml(entry.color || "-")}</p>
						</div>
						<div>
							<p class="return-card__label">Cantidad</p>
							<p class="return-card__value">${Number(entry.cantidad_devuelta || 0)} ud</p>
							<p class="return-card__hint">Compradas: ${Number(entry.cantidad_comprada || 0)}</p>
						</div>
						<div>
							<p class="return-card__label">Importe orientativo</p>
							<p class="return-card__value">${euro(Number(entry.precio_unitario || 0) * Number(entry.cantidad_devuelta || 0))}</p>
							<p class="return-card__hint">Unitario: ${euro(entry.precio_unitario)}</p>
						</div>
					</div>

					${entry.motivo ? `<p class="return-card__reason">Motivo: ${escapeHtml(entry.motivo)}</p>` : ""}
					${actions}
				</article>
			`;
		}).join("");

		listBox.querySelectorAll(".btn-action").forEach((btn) => {
			btn.addEventListener("click", async () => {
				const devolucionId = Number(btn.getAttribute("data-id") || 0);
				const estado = btn.getAttribute("data-state") || "";
				if (!devolucionId || !estado) return;

				try {
					const result = await requestApi("devoluciones.php", {
						method: "PATCH",
						credentials: "include",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ devolucion_id: devolucionId, estado }),
					});

					if (!result.ok) {
						throw new Error(result.error || "No se pudo actualizar la devolucion");
					}

					showMessage(`Devolucion #${devolucionId} actualizada a ${getStatusLabel(estado)}`, "success");
					await loadReturns();
				} catch (error) {
					showMessage(error instanceof Error ? error.message : "No se pudo actualizar la devolucion", "error");
				}
			});
		});

		listBox.hidden = false;
	}

	async function loadReturns() {
		setLoading(true);
		showMessage("");

		try {
			const result = await requestApi("devoluciones.php", {
				credentials: "include",
			});

			if (!result.ok) {
				throw new Error(result.error || "No se pudieron cargar las devoluciones");
			}

			allReturns = result.data?.devoluciones || [];
			renderReturns();
		} catch (error) {
			allReturns = [];
			renderReturns();
			showMessage(error instanceof Error ? error.message : "No se pudieron cargar las devoluciones", "error");
		} finally {
			setLoading(false);
		}
	}

	searchInput?.addEventListener("input", renderReturns);
	statusFilter?.addEventListener("change", renderReturns);

	loadReturns();
</script>

<style>
