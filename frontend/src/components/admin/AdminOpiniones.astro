<section class="reviews-admin">
  <div class="reviews-admin__head">
    <h1>OPINIONES</h1>
  </div>

  <div class="reviews-admin__tabs" id="reviewsTabs">
    <button type="button" class="reviews-tab is-active" data-filter="pendiente">
      Pendientes (<span id="reviewsCountPending">0</span>)
    </button>
    <button type="button" class="reviews-tab" data-filter="aprobada"
      >Aprobadas</button
    >
    <button type="button" class="reviews-tab" data-filter="rechazada"
      >Rechazadas</button
    >
    <button type="button" class="reviews-tab" data-filter="all">Todas</button>
  </div>

  <div id="reviewsMessage" class="reviews-admin__message" hidden></div>

  <div id="reviewsLoading" class="reviews-admin__loading" hidden>
    <span class="reviews-admin__spinner" aria-hidden="true"></span>
    <span>Cargando opiniones...</span>
  </div>

  <div id="reviewsTableWrap" class="reviews-admin__table-wrap" hidden>
    <table class="reviews-table">
      <thead>
        <tr>
          <th>Valoración</th>
          <th>Comentario</th>
          <th>Producto</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="reviewsTableBody"></tbody>
    </table>
  </div>

  <div id="reviewsEmpty" class="reviews-admin__empty" hidden>
    <h2>No hay opiniones para mostrar</h2>
    <p>Cambia el filtro o espera nuevas reseñas.</p>
  </div>

  <section id="reviewDetailSection" class="review-detail-shell" hidden>
    <div class="review-detail-card">
      <div class="review-detail__header">
        <div>
          <p class="review-detail__eyebrow">Detalle de opinión</p>
          <h2 id="reviewDetailTitle">Opinión</h2>
        </div>

        <button
          id="closeReviewDetail"
          class="review-detail__close"
          type="button"
        >
          Cerrar
        </button>
      </div>

      <div id="reviewDetailContent" class="review-detail__grid"></div>
    </div>
  </section>
</section>

<script>
  // @ts-nocheck
  const reviewsTabs = document.getElementById("reviewsTabs");
  const reviewsMessage = document.getElementById("reviewsMessage");
  const reviewsLoading = document.getElementById("reviewsLoading");
  const reviewsTableWrap = document.getElementById("reviewsTableWrap");
  const reviewsTableBody = document.getElementById("reviewsTableBody");
  const reviewsEmpty = document.getElementById("reviewsEmpty");
  const reviewsCountPending = document.getElementById("reviewsCountPending");

  const reviewDetailSection = document.getElementById("reviewDetailSection");
  const reviewDetailTitle = document.getElementById("reviewDetailTitle");
  const reviewDetailContent = document.getElementById("reviewDetailContent");
  const closeReviewDetail = document.getElementById("closeReviewDetail");

  let currentFilter = "pendiente";
  let allReviews = [];
  let activeReviewId = null;

  async function requestAdminApi(endpoint, options) {
    const response = await fetch(
      `/backend/api/admin/${String(endpoint || "").replace(/^\/+/, "")}`,
      {
        credentials: "include",
        ...(options || {}),
      },
    );

    let data = null;

    try {
      data = await response.json();
    } catch (_error) {
      data = null;
    }

    return {
      ok: response.ok,
      status: response.status,
      data,
      error:
        data?.error || (!response.ok ? `Error HTTP ${response.status}` : null),
    };
  }

  function setLoading(isLoading) {
    if (reviewsLoading) {
      reviewsLoading.hidden = !isLoading;
    }
  }

  function showMessage(text, kind = "info") {
    if (!reviewsMessage) return;

    reviewsMessage.hidden = !text;
    reviewsMessage.className = `reviews-admin__message is-${kind}`;
    reviewsMessage.textContent = text || "";
  }

  function escapeHtml(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function formatDate(value) {
    if (!value) return "-";

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return String(value);

    const diffMs = Date.now() - date.getTime();
    const diffDays = Math.max(0, Math.floor(diffMs / 86400000));

    if (diffDays === 0) return "hace 0 días";
    if (diffDays === 1) return "hace 1 día";
    if (diffDays < 7) return `hace ${diffDays} días`;

    return date.toLocaleDateString("es-ES", {
      day: "numeric",
      month: "short",
      year: "numeric",
    });
  }

  function renderStars(value) {
    const rating = Math.max(1, Math.min(5, Number(value || 0)));
    return `${"★".repeat(rating)}${"☆".repeat(5 - rating)}`;
  }

  function getStatusLabel(status) {
    switch (String(status || "").toLowerCase()) {
      case "aprobada":
        return "Aprobada";
      case "rechazada":
        return "Rechazada";
      default:
        return "Pendiente";
    }
  }

  function getStatusClass(status) {
    switch (String(status || "").toLowerCase()) {
      case "aprobada":
        return "is-approved";
      case "rechazada":
        return "is-rejected";
      default:
        return "is-pending";
    }
  }

  function getVerifiedText(entry) {
    return Number(entry?.compra_verificada || 0) > 0
      ? "Compra verificada"
      : "Compra no verificada";
  }

  function syncTabs() {
    const pendingTotal = allReviews.filter(
      (entry) => String(entry?.estado || "").toLowerCase() === "pendiente",
    ).length;

    if (reviewsCountPending) {
      reviewsCountPending.textContent = String(pendingTotal);
    }

    reviewsTabs?.querySelectorAll("[data-filter]").forEach((button) => {
      const isActive = button.getAttribute("data-filter") === currentFilter;
      button.classList.toggle("is-active", isActive);
    });
  }

  function filteredReviews() {
    if (currentFilter === "all") {
      return [...allReviews];
    }

    return allReviews.filter(
      (entry) => String(entry?.estado || "").toLowerCase() === currentFilter,
    );
  }

  function renderReviewDetail(entry) {
    if (!reviewDetailSection || !reviewDetailTitle || !reviewDetailContent)
      return;

    const status = String(entry?.estado || "pendiente").toLowerCase();

    reviewDetailTitle.textContent = `Opinión #${Number(entry?.id || 0)}`;

    reviewDetailContent.innerHTML = `
      <article class="review-detail__block">
        <h3>Opinión</h3>

        <p>
          <strong>Valoración</strong>
          <span>${escapeHtml(renderStars(entry?.puntuacion || 0))}</span>
        </p>

        <p>
          <strong>Comentario</strong>
          <span>${escapeHtml(entry?.comentario || "-")}</span>
        </p>

        <p>
          <strong>Estado</strong>
          <span>${escapeHtml(getStatusLabel(status))}</span>
        </p>

        <p>
          <strong>Fecha</strong>
          <span>${escapeHtml(formatDate(entry?.creado_en))}</span>
        </p>
      </article>

      <article class="review-detail__block">
        <h3>Usuario</h3>

        <p>
          <strong>Nombre</strong>
          <span>${escapeHtml(entry?.usuario_nombre || "-")}</span>
        </p>

        <p>
          <strong>ID usuario</strong>
          <span>${Number(entry?.usuario_id || 0)}</span>
        </p>

        <p>
          <strong>Compra</strong>
          <span>${escapeHtml(getVerifiedText(entry))}</span>
        </p>
      </article>

      <article class="review-detail__block">
        <h3>Producto</h3>

        <p>
          <strong>Producto</strong>
          <span>${escapeHtml(entry?.producto_nombre || "-")}</span>
        </p>

        <p>
          <strong>Slug</strong>
          <span>${escapeHtml(entry?.producto_slug || "-")}</span>
        </p>

        <p>
          <strong>ID producto</strong>
          <span>${Number(entry?.producto_id || 0)}</span>
        </p>
      </article>
    `;

    reviewDetailSection.hidden = false;
    reviewDetailSection.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function openReviewDetail(reviewId) {
    activeReviewId = Number(reviewId || 0);

    const entry = allReviews.find(
      (item) => Number(item?.id || 0) === activeReviewId,
    );

    if (!entry) return;

    renderReviewDetail(entry);
  }

  function actionsFor(entry) {
    const id = Number(entry?.id || 0);
    const status = String(entry?.estado || "").toLowerCase();

    const detailButton = `
  <button
    type="button"
    class="review-btn is-detail is-icon"
    data-view-review="${id}"
    aria-label="Ver detalle"
    title="Ver detalle"
  >
    👁
  </button>
`;
    if (status === "pendiente") {
      return `
        <div class="review-actions">
          <button
            type="button"
            class="review-btn is-approve is-icon"
            data-action="aprobada"
            data-id="${id}"
            aria-label="Aprobar opinión"
            title="Aprobar opinión"
          >
            ✅
          </button>

          <button
            type="button"
            class="review-btn is-reject is-icon"
            data-action="rechazada"
            data-id="${id}"
            aria-label="Rechazar opinión"
            title="Rechazar opinión"
          >
            ❌
          </button>

          ${detailButton}
        </div>
      `;
    }

    if (status === "aprobada") {
      return `
        <div class="review-actions">
          ${detailButton}

          <button
            type="button"
            class="review-btn is-delete is-icon"
            data-action="delete"
            data-id="${id}"
            aria-label="Eliminar opinión"
            title="Eliminar opinión"
          >
            🗑
          </button>
        </div>
      `;
    }

    return `
      <div class="review-actions">
        <button
          type="button"
          class="review-btn is-approve is-icon"
          data-action="aprobada"
          data-id="${id}"
          aria-label="Aprobar opinión"
          title="Aprobar opinión"
        >
          ✅
        </button>

        ${detailButton}

        <button
          type="button"
          class="review-btn is-delete is-icon"
          data-action="delete"
          data-id="${id}"
          aria-label="Eliminar opinión"
          title="Eliminar opinión"
        >
          🗑
        </button>
      </div>
    `;
  }

  function renderTable() {
    if (!reviewsTableWrap || !reviewsTableBody || !reviewsEmpty) return;

    syncTabs();
    const rows = filteredReviews();

    if (!rows.length) {
      reviewsTableWrap.hidden = true;
      reviewsTableBody.innerHTML = "";
      reviewsEmpty.hidden = false;
      return;
    }

    reviewsEmpty.hidden = true;
    reviewsTableWrap.hidden = false;

    reviewsTableBody.innerHTML = rows
      .map((entry) => {
        const status = String(entry?.estado || "pendiente").toLowerCase();

        return `
        <tr>
          <td data-label="Valoración">
            <div class="review-score ${status === "aprobada" ? "is-approved" : ""}">
              ${escapeHtml(renderStars(entry?.puntuacion || 0))}
            </div>
          </td>

          <td data-label="Comentario">
            <p class="review-comment">"${escapeHtml(entry?.comentario || "")}"</p>
          </td>

          <td data-label="Producto">
            <p class="review-main review-main--product">
              ${escapeHtml(entry?.producto_nombre || "-")}
            </p>
            <span class="review-sub">${escapeHtml(entry?.producto_slug || "-")}</span>
          </td>

          <td data-label="Estado">
            <span class="review-status ${getStatusClass(status)}">
              ${getStatusLabel(status)}
            </span>
          </td>

          <td data-label="Acciones">
            ${actionsFor(entry)}
          </td>
        </tr>
      `;
      })
      .join("");

    reviewsTableBody
      .querySelectorAll("[data-view-review]")
      .forEach((button) => {
        button.addEventListener("click", () => {
          const reviewId = Number(button.getAttribute("data-view-review") || 0);
          if (!reviewId) return;
          openReviewDetail(reviewId);
        });
      });

    reviewsTableBody.querySelectorAll("[data-action]").forEach((button) => {
      button.addEventListener("click", async () => {
        const opinionId = Number(button.getAttribute("data-id") || 0);
        const action = button.getAttribute("data-action") || "";

        if (!opinionId || !action) return;

        try {
          if (action === "delete") {
            const result = await requestAdminApi("opinion-delete.php", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ opinion_id: opinionId }),
            });

            if (!result.ok) {
              throw new Error(result.error || "No se pudo eliminar la opinión");
            }

            allReviews = allReviews.filter(
              (entry) => Number(entry?.id || 0) !== opinionId,
            );

            if (activeReviewId === opinionId && reviewDetailSection) {
              reviewDetailSection.hidden = true;
              activeReviewId = null;
            }

            showMessage("Opinión eliminada correctamente", "success");
            renderTable();
            return;
          }

          const result = await requestAdminApi("opinion-estado-update.php", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              opinion_id: opinionId,
              estado: action,
            }),
          });

          if (!result.ok) {
            throw new Error(result.error || "No se pudo actualizar la opinión");
          }

          allReviews = allReviews.map((entry) =>
            Number(entry?.id || 0) === opinionId
              ? { ...entry, estado: action }
              : entry,
          );

          if (activeReviewId === opinionId) {
            const updatedEntry = allReviews.find(
              (entry) => Number(entry?.id || 0) === opinionId,
            );

            if (updatedEntry) {
              renderReviewDetail(updatedEntry);
            }
          }

          showMessage(
            `Opinión marcada como ${getStatusLabel(action)}`,
            "success",
          );
          renderTable();
        } catch (error) {
          showMessage(
            error instanceof Error
              ? error.message
              : "No se pudo completar la acción",
            "error",
          );
        }
      });
    });
  }

  async function loadOpiniones() {
    setLoading(true);
    showMessage("");

    try {
      const query =
        currentFilter === "all"
          ? ""
          : `?estado=${encodeURIComponent(currentFilter)}`;

      const result = await requestAdminApi(`opiniones-list.php${query}`);

      if (!result.ok) {
        throw new Error(result.error || "No se pudieron cargar las opiniones");
      }

      allReviews = Array.isArray(result.data?.opiniones)
        ? result.data.opiniones
        : [];

      renderTable();
    } catch (error) {
      allReviews = [];
      renderTable();

      showMessage(
        error instanceof Error
          ? error.message
          : "No se pudieron cargar las opiniones",
        "error",
      );
    } finally {
      setLoading(false);
    }
  }

  reviewsTabs?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLButtonElement)) return;

    const filter = target.getAttribute("data-filter");
    if (!filter) return;

    currentFilter = filter;
    loadOpiniones();
  });

  closeReviewDetail?.addEventListener("click", () => {
    activeReviewId = null;

    if (reviewDetailSection) {
      reviewDetailSection.hidden = true;
    }
  });

  loadOpiniones();
</script>

<style is:global>
