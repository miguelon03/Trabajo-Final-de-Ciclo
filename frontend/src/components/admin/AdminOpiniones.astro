    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
  }

  .review-btn.is-detail {
    background: #C8FF00;
    color: #111;
    border-color: #C8FF00;
  }

  .review-btn.is-approve {
    color: #23bb64;
    border-color: rgba(17, 114, 61, 0.28);
    background: rgba(11, 74, 39, 0.28);
  }

  .review-btn.is-approve:hover {
    background: rgba(11, 74, 39, 0.42);
  }

  .review-btn.is-reject,
  .review-btn.is-delete {
    color: #ff5c6e;
    border-color: rgba(111, 33, 33, 0.28);
    background: rgba(76, 21, 21, 0.22);
  }

  .review-btn.is-reject:hover,
  .review-btn.is-delete:hover {
    background: rgba(76, 21, 21, 0.36);
  }

  .review-detail-shell {
    margin-top: 8px;
  }

  .review-detail-card {
    background: #111;
    border: 1px solid #202020;
    border-radius: 16px;
    padding: 18px;
  }

  .review-detail__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 18px;
  }

  .review-detail__eyebrow {
    margin: 0 0 6px;
    color: #C8FF00;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .review-detail__header h2 {
    margin: 0;
    color: #f4f4f4;
    font-size: 1.2rem;
  }

  .review-detail__close {
    min-height: 38px;
    padding: 0 14px;
    border-radius: 10px;
    border: 1px solid #303030;
    background: #171717;
    color: #e5e5e5;
    font-weight: 850;
