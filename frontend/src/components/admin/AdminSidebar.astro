---
const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <div class="brand">DMH — ADMIN</div>

  <div class="section-label">PANEL</div>
  <nav class="nav">
    <a href="/admin" class={currentPath === "/admin" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 5h6v6H5zM13 5h6v6h-6zM5 13h6v6H5zM13 13h6v6h-6z" />
        </svg>
      </span>
      <span>Dashboard</span>
    </a>
  </nav>

  <div class="section-label">TIENDA</div>
  <nav class="nav">
    <a href="/admin/productos" class={currentPath === "/admin/productos" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 6h10l1 3v9H6V9l1-3zm1.3 2L8 9h8l-.3-1zM9 12h6v2H9z" />
        </svg>
      </span>
      <span>Productos</span>
    </a>

    <a href="/admin/pedidos" class={currentPath === "/admin/pedidos" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 5h10v14H7zM9 8h6v1.8H9zm0 3h6v1.8H9zm0 3h4v1.8H9z" />
        </svg>
      </span>
      <span>Pedidos</span>
    </a>

    <a href="/admin/devoluciones" class={currentPath === "/admin/devoluciones" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 11H4l4-4 4 4H9c0 2.8 2.2 5 5 5a5 5 0 0 0 4.6-3h2A7 7 0 0 1 14 18c-3.9 0-7-3.1-7-7z" />
        </svg>
      </span>
      <span>Devoluciones</span>
    </a>

    <a href="/admin/opiniones" class={currentPath === "/admin/opiniones" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m12 17.3-5.2 3 1.4-5.9L3.6 10l6.1-.5L12 4l2.3 5.5 6.1.5-4.6 4.4 1.4 5.9z" />
        </svg>
      </span>
      <span>Opiniones</span>
    </a>

    <a href="/admin/usuarios" class={currentPath === "/admin/usuarios" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4zm0 2c-4.2 0-7 2.1-7 5v1h14v-1c0-2.9-2.8-5-7-5z" />
        </svg>
      </span>
      <span>Usuarios</span>
    </a>
  </nav>
</aside>

<style>
  .sidebar {
    min-height: 100vh;
    background: linear-gradient(180deg, #1c1c1c 0%, #141414 100%);
    border-right: 1px solid #2a2a2a;
    padding: 24px 18px;
    position: sticky;
    top: 0;
    align-self: start;
  }

  .brand {
    min-height: 58px;
    display: flex;
    align-items: center;
    padding: 0 14px 20px;
    color: #d7ff00;
    font-size: 1.06rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    border-bottom: 1px solid #292929;
    white-space: nowrap;
  }

  .section-label {
    color: #606060;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 26px 14px 10px;
    font-weight: 900;
  }

  .nav {
    display: grid;
    gap: 8px;
  }

  .nav a {
    min-height: 52px;
    display: grid;
    grid-template-columns: 22px 1fr;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: #a3a3a3;
    padding: 0 16px;
    border-radius: 14px;
    font-size: 0.98rem;
    font-weight: 800;
    transition: background 0.16s ease, color 0.16s ease, transform 0.16s ease;
  }

  .nav a:hover {
    background: #232323;
    color: #efefef;
    transform: translateX(2px);
  }

  .nav a.active {
    background: #d7ff00;
    color: #111;
  }

  .nav-icon {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .nav-icon svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  @media (max-width: 1100px) {
    .sidebar {
      padding: 22px 14px;
    }

    .brand {
      font-size: 0.96rem;
      letter-spacing: 0.16em;
    }

    .nav a {
      min-height: 50px;
      font-size: 0.93rem;
    }
  }

  @media (max-width: 980px) {
    .sidebar {
      min-height: auto;
      position: static;
      border-right: 0;
      border-bottom: 1px solid #272727;
      padding: 18px 16px 12px;
    }

    .brand {
      min-height: auto;
      font-size: 1.25rem;
      letter-spacing: 0.16em;
      margin-bottom: 16px;
      padding: 0;
      border-bottom: 0;
    }

    .section-label {
      font-size: 0.68rem;
      margin: 16px 0 8px;
    }

    .nav {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      gap: 8px;
      overflow-x: auto;
      padding: 0 0 5px;
      scrollbar-width: none;
    }

    .nav::-webkit-scrollbar {
      display: none;
    }

    .nav a {
      white-space: nowrap;
      flex-shrink: 0;
      min-height: 42px;
      grid-template-columns: 18px auto;
      padding: 0 14px;
      font-size: 0.86rem;
      border-radius: 12px;
    }

    .nav-icon,
    .nav-icon svg {
      width: 17px;
      height: 17px;
    }
  }

  @media (max-width: 640px) {
    .sidebar {
      padding: 14px 12px 8px;
    }

    .brand {
      font-size: 1rem;
      letter-spacing: 0.12em;
      margin-bottom: 12px;
    }

    .section-label {
      margin: 12px 0 7px;
    }

    .nav a {
      min-height: 38px;
      padding: 0 12px;
      font-size: 0.8rem;
    }
  }
</style>