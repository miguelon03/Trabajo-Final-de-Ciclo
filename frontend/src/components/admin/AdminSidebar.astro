---
const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <a class="brand" href="/admin" aria-label="Ir al panel de administración">
    <img src="/logo-dmh.png" alt="DMH" />
  </a>

  <div class="section-label">PANEL</div>
  <nav class="nav">
    <a href="/admin" class={currentPath === "/admin" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 5h6v6H5zM13 5h6v6h-6zM5 13h6v6H5zM13 13h6v6h-6z" />
        </svg>
      </span>
      <span>Dashboard</span>
    </a>

    <a
      href="/admin/personalizar-home"
      class={currentPath === "/admin/personalizar-home" ? "active" : ""}
    >
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3 3 8v13h18V8l-9-5Zm0 2.2 6.8 3.8v10H5.2V9l6.8-3.8Zm-3 6.3h6v1.8H9zm0 3.4h6v1.8H9z" />
        </svg>
      </span>
      <span>Personalizar home</span>
    </a>
  </nav>

  <div class="section-label">TIENDA</div>
  <nav class="nav">
    <a href="/admin/productos" class={currentPath === "/admin/productos" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 6h10l1 3v9H6V9l1-3zm1.3 2L8 9h8l-.3-1zM9 12h6v2H9z" />
        </svg>
      </span>
      <span>Productos</span>
    </a>

    <a href="/admin/pedidos" class={currentPath === "/admin/pedidos" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 5h10v14H7zM9 8h6v1.8H9zm0 3h6v1.8H9zm0 3h4v1.8H9z" />
        </svg>
      </span>
      <span>Pedidos</span>
    </a>

    <a href="/admin/devoluciones" class={currentPath === "/admin/devoluciones" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 11H4l4-4 4 4H9c0 2.8 2.2 5 5 5a5 5 0 0 0 4.6-3h2A7 7 0 0 1 14 18c-3.9 0-7-3.1-7-7z" />
        </svg>
      </span>
      <span>Devoluciones</span>
    </a>

    <a href="/admin/opiniones" class={currentPath === "/admin/opiniones" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m12 17.3-5.2 3 1.4-5.9L3.6 10l6.1-.5L12 4l2.3 5.5 6.1.5-4.6 4.4 1.4 5.9z" />
        </svg>
      </span>
      <span>Opiniones</span>
    </a>

    <a href="/admin/usuarios" class={currentPath === "/admin/usuarios" ? "active" : ""}>
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4zm0 2c-4.2 0-7 2.1-7 5v1h14v-1c0-2.9-2.8-5-7-5z" />
        </svg>
      </span>
      <span>Usuarios</span>
    </a>
  </nav>

  <div class="section-label">CUENTA</div>
  <nav class="nav">
    <a href="/" id="logoutLink" class="nav-link-logout">
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10 4h7v16h-7v-2h5V6h-5zm-1.2 3.2L3 12l5.8 4.8 1.2-1.5-3.4-2.8H14v-2H6.6L10 8.7z" />
        </svg>
      </span>
      <span>Cerrar sesión</span>
    </a>
  </nav>
</aside>

<style>
  .sidebar {
    min-height: 100vh;
    background: linear-gradient(180deg, #1a1a1a 0%, #121212 100%);
    border-right: 1px solid #242424;
    padding: 20px 12px;
    position: sticky;
    top: 0;
    align-self: start;
    overflow: hidden;
  }

  .brand {
    min-height: 50px;
    display: flex;
    align-items: center;
    padding: 0 10px 18px;
    border-bottom: 1px solid #272727;
  }

  .brand img {
    width: 148px;
    height: auto;
    object-fit: contain;
    display: block;
    filter: brightness(1.08);
  }

  .section-label {
    color: #5c5c5c;
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 22px 10px 9px;
    font-weight: 950;
  }

  .nav {
    display: grid;
    gap: 6px;
  }

  .nav a {
    min-height: 44px;
    display: grid;
    grid-template-columns: 18px 1fr;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    color: #a7a7a7;
    padding: 0 12px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 850;
    line-height: 1;
    transition:
      background 0.16s ease,
      color 0.16s ease,
      transform 0.16s ease;
  }

  .nav a:hover {
    background: #202020;
    color: #f0f0f0;
    transform: translateX(1px);
  }

  .nav a.active {
    background: #C8FF00;
    color: #111;
    box-shadow: 0 10px 24px rgba(200, 255, 0, 0.1);
  }

  .nav a.nav-link-logout {
    color: #f1b0b0;
  }

  .nav a.nav-link-logout:hover {
    background: rgba(255, 77, 77, 0.12);
    color: #ffd2d2;
  }

  .nav-icon {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .nav-icon svg {
    width: 17px;
    height: 17px;
    fill: currentColor;
  }

  @media (max-width: 1100px) {
    .sidebar {
      padding: 18px 10px;
    }

    .brand {
      padding-left: 8px;
      padding-right: 8px;
    }

    .brand img {
      width: 134px;
    }

    .nav a {
      min-height: 42px;
      grid-template-columns: 17px 1fr;
      gap: 10px;
      padding: 0 10px;
      font-size: 0.84rem;
    }

    .nav-icon,
    .nav-icon svg {
      width: 16px;
      height: 16px;
    }
  }

  @media (max-width: 980px) {
    .sidebar {
      min-height: auto;
      position: static;
      border-right: 0;
      border-bottom: 1px solid #272727;
      padding: 14px 12px 12px;
      overflow: hidden;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 6px;
    }

    .brand {
      flex: 0 0 100%;
      min-height: auto;
      margin-bottom: 4px;
      padding: 0;
      border-bottom: 0;
      justify-content: center;
    }

    .brand img {
      width: 146px;
    }

    .section-label {
      display: none;
    }

    /* Disolvemos las 3 listas de navegación para que TODOS los botones
       fluyan juntos en una sola fila centrada debajo del logo. */
    .nav {
      display: contents;
    }

    .nav:first-of-type {
      margin-top: 0;
    }

    /* Botones compactos para que las palabras quepan SIEMPRE en 2 filas
       (nunca 3) hasta que se pasa a solo iconos en ≤560px. */
    .nav a {
      white-space: nowrap;
      flex: 0 0 auto;
      min-height: 36px;
      grid-template-columns: 15px auto;
      gap: 7px;
      padding: 0 9px;
      font-size: 0.75rem;
      border-radius: 10px;
    }

    .nav-icon,
    .nav-icon svg {
      width: 15px;
      height: 15px;
    }
  }

  @media (max-width: 560px) {
    .sidebar {
      padding: 12px 10px;
      gap: 5px;
    }

    .brand {
      margin-bottom: 6px;
    }

    .brand img {
      width: 132px;
    }

    .nav a {
      width: 36px;
      min-height: 36px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      border-radius: 11px;
    }

    .nav a span:not(.nav-icon) {
      display: none;
    }

    .nav-icon,
    .nav-icon svg {
      width: 17px;
      height: 17px;
    }
  }
</style>
