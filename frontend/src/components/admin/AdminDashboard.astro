---
import { fetchAdminDashboard } from "../../lib/admin-dashboard-api";

let stats = {
  productos: 0,
  pedidos: 0,
  usuarios: 0,
  ingresosMes: 0,
};

let error = "";

try {
  const cookieHeader = Astro.request.headers.get("cookie") ?? "";
  stats = await fetchAdminDashboard(cookieHeader);
} catch (e) {
  error = e instanceof Error ? e.message : "Error al cargar dashboard";
}
---

<section class="admin-section">
  <h1>DASHBOARD</h1>

  {
    error ? (
      <p class="error-message">{error}</p>
    ) : (
      <div class="cards">
        <div class="card">
          <span class="label">Productos</span>
          <strong>{stats.productos}</strong>
        </div>

        <div class="card">
          <span class="label">Pedidos</span>
          <strong>{stats.pedidos}</strong>
        </div>

        <div class="card">
          <span class="label">Usuarios</span>
          <strong>{stats.usuarios}</strong>
        </div>

        <div class="card">
          <span class="label">Ingresos del mes</span>
          <strong>{stats.ingresosMes.toFixed(2)}€</strong>
        </div>
      </div>
    )
  }
</section>

<style>
  .admin-section h1 {
    font-size: var(--page-title-size);
    font-weight: 900;
    letter-spacing: var(--page-title-letter-spacing);
    margin-bottom: 24px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .card {
    background: #121212;
    border: 1px solid #232323;
    border-radius: 14px;
    padding: 22px;
  }

  .label {
    display: block;
    color: #777;
    margin-bottom: 12px;
    font-size: 0.86rem;
  }

  .card strong {
    font-size: clamp(1.65rem, 2.4vw, 2rem);
    color: #f5f5f5;
  }

  .error-message {
    color: #ff4d4d;
    font-size: 1rem;
  }

  @media (max-width: 980px) {
    .cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>