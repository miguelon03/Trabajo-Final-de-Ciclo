  .image-slots {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .image-slot {
    position: relative;
    height: 260px;
    border: 1px dashed #3a3a3a;
    border-radius: 16px;
    background: #171717;
    overflow: hidden;
    cursor: pointer;
    transition:
      border-color 0.16s ease,
      background 0.16s ease,
      transform 0.16s ease;
  }

  .image-slot:hover {
    border-color: rgba(215, 255, 0, 0.55);
    background: #1b1b1b;
    transform: translateY(-1px);
  }

  .image-slot.is-drag-over {
    border-color: #d7ff00;
    background: #1c210f;
  }

  .image-slot-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    z-index: 4;
  }

  .image-slot-preview {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 1;
  }

  .image-slot-preview[hidden] {
    display: none !important;
  }

  .image-slot-placeholder {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 6px;
    text-align: center;
    color: #a0a0a0;
    padding: 12px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(0, 0, 0, 0.18));
