    line-height: 1.3;
  }

  .image-slot.has-image .image-slot-placeholder {
    opacity: 0;
    pointer-events: none;
  }

  .image-slot-clear {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    z-index: 5;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.62);
