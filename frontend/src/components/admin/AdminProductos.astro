    border-radius: 12px;
    background: #141414;
    color: #ededed;
    padding: 12px 14px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.28);
    font-size: 0.84rem;
    line-height: 1.4;
    transform: translateY(8px);
    opacity: 0;
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  :global(.admin-toast.is-visible) {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.admin-toast.is-leaving) {
    opacity: 0;
    transform: translateY(8px);
  }

  :global(.admin-toast--success) {
    border-color: rgba(215, 255, 0, 0.35);
  }

  :global(.admin-toast--error) {
    border-color: rgba(255, 96, 96, 0.4);
  }

  :global(.admin-toast--confirm) {
    display: grid;
    gap: 10px;
  }

  :global(.admin-toast__text) {
    color: #f1f1f1;
    font-weight: 700;
  }

  :global(.admin-toast__actions) {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }

  :global(.admin-toast__btn) {
    border: none;
    border-radius: 9px;
    min-height: 30px;
    padding: 0 10px;
    font-size: 0.76rem;
    font-weight: 850;
