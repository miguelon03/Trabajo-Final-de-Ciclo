  const deleteConfirmBackdrop = document.getElementById("deleteConfirmBackdrop");
  const confirmDeleteBtn = document.getElementById("confirmDeleteBtn");
  const stockSplitForm = document.getElementById("stockSplitForm");
  const stockSplitGrid = document.getElementById("stockSplitGrid");
  const stockSplitProductName = document.getElementById(
    "stockSplitProductName",
  );
  const stockSplitTotal = document.getElementById("stockSplitTotal");
  const stockSplitAssigned = document.getElementById("stockSplitAssigned");
  const stockSplitExpected = document.getElementById("stockSplitExpected");
  const stockSplitWarning = document.getElementById("stockSplitWarning");

  type StockVariantDraft = {
    talla: string;
    stock: number;
  };

  type PendingCreatePayload = {
    id?: number;
    nombre: string;
    slug: string;
    descripcion: string;
    precio_base: number;
    precio_original: string;
    tallaje: string;
    tipo: string;
    badge: string;
    estado: string;
    stock_inicial: number;
    imagenes?: {
      data_url: string;
      nombre: string;
    }[];
    variantes?: StockVariantDraft[];
  };

  let pendingCreatePayload: PendingCreatePayload | null = null;
  let pendingDeleteProductId: number | null = null;
  let stockSplitSizes: string[] = [];
  let lastManualTipo = "";
  let selectedImageFiles: (File | null)[] = [null, null, null];
  let selectedImagePreviewUrls: string[] = ["", "", ""];

  function asField(
    el: Element | null,
  ): HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null {
    if (
      el instanceof HTMLInputElement ||
      el instanceof HTMLTextAreaElement ||
      el instanceof HTMLSelectElement
    ) {
      return el;
    }

    return null;
  }

  function slugify(value: string): string {
    const normalized = value
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");

    return normalized || "producto";
  }

  function normalizeBadgeValue(value: string): string {
    const normalized = value.trim().toLowerCase();

    if (normalized === "new") return "NEW";
    if (normalized === "oferta") return "Oferta";

    return "";
  }

  function normalizeTallajeValue(value: string): "clasico" | "pantalon" | "unica" {
    const normalized = value.trim().toLowerCase();

    if (normalized === "pantalon") return "pantalon";
    if (normalized === "unica") return "unica";
    return "clasico";
  }

  function resolveTallajeFromForm(tipo: string, currentTallaje: string): "clasico" | "pantalon" | "unica" {
    const explicit = normalizeTallajeValue(currentTallaje);
    if (explicit) return explicit;

    const normalizedType = normalizeType(tipo);
    if (normalizedType.includes("accesorio")) return "unica";
    if (normalizedType.includes("pantalon")) return "pantalon";
    return "clasico";
  }

  function validateAndNormalizePricing(
    precioActualRaw: string,
    precioOriginalRaw: string,
    currentBadge: string,
  ): {
    precioOferta: number;
    precioOriginal: string;
    badge: string;
    warning: string | null;
  } {
    const ofertaTrimmed = precioActualRaw.trim();
    const originalTrimmed = precioOriginalRaw.trim();
    const hasOriginal = originalTrimmed !== "";
    const hasOferta = ofertaTrimmed !== "";
    const hasValidMoney = (value: string) => /^\d+(?:[\.,]\d{1,2})?$/.test(value);
    const parseMoney = (value: string) => Number(value.replace(",", "."));
    const originalNumber = hasOriginal ? parseMoney(originalTrimmed) : null;
    const normalizedBadge = normalizeBadgeValue(currentBadge);
    const precioActual = hasOferta ? parseMoney(ofertaTrimmed) : null;

    if (hasOriginal && !hasValidMoney(originalTrimmed)) {
      throw new Error("El precio original no es válido");
    }

    if (hasOriginal && (!Number.isFinite(originalNumber) || Number(originalNumber) <= 0)) {
      throw new Error("El precio original debe ser mayor que 0");
    }

    if (normalizedBadge === "Oferta") {
      if (!hasOferta) {
        throw new Error("Debes indicar el precio oferta");
      }

      if (!hasValidMoney(ofertaTrimmed)) {
        throw new Error("El precio oferta no es válido");
      }

      if (!Number.isFinite(precioActual) || Number(precioActual) <= 0) {
        throw new Error("El precio oferta debe ser mayor que 0");
      }

      if (!hasOriginal) {
        throw new Error("Para usar badge Oferta debes indicar también el precio original");
      }

      if (Number(precioActual) >= Number(originalNumber)) {
        throw new Error("El precio oferta debe ser inferior al precio original");
      }

      return {
        precioOferta: Number(precioActual),
        precioOriginal: Number(originalNumber).toFixed(2),
        badge: normalizedBadge,
        warning: null,
      };
    }

    if (hasOferta) {
      throw new Error("El precio oferta solo se permite cuando la badge es Oferta");
    }

    if (!hasOriginal) {
      throw new Error("Debes indicar el precio del producto");
    }

    return {
      // Sin badge Oferta, usamos el precio original como precio base y no enviamos precio original.
      precioOferta: Number(originalNumber),
      precioOriginal: "",
      badge: normalizedBadge,
      warning: null,
    };
  }

  function formatMoneyInput(input: HTMLInputElement, optional = false) {
    const raw = input.value.trim();
    if (!raw) {
      if (!optional) {
        input.value = "";
      }
      return;
    }

    const parsed = Number(raw.replace(",", "."));
    if (!Number.isFinite(parsed)) {
      return;
    }

    input.value = parsed.toFixed(2);
  }

  type ToastKind = "success" | "error" | "info";

  let adminToastStackEl: HTMLElement | null = null;

  function ensureAdminToastStack(): HTMLElement {
    if (adminToastStackEl) return adminToastStackEl;

    const existing = document.getElementById("adminToastStack");
    if (existing instanceof HTMLElement) {
      adminToastStackEl = existing;
      return existing;
    }

    const stack = document.createElement("div");
    stack.id = "adminToastStack";
    stack.className = "admin-toast-stack";
    document.body.appendChild(stack);
    adminToastStackEl = stack;
    return stack;
  }

  function showToastMessage(message: string, kind: ToastKind = "info") {
    if (typeof appWindow.showToast === "function") {
      appWindow.showToast(message, kind);
      return;
    }

    const stack = ensureAdminToastStack();
    const toast = document.createElement("div");
    toast.className = `admin-toast admin-toast--${kind}`;
    toast.textContent = message;
    stack.appendChild(toast);

    requestAnimationFrame(() => {
      toast.classList.add("is-visible");
    });

    setTimeout(() => {
      toast.classList.remove("is-visible");
      toast.classList.add("is-leaving");
      setTimeout(() => toast.remove(), 220);
    }, 2800);
  }

  function setProductFormFeedback(message: string, kind: "error" | "success" = "error") {
    if (!(productFormFeedback instanceof HTMLElement)) return;
    productFormFeedback.textContent = message;
    productFormFeedback.style.color = kind === "success" ? "#8effad" : "#ff8f8f";
  }

  function openDeleteConfirmModal(productId: number) {
    pendingDeleteProductId = productId;
    deleteConfirmBackdrop?.classList.add("is-open");
    document.body.style.overflow = "hidden";
  }

  function closeDeleteConfirmModal() {
    pendingDeleteProductId = null;
    deleteConfirmBackdrop?.classList.remove("is-open");
    document.body.style.overflow = "";
  }

  async function confirmDeleteProduct() {
    if (!pendingDeleteProductId) return;

    const id = pendingDeleteProductId;
    closeDeleteConfirmModal();

    try {
      await deleteAdminProducto(id);
      showToastMessage("Producto eliminado", "success");
      window.location.reload();
    } catch (error) {
      showToastMessage(
        error instanceof Error ? error.message : "Error al eliminar producto",
        "error",
      );
    }
  }

  function validateRequiredProductFields(options: {
    isEditing: boolean;
    nombre: string;
    slug: string;
    descripcion: string;
    precioOfertaRaw: string;
    precioOriginalRaw: string;
    tallaje: string;
    tipo: string;
    badge: string;
    estado: string;
    stockRaw: string;
    hasImageSelected: boolean;
  }) {
    const isOfertaBadge = normalizeBadgeValue(options.badge) === "Oferta";

    if (!options.nombre) {
      throw new Error("Debes indicar el nombre del producto");
    }

    if (!options.slug) {
      throw new Error("No se ha podido generar el slug automáticamente");
    }

    if (!options.descripcion) {
      throw new Error("Debes indicar la descripción del producto");
    }

    if (isOfertaBadge) {
      if (!options.precioOfertaRaw) {
        throw new Error("Debes indicar un precio oferta válido");
      }

      if (!/^\d+(?:[\.,]\d{1,2})?$/.test(options.precioOfertaRaw.trim())) {
        throw new Error("Debes indicar un precio oferta válido");
      }
    } else if (!options.precioOriginalRaw || !/^\d+(?:[\.,]\d{1,2})?$/.test(options.precioOriginalRaw.trim())) {
      throw new Error("Debes indicar el precio del producto");
    }

    if (!options.tallaje) {
      throw new Error("Debes seleccionar el tallaje");
    }

    if (!options.tipo) {
      throw new Error("Debes indicar el tipo de producto");
    }

    if (!options.estado) {
      throw new Error("Debes seleccionar el estado del producto");
    }

    const stockValue = Number(options.stockRaw.trim() === "" ? "0" : options.stockRaw);
    if (!Number.isFinite(stockValue) || stockValue < 0) {
      throw new Error("Debes indicar un stock válido");
    }

    if (!options.isEditing && !options.hasImageSelected) {
      throw new Error("Debes subir al menos 1 imagen en una de las 3 cajas");
    }

    if (isOfertaBadge && options.precioOriginalRaw.trim() === "") {
      throw new Error("Con badge Oferta debes completar el precio original");
    }
  }

  function setProductImageVisible(visible: boolean) {
    if (productImageField instanceof HTMLElement) {
      productImageField.hidden = !visible;
    }

    productImageSlotInputs.forEach((input) => {
      input.disabled = !visible;
    });

    productImageSlotClearButtons.forEach((button) => {
      button.disabled = !visible;
    });
  }

  function syncTipoFromAccesorioToggle() {
    if (!(productTipo instanceof HTMLInputElement)) return;
    if (!(productIsAccesorio instanceof HTMLInputElement)) return;

    const isAccesorio = productIsAccesorio.checked;

    if (isAccesorio) {
      const currentTipo = productTipo.value.trim();
      if (currentTipo && normalizeType(currentTipo) !== "accesorio") {
        lastManualTipo = currentTipo;
      }

      productTipo.value = "accesorio";
      productTipo.readOnly = true;
      productTipo.placeholder = "accesorio";
      return;
    }

    productTipo.readOnly = false;
    productTipo.placeholder = "Ej: camiseta";

    if (normalizeType(productTipo.value) === "accesorio") {
      productTipo.value = lastManualTipo;
    }
  }

  function syncPricingModeFromBadge() {
    if (!(productBadge instanceof HTMLSelectElement)) return;
    if (!(productPrecioBase instanceof HTMLInputElement)) return;
    if (!(productPrecioOriginal instanceof HTMLInputElement)) return;

    const isOferta = normalizeBadgeValue(productBadge.value) === "Oferta";

    productPrecioBase.disabled = !isOferta;

    if (isOferta) {
      productPrecioBase.required = true;
      productPrecioBase.placeholder = "Ej: 9,99";
      productPrecioOriginal.placeholder = "Ej: 50,00";
      return;
    }

    productPrecioBase.required = false;
    productPrecioBase.value = "";
    productPrecioBase.placeholder = "Solo disponible con badge Oferta";
    productPrecioOriginal.placeholder = "Ej: 39,99";
  }

  function validateProductImage(file: File): void {
    const allowedTypes = ["image/jpeg", "image/png", "image/webp"];
    const maxBytes = 4 * 1024 * 1024;

    if (!allowedTypes.includes(file.type)) {
      throw new Error("Las imágenes deben ser JPG, PNG o WEBP");
    }

    if (file.size > maxBytes) {
      throw new Error("Cada imagen no puede superar los 4MB");
    }
  }

  function readFileAsDataUrl(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();

      reader.onload = () => {
        if (typeof reader.result === "string") {
          resolve(reader.result);
        } else {
          reject(new Error("No se pudo leer una imagen"));
        }
      };

      reader.onerror = () => {
        reject(new Error("No se pudo leer una imagen"));
      };

      reader.readAsDataURL(file);
    });
  }

  function updateImageSlotsSummary() {
    if (!(productImageUploadText instanceof HTMLElement)) return;

    const selectedCount = selectedImageFiles.filter((file) => file instanceof File)
      .length;

    productImageUploadText.textContent =
      selectedCount > 0
        ? `${selectedCount}/3 imágenes cargadas. Vista previa con tamaño de catálogo.`
        : "Vista previa en formato catálogo. Máximo 3 imágenes (JPG, PNG o WEBP, 4MB cada una).";
  }

  function resetImageInput() {
    selectedImageFiles = [null, null, null];

    selectedImagePreviewUrls.forEach((url) => {
      if (url) URL.revokeObjectURL(url);
    });

    selectedImagePreviewUrls = ["", "", ""];

    productImageSlotInputs.forEach((input) => {
      input.value = "";
    });

    productImageSlots.forEach((slot) => {
      slot.classList.remove("has-image");
      slot.classList.remove("is-drag-over");
    });

    productImageSlotPreviews.forEach((preview) => {
      preview.src = "";
      preview.hidden = true;
    });

    productImageSlotClearButtons.forEach((button) => {
      button.hidden = true;
    });

    updateImageSlotsSummary();
  }

  function setImageForSlot(slotIndex: number, file: File | null): void {
    const slot = productImageSlots[slotIndex];
    const preview = productImageSlotPreviews[slotIndex];
    const clearButton = productImageSlotClearButtons[slotIndex];
    const input = productImageSlotInputs[slotIndex];

    if (!slot || !preview || !clearButton || !input) return;

    const previousUrl = selectedImagePreviewUrls[slotIndex];
    if (previousUrl) {
      URL.revokeObjectURL(previousUrl);
      selectedImagePreviewUrls[slotIndex] = "";
    }

    selectedImageFiles[slotIndex] = file;

    if (!file) {
      input.value = "";
      preview.removeAttribute("src");
      preview.hidden = true;
      clearButton.hidden = true;
      slot.classList.remove("has-image");
      updateImageSlotsSummary();
      return;
    }

    const objectUrl = URL.createObjectURL(file);
    selectedImagePreviewUrls[slotIndex] = objectUrl;
    preview.hidden = true;
    preview.src = objectUrl;
    clearButton.hidden = true;
    slot.classList.remove("has-image");
    updateImageSlotsSummary();
  }

  function handleSlotFileSelection(slotIndex: number, file: File | null): void {
    if (!file) {
      setImageForSlot(slotIndex, null);
      return;
    }

    try {
      validateProductImage(file);
      setImageForSlot(slotIndex, file);
    } catch (error) {
      setImageForSlot(slotIndex, null);
      showToastMessage(
        error instanceof Error ? error.message : "Imagen no válida",
        "error",
      );
    }
  }

  async function buildProductImagesPayload(files: (File | null)[]) {
    const imagenes = [];

    for (const file of files) {
      if (!(file instanceof File)) continue;

      imagenes.push({
        data_url: await readFileAsDataUrl(file),
        nombre: file.name,
      });
    }

    return imagenes;
  }

  function isInteractiveTarget(target: EventTarget | null): boolean {
    if (!(target instanceof Element)) return false;

    return Boolean(target.closest("button, a, input, label, select, textarea"));
  }

  function setRowSelected(row: HTMLTableRowElement, selected: boolean) {
    const checkbox = row.querySelector<HTMLInputElement>(".product-select");

    if (checkbox) {
      checkbox.checked = selected;
    }

    row.classList.toggle("is-selected", selected);
    row.setAttribute("aria-selected", selected ? "true" : "false");
  }

  function getSelectedProductIds(): number[] {
    return productCheckboxes
      .filter((checkbox) => checkbox.checked)
      .map((checkbox) => Number(checkbox.value))
      .filter((id) => Number.isInteger(id) && id > 0);
  }

  function normalizeSearchText(value: string): string {
    return value
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .trim();
  }

  function getVisibleProductRows(): HTMLTableRowElement[] {
    return productRows.filter((row) => !row.hidden);
  }

  function applyProductSearchFilter(): void {
    const rawQuery =
      productSearchInput instanceof HTMLInputElement
        ? productSearchInput.value
        : "";
    const query = normalizeSearchText(rawQuery);

    let visibleCount = 0;

    productRows.forEach((row) => {
      const source = row.dataset.search || row.textContent || "";
      const haystack = normalizeSearchText(source);
      const matches = query === "" || haystack.includes(query);

      row.hidden = !matches;

      if (!matches) {
        setRowSelected(row, false);
      } else {
        visibleCount += 1;
      }
    });

    const footer = document.querySelector<HTMLElement>(".footer-row");
    if (footer instanceof HTMLElement) {
      footer.textContent = `Mostrando ${visibleCount} de ${productRows.length} productos`;
    }

    if (productsSearchEmpty instanceof HTMLElement) {
      productsSearchEmpty.hidden = visibleCount > 0;
    }

    updateBulkToolbar();
  }

  function updateBulkToolbar() {
    const visibleRows = getVisibleProductRows();
    const visibleCheckboxes = visibleRows
      .map((row) => row.querySelector<HTMLInputElement>(".product-select"))
      .filter((checkbox): checkbox is HTMLInputElement => checkbox instanceof HTMLInputElement);
    const selected = visibleCheckboxes.filter((checkbox) => checkbox.checked).length;
    const total = visibleCheckboxes.length;

    productRows.forEach((row) => {
      const checkbox = row.querySelector<HTMLInputElement>(".product-select");
      const checked = Boolean(checkbox?.checked);

      row.classList.toggle("is-selected", checked);
      row.setAttribute("aria-selected", checked ? "true" : "false");
    });

    if (selectedProductsCount instanceof HTMLElement) {
      selectedProductsCount.textContent = String(selected);
    }

    if (selectAllProducts instanceof HTMLInputElement) {
      selectAllProducts.checked = total > 0 && selected === total;
      selectAllProducts.indeterminate = selected > 0 && selected < total;
    }

    if (bulkBadgeBtn instanceof HTMLButtonElement) {
      bulkBadgeBtn.disabled = selected === 0;
    }

    if (bulkBadgeMessage instanceof HTMLElement) {
      bulkBadgeMessage.textContent = "";
    }
  }

  function openModal() {
    modalBackdrop?.classList.add("is-open");
    document.body.style.overflow = "hidden";
    setProductFormFeedback("");
  }

  function closeModal() {
    modalBackdrop?.classList.remove("is-open");
    document.body.style.overflow = "";
  }

  function openStockSplitModal() {
    stockSplitModalBackdrop?.classList.add("is-open");
    document.body.style.overflow = "hidden";
  }

  function closeStockSplitModal() {
    stockSplitModalBackdrop?.classList.remove("is-open");
    document.body.style.overflow = "";
  }

  function resetForm() {
    if (!(productId instanceof HTMLInputElement)) return;

    const nombreInput = asField(productNombre);
    const slugInput = asField(productSlug);
    const descripcionInput = asField(productDescripcion);
    const precioBaseInput = asField(productPrecioBase);
    const precioOriginalInput = asField(productPrecioOriginal);
    const tipoInput = asField(productTipo);
    const tallajeInput = asField(productTallaje);
    const badgeInput = asField(productBadge);
    const stockInicialInput = asField(productStockInicial);
    const estadoInput = asField(productEstado);

    if (
      !nombreInput ||
      !slugInput ||
      !descripcionInput ||
      !precioBaseInput ||
      !precioOriginalInput ||
      !tallajeInput ||
      !tipoInput ||
      !badgeInput ||
      !stockInicialInput ||
      !estadoInput
    ) {
      return;
    }

    productId.value = "";
    nombreInput.value = "";
    slugInput.value = "";
    descripcionInput.value = "";
    precioBaseInput.value = "";
    precioOriginalInput.value = "";
    tipoInput.value = "";
    if (productIsAccesorio instanceof HTMLInputElement) {
      productIsAccesorio.checked = false;
    }
    lastManualTipo = "";
    tallajeInput.value = "clasico";
    badgeInput.value = "NEW";
    stockInicialInput.value = "";
    stockInicialInput.disabled = false;
    estadoInput.value = "borrador";
    pendingCreatePayload = null;
    stockSplitSizes = [];
    setProductFormFeedback("");
    resetImageInput();
    setProductImageVisible(true);
    syncTipoFromAccesorioToggle();
    syncPricingModeFromBadge();

    if (productStockLabel instanceof HTMLElement) {
      productStockLabel.textContent = "Stock";
    }
  }

  function fillEditForm(button: HTMLButtonElement) {
    if (!(button instanceof HTMLButtonElement)) return;
    if (!(productId instanceof HTMLInputElement)) return;

    const nombreInput = asField(productNombre);
    const slugInput = asField(productSlug);
    const descripcionInput = asField(productDescripcion);
    const precioBaseInput = asField(productPrecioBase);
    const precioOriginalInput = asField(productPrecioOriginal);
    const tipoInput = asField(productTipo);
    const tallajeInput = asField(productTallaje);
    const badgeInput = asField(productBadge);
    const stockInicialInput = asField(productStockInicial);
    const estadoInput = asField(productEstado);

    if (
      !nombreInput ||
      !slugInput ||
      !descripcionInput ||
      !precioBaseInput ||
      !precioOriginalInput ||
      !tallajeInput ||
      !tipoInput ||
      !badgeInput ||
      !stockInicialInput ||
      !estadoInput
    ) {
      return;
    }

    productId.value = button.dataset.id || "";
    nombreInput.value = button.dataset.nombre || "";
    slugInput.value = button.dataset.slug || "";
    descripcionInput.value = button.dataset.descripcion || "";
    const badgeNormalized = normalizeBadgeValue(button.dataset.badge || "");
    const precioBaseData = button.dataset.precioBase || "";
    const precioOriginalData = button.dataset.precioOriginal || "";

    if (badgeNormalized === "Oferta") {
      precioBaseInput.value = precioBaseData;
      precioOriginalInput.value = precioOriginalData;
    } else {
      precioBaseInput.value = "";
      precioOriginalInput.value = precioBaseData;
    }
    tallajeInput.value = normalizeTallajeValue(button.dataset.tallaje || "clasico");
    tipoInput.value = button.dataset.tipo || "";
    const isAccesorio = normalizeType(tipoInput.value) === "accesorio";
    if (productIsAccesorio instanceof HTMLInputElement) {
      productIsAccesorio.checked = isAccesorio;
    }
    lastManualTipo = isAccesorio ? "" : tipoInput.value.trim();
    badgeInput.value = badgeNormalized;
    stockInicialInput.value = "0";
    stockInicialInput.disabled = false;
    estadoInput.value = button.dataset.estado || "borrador";
    setProductFormFeedback("");
    resetImageInput();
    setProductImageVisible(false);
    syncTipoFromAccesorioToggle();
    syncPricingModeFromBadge();

    if (productStockLabel instanceof HTMLElement) {
      productStockLabel.textContent = "Añadir stock";
    }
  }

  productRows.forEach((row) => {
    row.addEventListener("click", (event) => {
      if (isInteractiveTarget(event.target)) return;

      const checkbox = row.querySelector<HTMLInputElement>(".product-select");
      if (!checkbox) return;

      setRowSelected(row, !checkbox.checked);
      updateBulkToolbar();
    });

    row.addEventListener("keydown", (event) => {
      if (event.key !== "Enter" && event.key !== " ") return;
      if (isInteractiveTarget(event.target)) return;

      event.preventDefault();

      const checkbox = row.querySelector<HTMLInputElement>(".product-select");
      if (!checkbox) return;

      setRowSelected(row, !checkbox.checked);
      updateBulkToolbar();
    });
  });

  selectAllProducts?.addEventListener("change", () => {
    if (!(selectAllProducts instanceof HTMLInputElement)) return;

    getVisibleProductRows().forEach((row) => {
      setRowSelected(row, selectAllProducts.checked);
    });

    updateBulkToolbar();
  });

  clearProductSelectionBtn?.addEventListener("click", () => {
    productRows.forEach((row) => {
      setRowSelected(row, false);
    });

    if (bulkBadgeSelect instanceof HTMLSelectElement) {
      bulkBadgeSelect.value = "";
    }

    updateBulkToolbar();
  });

  productSearchInput?.addEventListener("input", applyProductSearchFilter);

  clearProductSearchBtn?.addEventListener("click", () => {
    if (!(productSearchInput instanceof HTMLInputElement)) return;

    productSearchInput.value = "";
    applyProductSearchFilter();
    productSearchInput.focus();
  });

  bulkBadgeBtn?.addEventListener("click", async () => {
    const selectedIds = getSelectedProductIds();

    if (selectedIds.length === 0) {
      if (bulkBadgeMessage instanceof HTMLElement) {
        bulkBadgeMessage.textContent = "Selecciona al menos un producto";
      }
      return;
    }

    const badge =
      bulkBadgeSelect instanceof HTMLSelectElement ? bulkBadgeSelect.value : "";

    try {
      await updateAdminProductosBadge(selectedIds, badge);
      window.location.reload();
    } catch (error) {
      if (bulkBadgeMessage instanceof HTMLElement) {
        bulkBadgeMessage.textContent =
          error instanceof Error ? error.message : "Error al actualizar badges";
      }
    }
  });

  function syncSlugFromName() {
    if (!(productNombre instanceof HTMLInputElement)) return;
    if (!(productSlug instanceof HTMLInputElement)) return;

    const nombre = productNombre.value.trim();
    productSlug.value = nombre ? slugify(nombre) : "";
  }

  productNombre?.addEventListener("input", syncSlugFromName);
  productNombre?.addEventListener("blur", syncSlugFromName);

  if (productIsAccesorio instanceof HTMLInputElement) {
    productIsAccesorio.addEventListener("change", () => {
      syncTipoFromAccesorioToggle();
    });
  }

  if (productTipo instanceof HTMLInputElement) {
    productTipo.addEventListener("input", () => {
      if (!(productIsAccesorio instanceof HTMLInputElement)) return;
      if (!productIsAccesorio.checked) {
        lastManualTipo = productTipo.value.trim();
      }
    });
  }

  if (productPrecioBase instanceof HTMLInputElement) {
    productPrecioBase.addEventListener("blur", () => {
      formatMoneyInput(productPrecioBase, false);
    });
  }

  if (productPrecioOriginal instanceof HTMLInputElement) {
    productPrecioOriginal.addEventListener("blur", () => {
      formatMoneyInput(productPrecioOriginal, true);
    });
  }

  if (productBadge instanceof HTMLSelectElement) {
    productBadge.addEventListener("change", () => {
      syncPricingModeFromBadge();
    });
  }

  syncTipoFromAccesorioToggle();
  syncPricingModeFromBadge();

  productImageSlotInputs.forEach((input, slotIndex) => {
    input.addEventListener("change", () => {
      const file = input.files?.[0] ?? null;
      handleSlotFileSelection(slotIndex, file);
    });
  });

  productImageSlots.forEach((slot, slotIndex) => {
    slot.addEventListener("dragover", (event) => {
      event.preventDefault();
      slot.classList.add("is-drag-over");
    });

    slot.addEventListener("dragleave", () => {
      slot.classList.remove("is-drag-over");
    });

    slot.addEventListener("drop", (event) => {
      event.preventDefault();
      slot.classList.remove("is-drag-over");

      const file = event.dataTransfer?.files?.[0] ?? null;
      handleSlotFileSelection(slotIndex, file);
    });
  });

  productImageSlotClearButtons.forEach((button, slotIndex) => {
    button.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      setImageForSlot(slotIndex, null);
    });
  });

  productImageSlotPreviews.forEach((preview, slotIndex) => {
    preview.addEventListener("load", () => {
      const slot = productImageSlots[slotIndex];
      const clearButton = productImageSlotClearButtons[slotIndex];
      if (!slot) return;
      if (!(selectedImageFiles[slotIndex] instanceof File)) return;
      if (!preview.getAttribute("src")) return;

      preview.hidden = false;
      slot.classList.add("has-image");
      if (clearButton) {
        clearButton.hidden = false;
      }
    });

    preview.addEventListener("error", () => {
      setImageForSlot(slotIndex, null);
    });
  });

  function normalizeType(value: string): string {
    return value
      .toLowerCase()
      .trim()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
  }

  function getSizesForTallaje(tallaje: string): string[] {
    const normalized = normalizeTallajeValue(tallaje);

    if (normalized === "unica") {
      return ["Única"];
    }

    if (normalized === "pantalon") {
      return ["28", "36", "40", "42", "44"];
    }

    return ["XS", "S", "M", "L", "XL"];
  }

  function renderStockSplitGrid(totalStock: number, sizes: string[]) {
    if (!(stockSplitGrid instanceof HTMLElement)) return;

    stockSplitGrid.innerHTML = sizes
      .map(
        (size) => `
        <div class="stock-split__field">
          <label for="stock-size-${size}">Talla ${size}</label>
          <input
            id="stock-size-${size}"
            class="stock-split__input stock-size-input"
            type="number"
            min="0"
            step="1"
            value="0"
            data-size="${size}"
          />
        </div>
      `,
      )
      .join("");

    stockSplitGrid.querySelectorAll(".stock-size-input").forEach((input) => {
      input.addEventListener("input", updateStockSplitSummary);
    });

    if (stockSplitExpected instanceof HTMLElement) {
      stockSplitExpected.textContent = String(totalStock);
    }

    updateStockSplitSummary();
  }

  function updateStockSplitSummary() {
    const expectedTotal = Number(
      stockSplitExpected instanceof HTMLElement
        ? stockSplitExpected.textContent || "0"
        : "0",
    );

    const assigned = Array.from(document.querySelectorAll(".stock-size-input"))
      .filter((input) => input instanceof HTMLInputElement)
      .reduce((sum, input) => sum + Math.max(0, Number(input.value || 0)), 0);

    if (stockSplitAssigned instanceof HTMLElement) {
      stockSplitAssigned.textContent = String(assigned);
    }

    if (stockSplitWarning instanceof HTMLElement) {
      if (assigned === expectedTotal) {
        stockSplitWarning.hidden = true;
        stockSplitWarning.textContent = "";
      } else if (assigned < expectedTotal) {
        stockSplitWarning.hidden = false;
        stockSplitWarning.textContent = `Faltan ${expectedTotal - assigned} unidades por repartir.`;
      } else {
        stockSplitWarning.hidden = false;
        stockSplitWarning.textContent = `Te sobran ${assigned - expectedTotal} unidades. Reduce el reparto.`;
      }
    }
  }

  function prepareStockSplitModal(payload: PendingCreatePayload) {
    const totalStock = Math.max(0, Number(payload.stock_inicial || 0));
    const sizes = getSizesForTallaje(payload.tallaje || "clasico");

    pendingCreatePayload = payload;
    stockSplitSizes = sizes;

    if (stockSplitProductName instanceof HTMLElement) {
      stockSplitProductName.textContent = payload.nombre || "Producto";
    }

    if (stockSplitTotal instanceof HTMLElement) {
      stockSplitTotal.textContent = String(totalStock);
    }

    renderStockSplitGrid(totalStock, sizes);
  }

  function collectVariantsFromSplit(totalStock: number): StockVariantDraft[] {
    const inputs = Array.from(
      document.querySelectorAll(".stock-size-input"),
    ).filter((input) => input instanceof HTMLInputElement);

    const variants = inputs.map((input) => ({
      talla: input.dataset.size || "Única",
      stock: Math.max(0, Number(input.value || 0)),
    }));

    const assigned = variants.reduce((sum, item) => sum + item.stock, 0);

    if (assigned !== totalStock) {
      throw new Error(
        `La suma por tallas debe ser ${totalStock}. Ahora mismo es ${assigned}.`,
      );
    }

    return variants.filter(
      (item) => item.stock > 0 || stockSplitSizes.length === 1,
    );
  }

  document.getElementById("newProductBtn")?.addEventListener("click", () => {
    resetForm();

    if (modalTitle instanceof HTMLElement) {
      modalTitle.textContent = "Nuevo producto";
    }

    openModal();
  });

  document.querySelectorAll<HTMLButtonElement>(".btn-edit").forEach((btn) => {
    btn.addEventListener("click", () => {
      fillEditForm(btn);

      if (modalTitle instanceof HTMLElement) {
        modalTitle.textContent = "Editar producto";
      }

      openModal();
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".btn-delete").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = Number(btn.dataset.id);
      if (!id) return;

      openDeleteConfirmModal(id);
    });
  });

  document
    .getElementById("closeProductModal")
    ?.addEventListener("click", closeModal);

  document
    .getElementById("cancelProductModal")
    ?.addEventListener("click", closeModal);

  document
    .getElementById("closeStockSplitModal")
    ?.addEventListener("click", () => {
      closeStockSplitModal();
      openModal();
    });

  document
    .getElementById("backToProductModalBtn")
    ?.addEventListener("click", () => {
      closeStockSplitModal();
      openModal();
    });

  document
    .getElementById("closeDeleteConfirmModal")
    ?.addEventListener("click", closeDeleteConfirmModal);

  document
    .getElementById("cancelDeleteConfirmBtn")
    ?.addEventListener("click", closeDeleteConfirmModal);

  confirmDeleteBtn?.addEventListener("click", () => {
    void confirmDeleteProduct();
  });

  modalBackdrop?.addEventListener("click", (e) => {
    if (e.target === modalBackdrop) {
      closeModal();
    }
  });

  stockSplitModalBackdrop?.addEventListener("click", (e) => {
    if (e.target === stockSplitModalBackdrop) {
      closeStockSplitModal();
      openModal();
    }
  });

  deleteConfirmBackdrop?.addEventListener("click", (e) => {
    if (e.target === deleteConfirmBackdrop) {
      closeDeleteConfirmModal();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modalBackdrop?.classList.contains("is-open")) {
      closeModal();
    }

    if (
      e.key === "Escape" &&
      stockSplitModalBackdrop?.classList.contains("is-open")
    ) {
      closeStockSplitModal();
      openModal();
    }

    if (
      e.key === "Escape" &&
      deleteConfirmBackdrop?.classList.contains("is-open")
    ) {
      closeDeleteConfirmModal();
    }
  });

  productForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (
      !(productId instanceof HTMLInputElement) ||
      !(productNombre instanceof HTMLInputElement) ||
      !(productSlug instanceof HTMLInputElement) ||
      !(productDescripcion instanceof HTMLTextAreaElement) ||
      !(productPrecioBase instanceof HTMLInputElement) ||
      !(productPrecioOriginal instanceof HTMLInputElement) ||
      !(productTallaje instanceof HTMLSelectElement) ||
      !(productTipo instanceof HTMLInputElement) ||
      !(productBadge instanceof HTMLSelectElement) ||
      !(productEstado instanceof HTMLSelectElement) ||
      !(productStockInicial instanceof HTMLInputElement)
    ) {
      return;
    }

    try {
      const isEditing = Boolean(productId.value);
      const hasSelectedImages = selectedImageFiles.some(
        (file) => file instanceof File,
      );

      // Los input[type=number] pueden entregar "22" aunque el usuario escriba 22.00.
      // Normalizamos antes de validar para evitar falsos errores de formato.
      formatMoneyInput(productPrecioBase, false);
      formatMoneyInput(productPrecioOriginal, true);

      validateRequiredProductFields({
        isEditing,
        nombre: productNombre.value.trim(),
        slug: productSlug.value.trim(),
        descripcion: productDescripcion.value.trim(),
        precioOfertaRaw: productPrecioBase.value,
        precioOriginalRaw: productPrecioOriginal.value,
        tallaje: productTallaje.value,
        tipo: productTipo.value.trim(),
        badge: productBadge.value,
        estado: productEstado.value,
        stockRaw: productStockInicial.value,
        hasImageSelected: hasSelectedImages,
      });

      const stockValue = Math.max(0, Number(productStockInicial.value || 0));
      const resolvedTallaje = resolveTallajeFromForm(
        productTipo.value,
        productTallaje.value,
      );
      const unicaAutoVariants =
        resolvedTallaje === "unica" && stockValue > 0
          ? [{ talla: "Única", stock: stockValue }]
          : [];
      const pricing = validateAndNormalizePricing(
        productPrecioBase.value,
        productPrecioOriginal.value,
        productBadge.value,
      );

      productPrecioBase.value = pricing.precioOferta.toFixed(2);
      if (pricing.precioOriginal) {
        productPrecioOriginal.value = Number(
          pricing.precioOriginal.replace(",", "."),
        ).toFixed(2);
      }

      const basePayload: PendingCreatePayload = {
        nombre: productNombre.value.trim(),
        slug: productSlug.value.trim(),
        descripcion: productDescripcion.value.trim(),
        precio_base: pricing.precioOferta,
        precio_original: pricing.precioOriginal,
        tallaje: resolvedTallaje,
        tipo: productTipo.value.trim(),
        badge: pricing.badge,
        estado: productEstado.value,
        stock_inicial: stockValue,
      };

      if (hasSelectedImages) {
        basePayload.imagenes = await buildProductImagesPayload(selectedImageFiles);
      }

      if (productId.value) {
        if (unicaAutoVariants.length > 0) {
          await updateAdminProducto({
            id: Number(productId.value),
            ...basePayload,
            variantes: unicaAutoVariants,
          });

          closeModal();
          window.location.reload();
          return;
        }

        if (stockValue > 0) {
          prepareStockSplitModal({
            id: Number(productId.value),
            ...basePayload,
          });
          closeModal();
          openStockSplitModal();
          return;
        }

        await updateAdminProducto({
          id: Number(productId.value),
          ...basePayload,
          variantes: [],
        });

        closeModal();
        window.location.reload();
        return;
      }

      if (unicaAutoVariants.length > 0) {
        await createAdminProducto({
          ...basePayload,
          variantes: unicaAutoVariants,
        });
        closeModal();
        window.location.reload();
        return;
      }

      if (stockValue <= 0) {
        await createAdminProducto({
          ...basePayload,
          variantes: [],
        });
        closeModal();
        window.location.reload();
        return;
      }

      prepareStockSplitModal(basePayload);
      closeModal();
      openStockSplitModal();
    } catch (error) {
      const message =
        error instanceof Error ? error.message : "Error al preparar producto";
      showToastMessage(message, "error");
      setProductFormFeedback(message, "error");
    }
  });

  stockSplitForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!pendingCreatePayload) {
      return;
    }

    try {
      const totalStock = Math.max(
        0,
        Number(pendingCreatePayload.stock_inicial || 0),
      );
      const variantes = collectVariantsFromSplit(totalStock);

      if (pendingCreatePayload.id) {
        await updateAdminProducto({
          ...pendingCreatePayload,
          variantes,
        });
      } else {
        await createAdminProducto({
          ...pendingCreatePayload,
          variantes,
        });
      }

      closeStockSplitModal();
      window.location.reload();
    } catch (error) {
      showToastMessage(
        error instanceof Error ? error.message : "Error al guardar producto",
        "error",
      );
    }
  });

  applyProductSearchFilter();
</script>