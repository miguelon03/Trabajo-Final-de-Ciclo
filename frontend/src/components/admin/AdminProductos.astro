  const productImageSlotPreviews = Array.from(
    document.querySelectorAll<HTMLImageElement>(".image-slot-preview"),
  );
  const productImageSlotClearButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".image-slot-clear"),
  );
  const productImageUploadText = document.getElementById(
    "productImageUploadText",
  );
  const selectedProductsCount = document.getElementById(
    "selectedProductsCount",
  );
  const bulkBadgeSelect = document.getElementById("bulkBadgeSelect");
  const bulkBadgeBtn = document.getElementById("bulkBadgeBtn");
  const bulkBadgeMessage = document.getElementById("bulkBadgeMessage");
  const clearProductSelectionBtn = document.getElementById(
    "clearProductSelectionBtn",
  );
  const productSearchInput = document.getElementById("productSearchInput");
  const clearProductSearchBtn = document.getElementById("clearProductSearchBtn");
  const productsSearchEmpty = document.getElementById("productsSearchEmpty");
  const selectAllProducts = document.getElementById("selectAllProducts");
  const productRows = Array.from(
    document.querySelectorAll<HTMLTableRowElement>(".product-row"),
  );
  const productCheckboxes = Array.from(
    document.querySelectorAll<HTMLInputElement>(".product-select"),
  );
  const stockSplitModalBackdrop = document.getElementById(
    "stockSplitModalBackdrop",
