  .image-slot-clear:hover {
    border-color: rgba(255, 100, 100, 0.5);
    color: #ff8b8b;
  }

  .image-slots-help {
    display: block;
    margin-top: 10px;
    color: #8d8d8d;
    font-size: 0.8rem;
    line-height: 1.35;
  }

