  );
  const productTallaje = document.getElementById("productTallaje");
  const productTipo = document.getElementById("productTipo");
  const productIsAccesorio = document.getElementById("productIsAccesorio");
  const productBadge = document.getElementById("productBadge");
  const productEstado = document.getElementById("productEstado");
  const productStockInicial = document.getElementById("productStockInicial");
  const productStockLabel = document.getElementById("productStockLabel");
  const productImageField = document.getElementById("productImageField");
  const productImageSlots = Array.from(
