---
import {
  fetchAdminProductos,
  type AdminProducto,
} from "../../lib/admin-productos-api";

let productos: AdminProducto[] = [];
let error = "";

try {
  const cookieHeader = Astro.request.headers.get("cookie") ?? "";
  productos = await fetchAdminProductos(cookieHeader);
} catch (e) {
  error = e instanceof Error ? e.message : "Error al cargar productos";
}

function getInitials(name: string): string {
  return (
    name
      .split(" ")
      .filter(Boolean)
      .slice(0, 2)
      .map((part) => part.charAt(0).toUpperCase())
      .join("") || "DM"
  );
}
---

<section class="admin-section">
  <div class="title-row">
    <div>
      <h1>PRODUCTOS</h1>
    </div>
  </div>

  {
    error ? (
      <p class="error-message">{error}</p>
    ) : (
      <>
        <div class="search-row">
          <div class="bulk-search" role="search" aria-label="Buscar productos">
            <input
              id="productSearchInput"
              type="search"
              placeholder="Buscar por nombre, slug o tipo"
              autocomplete="off"
            />
            <button id="clearProductSearchBtn" type="button" aria-label="Limpiar búsqueda">
              ×
            </button>
          </div>
        </div>

        <div class="management-row">
          <div class="bulk-panel" aria-label="Acciones en bloque de productos">
            <label class="bulk-select-all">
              <input
                id="selectAllProducts"
                type="checkbox"
                aria-label="Seleccionar todos los productos"
              />
              <span>Seleccionar todo</span>
            </label>

            <span class="bulk-counter">
              <strong id="selectedProductsCount">0</strong>
              seleccionados
            </span>

            <select
              id="bulkBadgeSelect"
              aria-label="Badge para productos seleccionados"
            >
              <option value="">Sin badge</option>
              <option value="NEW">NEW</option>
              <option value="Oferta">oferta</option>
            </select>

            <button class="btn-bulk" id="bulkBadgeBtn" type="button" disabled>
              Aplicar badge
            </button>

            <button
              class="btn-clear-selection"
              id="clearProductSelectionBtn"
              type="button"
            >
              Limpiar
            </button>
          </div>

          <button class="new-btn" id="newProductBtn" type="button">
            + Nuevo producto
          </button>
        </div>

        <p class="bulk-message" id="bulkBadgeMessage"></p>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Producto</th>
                <th>Badge</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Estado</th>
                <th class="actions-heading">Acciones</th>
              </tr>
            </thead>

            <tbody>
              {productos.map((p) => (
                <tr
                  class="product-row"
                  data-product-id={p.id}
                  data-search={`${p.nombre} ${p.slug} ${p.tipo ?? ""} ${p.badge ?? ""}`
                    .toLowerCase()}
                  aria-selected="false"
                  title="Pulsa la fila para seleccionarla y cambiar su badge"
                >
                  <td class="product-cell" data-label="Producto">
                    <div class="product-inline">
                      <div class="product-thumb" aria-hidden={!p.imagen}>
                        {p.imagen ? (
                          <img
                            src={p.imagen}
                            alt={`Imagen de ${p.nombre}`}
                            loading="lazy"
                          />
                        ) : (
                          <span>{getInitials(p.nombre)}</span>
                        )}
                      </div>

                      <div class="product-copy">
                        <strong>{p.nombre}</strong>
                        <span class="muted">{p.slug}</span>
                      </div>
                    </div>
                  </td>

                  <td data-label="Badge">
                    {p.badge ? (
                      <span
                        class:list={[
                          "product-badge",
                          String(p.badge).toLowerCase() === "oferta" &&
                            "is-offer",
                        ]}
                      >
                        {String(p.badge).toLowerCase() === "oferta"
                          ? "oferta"
                          : p.badge}
                      </span>
                    ) : (
                      <span class="no-badge">Sin badge</span>
                    )}
                  </td>

                  <td data-label="Precio">
                    {Number(p.precio_base).toFixed(2)}€
                  </td>

                  <td
                    data-label="Stock"
                    class={
                      p.stock_total <= 0
                        ? "stock-out"
                        : p.stock_total <= 5
                          ? "stock-low"
                          : "stock-ok"
                    }
                  >
                    {p.stock_total} ud.
                  </td>

                  <td data-label="Estado">
                    <span
                      class:list={[
                        "status-badge",
                        p.estado === "publicado" && "published",
                        p.estado === "borrador" && "draft",
                        p.estado === "archivado" && "archived",
                        p.stock_total <= 0 &&
                          p.estado === "publicado" &&
                          "soldout",
                      ]}
                    >
                      {p.stock_total <= 0 && p.estado === "publicado"
                        ? "Agotado"
                        : p.estado.charAt(0).toUpperCase() + p.estado.slice(1)}
                    </span>
                  </td>

                  <td class="actions" data-label="Acciones">
                    <input
                      class="product-select"
                      type="checkbox"
                      value={p.id}
                      hidden
                      aria-hidden="true"
                      tabindex="-1"
                    />

                    <div class="actions-inner">
                      <button
                        class="btn-edit action-icon"
                        type="button"
                        data-id={p.id}
                        data-nombre={p.nombre}
                        data-slug={p.slug}
                        data-descripcion={p.descripcion ?? ""}
                        data-precio-base={p.precio_base}
                        data-precio-original={p.precio_original ?? ""}
                        data-tallaje={p.tallaje ?? "clasico"}
                        data-tipo={p.tipo ?? ""}
                        data-badge={p.badge ?? ""}
                        data-estado={p.estado}
                        aria-label={`Editar ${p.nombre}`}
                        title="Editar"
                      >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M4 17.3V20h2.7L17.8 8.9l-2.7-2.7L4 17.3Zm15.9-10.5a1 1 0 0 0 0-1.4l-1.3-1.3a1 1 0 0 0-1.4 0l-1 1 2.7 2.7 1-1Z" />
                        </svg>
                      </button>

                      <button
                        class="btn-delete action-icon"
                        type="button"
                        data-id={p.id}
                        aria-label={`Eliminar ${p.nombre}`}
                        title="Eliminar"
                      >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M8 4h8l1 2h4v2H3V6h4l1-2Zm1 6h2v8H9v-8Zm4 0h2v8h-2v-8Zm4 0h2v8h-2v-8ZM6 9h12l-1 11H7L6 9Z" />
                        </svg>
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="footer-row">Mostrando {productos.length} productos</div>
        <p id="productsSearchEmpty" class="search-empty" hidden>
          No hay productos que coincidan con tu búsqueda.
        </p>
      </>
    )
  }
</section>

<div class="modal-backdrop" id="productModalBackdrop">
  <div
    class="modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="productModalTitle"
  >
    <div class="modal-header">
      <div>
        <p class="modal-kicker">Producto</p>
        <h2 id="productModalTitle">Nuevo producto</h2>
      </div>

      <button
        class="modal-close"
        id="closeProductModal"
        type="button"
        aria-label="Cerrar modal"
      >
        ×
      </button>
    </div>

    <form id="productForm" class="modal-form" novalidate>
      <input type="hidden" id="productId" />

      <div class="form-grid">
        <div class="field field-full">
          <label for="productNombre">Nombre</label>
          <input id="productNombre" type="text" required />
        </div>

        <div class="field">
          <label for="productSlug">Slug</label>
          <input id="productSlug" type="text" readonly />
          <small class="field-help">Se genera automáticamente a partir del nombre.</small>
        </div>

        <div class="field">
          <label for="productEstado">Estado</label>
          <select id="productEstado">
            <option value="borrador">Borrador</option>
            <option value="publicado">Publicado</option>
            <option value="archivado">Archivado</option>
          </select>
        </div>

        <div class="field">
          <label for="productPrecioOriginal">Precio original</label>
          <input
            id="productPrecioOriginal"
            type="text"
            inputmode="decimal"
            autocomplete="off"
            placeholder="Ej: 50,00"
          />
        </div>

        <div class="field">
          <label for="productPrecioBase">Precio oferta</label>
          <input
            id="productPrecioBase"
            type="text"
            inputmode="decimal"
            autocomplete="off"
            placeholder="Ej: 9,99"
            required
          />
        </div>

        <div class="field">
          <label for="productTallaje">Tallaje</label>
          <select id="productTallaje">
            <option value="clasico">Clásico (XS, S, M, L, XL)</option>
            <option value="pantalon">Pantalón (28, 36, 40, 42, 44)</option>
            <option value="unica">Talla única</option>
          </select>
        </div>

        <div class="field">
          <label for="productTipo">Tipo</label>
          <input id="productTipo" type="text" placeholder="Ej: camiseta" />
        </div>

        <div class="field field--accent field--toggle">
          <label class="checkbox-toggle" for="productIsAccesorio">
            <input id="productIsAccesorio" type="checkbox" />
            <span>Marcar como accesorio</span>
          </label>
          <small class="field-hint">Si está activo, el producto aparecerá en Accesorios.</small>
        </div>

        <div class="field field--accent">
          <label for="productBadge">Badge</label>
          <select id="productBadge">
            <option value="">Sin badge</option>
            <option value="NEW" selected>NEW</option>
            <option value="Oferta">oferta</option>
          </select>
        </div>

        <div class="field field--accent">
          <label id="productStockLabel" for="productStockInicial">Stock</label>
          <input
            id="productStockInicial"
            type="number"
            min="0"
            step="1"
            placeholder="Introduce stock (puede ser 0)"
            required
          />
        </div>

        <div class="field field-full" id="productImageField">
          <label for="productImageSlot1">Imágenes del producto</label>
          <div class="image-slots" id="productImageSlots">
            <div class="image-slot" data-slot="0">
              <input
                id="productImageSlot1"
                class="image-slot-input"
                type="file"
                accept="image/jpeg,image/png,image/webp"
              />
              <img class="image-slot-preview" alt="" hidden />
              <div class="image-slot-placeholder">
                <strong>Imagen 1</strong>
                <span>Arrastra o elige archivo</span>
              </div>
              <button class="image-slot-clear" type="button" hidden aria-label="Quitar imagen 1">
                ×
              </button>
            </div>

            <div class="image-slot" data-slot="1">
              <input
                id="productImageSlot2"
                class="image-slot-input"
                type="file"
                accept="image/jpeg,image/png,image/webp"
              />
              <img class="image-slot-preview" alt="" hidden />
              <div class="image-slot-placeholder">
                <strong>Imagen 2</strong>
                <span>Arrastra o elige archivo</span>
              </div>
              <button class="image-slot-clear" type="button" hidden aria-label="Quitar imagen 2">
                ×
              </button>
            </div>

            <div class="image-slot" data-slot="2">
              <input
                id="productImageSlot3"
                class="image-slot-input"
                type="file"
                accept="image/jpeg,image/png,image/webp"
              />
              <img class="image-slot-preview" alt="" hidden />
              <div class="image-slot-placeholder">
                <strong>Imagen 3</strong>
                <span>Arrastra o elige archivo</span>
              </div>
              <button class="image-slot-clear" type="button" hidden aria-label="Quitar imagen 3">
                ×
              </button>
            </div>
          </div>
          <span id="productImageUploadText" class="image-slots-help">
            Vista previa en formato catálogo. Máximo 3 imágenes (JPG, PNG o WEBP, 4MB cada una).
          </span>
        </div>

        <div class="field field-full">
          <label for="productDescripcion">Descripción</label>
          <textarea id="productDescripcion" rows="5"></textarea>
        </div>
      </div>

      <div class="modal-actions">
        <button type="button" class="btn-secondary" id="cancelProductModal">
          Cancelar
        </button>

        <button type="submit" class="btn-primary" id="saveProductBtn">
          Guardar
        </button>
      </div>

      <p id="productFormFeedback" class="modal-feedback" aria-live="polite"></p>
    </form>
  </div>
</div>

<div class="modal-backdrop" id="stockSplitModalBackdrop">
  <div
    class="modal modal--compact"
    role="dialog"
    aria-modal="true"
    aria-labelledby="stockSplitModalTitle"
  >
    <div class="modal-header">
      <h2 id="stockSplitModalTitle">Repartir stock por tallas</h2>
      <button
        class="modal-close"
        id="closeStockSplitModal"
        type="button"
        aria-label="Cerrar reparto de stock"
      >
        ×
      </button>
    </div>

    <form id="stockSplitForm" class="modal-form">
      <div class="stock-split__summary">
        <div class="stock-split__summary-head">
          <span class="stock-split__eyebrow">Producto</span>
          <strong id="stockSplitProductName">Producto</strong>
        </div>

        <div class="stock-split__stats">
          <div class="stock-split__stat">
            <span>Total</span>
            <strong id="stockSplitTotal">0</strong>
          </div>

          <div class="stock-split__stat">
            <span>Repartido</span>
            <strong id="stockSplitAssigned">0</strong>
          </div>

          <div class="stock-split__stat">
            <span>Objetivo</span>
            <strong id="stockSplitExpected">0</strong>
          </div>
        </div>
      </div>

      <div id="stockSplitGrid" class="stock-split__grid"></div>
      <p id="stockSplitWarning" class="stock-split__warning" hidden></p>

      <div class="modal-actions">
        <button type="button" class="btn-secondary" id="backToProductModalBtn">
          Volver
        </button>
        <button type="submit" class="btn-primary">Guardar producto</button>
      </div>
    </form>
  </div>
</div>

<div class="modal-backdrop" id="deleteConfirmBackdrop">
  <div
    class="modal modal--confirm"
    role="dialog"
    aria-modal="true"
    aria-labelledby="deleteConfirmTitle"
    aria-describedby="deleteConfirmText"
  >
    <div class="modal-header">
      <h2 id="deleteConfirmTitle">Eliminar producto</h2>
      <button
        class="modal-close"
        id="closeDeleteConfirmModal"
        type="button"
        aria-label="Cerrar confirmación"
      >
        ×
      </button>
    </div>

    <div class="modal-form modal-form--confirm">
      <p id="deleteConfirmText" class="confirm-text">
        ¿Seguro que quieres eliminar este producto?
      </p>

      <div class="modal-actions">
        <button type="button" class="btn-secondary" id="cancelDeleteConfirmBtn">
          Cancelar
        </button>
        <button type="button" class="btn-danger" id="confirmDeleteBtn">
          Eliminar
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .admin-section {
    width: 100%;
    min-width: 0;
  }

  .modal-kicker {
    color: #d7ff00;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .admin-section h1 {
    font-size: clamp(2.15rem, 5vw, 3.7rem);
    font-weight: 950;
    letter-spacing: 0.07em;
    color: #f4f4f4;
    line-height: 0.95;
    margin: 0;
  }

  .title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .management-row {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
  }

  .search-row {
    width: 100%;
    display: flex;
    justify-content: flex-start;
    margin-bottom: 10px;
  }

  .bulk-panel {
    flex: 1 1 auto;
    max-width: 900px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    flex-wrap: wrap;
    background: #101010;
    border: 1px solid #272727;
    border-radius: 18px;
    padding: 10px;
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.22);
  }

  .new-btn {
    flex: 0 0 auto;
    min-height: 48px;
    background: #d7ff00;
    color: #111;
    border: none;
    border-radius: 14px;
    padding: 0 24px;
    font-weight: 950;
    cursor: pointer;
    box-shadow: 0 14px 28px rgba(215, 255, 0, 0.12);
    white-space: nowrap;
  }

  .new-btn:hover,
  .btn-bulk:hover,
  .btn-edit:hover,
  .btn-primary:hover {
    filter: brightness(1.04);
  }

  .bulk-select-all,
  .bulk-counter {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #dcdcdc;
    font-size: 0.86rem;
    font-weight: 850;
    white-space: nowrap;
  }

  .bulk-select-all {
    min-height: 38px;
    background: #171717;
    border: 1px solid #2b2b2b;
    border-radius: 12px;
    padding: 0 12px;
    cursor: pointer;
  }

  .bulk-select-all input {
    width: 18px;
    height: 18px;
    accent-color: #d7ff00;
    cursor: pointer;
  }

  .bulk-counter {
    color: #8a8a8a;
    padding: 0 4px;
  }

  .bulk-counter strong {
    color: #d7ff00;
  }

  .bulk-panel select {
    min-height: 38px;
    background: #171717;
    border: 1px solid #2b2b2b;
    border-radius: 12px;
    color: #f4f4f4;
    padding: 0 34px 0 12px;
    font-weight: 850;
    outline: none;
  }

  .btn-bulk,
  .btn-clear-selection {
    min-height: 38px;
    border-radius: 12px;
    padding: 0 14px;
    font-weight: 950;
    cursor: pointer;
  }

  .btn-bulk {
    background: #d7ff00;
    color: #111;
    border: none;
  }

  .btn-bulk:disabled {
    cursor: not-allowed;
    opacity: 0.45;
    filter: grayscale(0.35);
  }

  .btn-clear-selection {
    background: transparent;
    color: #aaa;
    border: 1px solid #303030;
  }

  .bulk-search {
    min-height: 38px;
    display: inline-flex;
    align-items: center;
    width: min(100%, 340px);
    border: 1px solid #2b2b2b;
    border-radius: 12px;
    overflow: hidden;
    background: #171717;
  }

  .bulk-search input {
    flex: 1 1 auto;
    min-width: 0;
    min-height: 38px;
    border: none;
    outline: none;
    background: transparent;
    color: #f4f4f4;
    padding: 0 12px;
    font-weight: 800;
  }

  .bulk-search input::placeholder {
    color: #707070;
  }

  .bulk-search button {
    width: 38px;
    min-height: 38px;
    border: none;
    border-left: 1px solid #2b2b2b;
    background: #1b1b1b;
    color: #9a9a9a;
    font-size: 1.1rem;
    cursor: pointer;
  }

  .bulk-search button:hover {
    color: #fff;
    background: #212121;
  }

  .btn-clear-selection:hover {
    color: #f0f0f0;
    border-color: #444;
  }

  .bulk-message {
    min-height: 20px;
    margin: 0 0 12px;
    color: #ff6b6b;
    font-size: 0.9rem;
  }

  .table-wrap {
    width: 100%;
    background: #0f0f0f;
    border: 1px solid #232323;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: none;
  }

  table {
    width: 100%;
    min-width: 0;
    border-collapse: separate;
    border-spacing: 0;
    table-layout: fixed;
  }

  thead {
    background: #101010;
  }

  th,
  td {
    padding: 16px 14px;
    text-align: left;
    border-bottom: 1px solid #191919;
    font-size: 0.9rem;
    vertical-align: middle;
  }

  th {
    color: #777;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  td {
    color: #eaeaea;
  }

  tbody tr {
    background: #111;
    transition:
      background 0.16s ease,
      box-shadow 0.16s ease;
  }

  tbody tr:nth-child(even) {
    background: #0f0f0f;
  }

  tbody tr.product-row {
    cursor: pointer;
  }

  tbody tr.product-row:hover {
    background: #151515;
  }

  tbody tr.product-row.is-selected {
    background: rgba(215, 255, 0, 0.055);
    box-shadow: inset 4px 0 0 #d7ff00;
  }

  tbody tr.product-row.is-selected .product-thumb {
    border-color: rgba(215, 255, 0, 0.65);
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  .product-cell {
    width: 42%;
    min-width: 0;
  }

  th:nth-child(2),
  td:nth-child(2) {
    width: 115px;
  }

  th:nth-child(3),
  td:nth-child(3) {
    width: 95px;
  }

  th:nth-child(4),
  td:nth-child(4) {
    width: 95px;
  }

  th:nth-child(5),
  td:nth-child(5) {
    width: 125px;
  }

  .actions-heading,
  .actions {
    width: 112px;
    text-align: right;
  }

  .product-inline {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .product-thumb {
    width: 58px;
    height: 58px;
    flex: 0 0 58px;
    border-radius: 14px;
    overflow: hidden;
    background: linear-gradient(145deg, #242424, #101010);
    border: 1px solid #2b2b2b;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #d7ff00;
    font-size: 0.86rem;
    font-weight: 950;
    letter-spacing: 0.08em;
  }

  .product-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-copy {
    min-width: 0;
  }

  .product-copy strong {
    display: block;
    color: #f4f4f4;
    font-size: 0.95rem;
    line-height: 1.25;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
