---
import HomeLayout from "../../layouts/HomeLayout.astro";
import {
  fetchCatalogData,
  type CatalogProduct as Product,
  type CatalogStockEntry as StockEntry,
  type CatalogReviewEntry as ReviewEntry,
  type CatalogReviewItem as ReviewItem,
} from "../../lib/catalog-api";

export async function getStaticPaths() {
  const { products } = await fetchCatalogData();
  return (products as Product[]).map((product: Product) => ({
    params: { slug: product.slug },
    props: { slug: product.slug },
  }));
}

const { products, stock, reviews } = await fetchCatalogData();
const allProducts = products as Product[];
const allStock = stock as StockEntry[];
const allReviews = reviews as ReviewEntry[];

const { slug } = Astro.props;
const sourceLinks: Record<string, { href: string; label: string }> = {
  catalogo: { href: "/catalogo", label: "Catálogo" },
  novedades: { href: "/novedades", label: "Novedades" },
  accesorios: { href: "/accesorios", label: "Accesorios" },
  ofertas: { href: "/ofertas", label: "Ofertas" },
};
const sourceLink = sourceLinks.catalogo;
const product = allProducts.find((item: Product) => item.slug === slug);

if (!product) {
  throw new Error("Producto no encontrado");
}

const productStock = allStock.find(
  (item: StockEntry) => item.productSlug === product.slug,
);
const gallery = product.images?.length ? product.images : [product.image];
// Opiniones dinámicas
let reviewsList = [];
let averageRating = 0;
let reviewCount = 0;
const typeLabel = product.type.charAt(0).toUpperCase() + product.type.slice(1);
const isAccessory = product.type === "accesorio";

const rawSizes = Object.keys(productStock?.bySize ?? {});
const SIZE_ORDER = ["XS", "S", "M", "L", "XL"];

function normalizeSize(size: string): string {
  return String(size || "").replace(/\s+/g, "").toUpperCase();
}

function compareSizes(a: string, b: string): number {
  const indexA = SIZE_ORDER.indexOf(normalizeSize(a));
  const indexB = SIZE_ORDER.indexOf(normalizeSize(b));

  if (indexA !== -1 && indexB !== -1) {
    return indexA - indexB;
  }

  if (indexA !== -1) {
    return -1;
  }

  if (indexB !== -1) {
    return 1;
  }

  return a.localeCompare(b, "es", { sensitivity: "base" });
}

const sizesArray: string[] = (Array.isArray(rawSizes)
  ? rawSizes
  : [rawSizes as unknown as string]
).sort(compareSizes);
const sizeOptions = sizesArray.map((size: string) => {
  const sizeStock = productStock?.bySize?.[size]?.stock ?? 0;
  return {
    size,
    stock: sizeStock,
    available: sizeStock > 0,
    sku: productStock?.bySize?.[size]?.sku ?? `DMH-${product.id}-${size}`,
  };
});

const relatedProducts = allProducts
  .filter(
    (item: Product) => item.id !== product.id && item.type === product.type,
  )
  .slice(0, 4);
---

<HomeLayout title={`DMH - ${product.title}`} description={product.description}>
  <section class="product-detail">
    <div class="product-detail__container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <a id="sourceBreadcrumbLink" href={sourceLink.href}
          >{sourceLink.label}</a
        >
        <span>/</span>
        <span>{product.title}</span>
      </nav>

      <div class="product-detail__grid">
        <div class="gallery">
          <div class="gallery__carousel">
            <button
              class="carousel__btn carousel__btn--prev"
              id="carouselPrev"
              aria-label="Imagen anterior">&#8592;</button
            >
            <div class="gallery__slides" id="gallerySlides">
              {
                gallery.map((img, i) => (
                  <div
                    class={`gallery__slide${i === 0 ? " is-active" : ""}`}
                    data-index={String(i)}
                  >
                    {img.startsWith("/") || img.startsWith("http") ? (
                      <img
                        src={img}
                        alt={`${product.title} - imagen ${i + 1}`}
                        class="gallery__img"
                      />
                    ) : (
                      <span class="gallery__placeholder-label">
                        {img.replace("-", " ")}
                      </span>
                    )}
                  </div>
                ))
              }
            </div>
            <button
              class="carousel__btn carousel__btn--next"
              id="carouselNext"
              aria-label="Imagen siguiente">&#8594;</button
            >
          </div>
          {
            gallery.length > 1 && (
              <div class="carousel__dots" id="carouselDots">
                {gallery.map((_image, index) => (
                  <button
                    type="button"
                    class={`carousel__dot ${index === 0 ? "is-active" : ""}`}
                    data-index={String(index)}
                    aria-label={`Ir a imagen ${index + 1}`}
                  />
                ))}
              </div>
            )
          }
        </div>

        <div
          class="product-info"
          id="productInfo"
          data-product-id={product.id}
          data-product-slug={product.slug}
          data-product-title={product.title}
          data-product-price={product.price}
          data-product-image={gallery[0]}
          data-product-type={product.type}
          data-product-total-stock={productStock?.totalStock ?? 0}
        >
          <p class="product-info__type">{product.category} · {typeLabel}</p>
          <h1>{product.title}</h1>
          <div class="product-info__rating">
            <span id="productRatingStars"
              >{"★".repeat(Math.floor(averageRating))}{
                "☆".repeat(5 - Math.floor(averageRating))
              }</span
            >
            <strong id="productRatingValue">{averageRating.toFixed(1)}</strong>
            <span id="productRatingCount">({reviewCount} reseñas)</span>
          </div>

          <div class="product-info__price">
            {
              product.originalPrice && (
                <span class="old-price">
                  {product.originalPrice.toFixed(2)}€
                </span>
              )
            }
            <span class="current-price">{product.price.toFixed(2)}€</span>
          </div>

          <p class="product-info__description">{product.description}</p>

          <div class="product-info__meta">
            <div>
              <span class="meta-label">Stock total</span>
              <span class="meta-value"
                >{productStock?.totalStock ?? 0} uds.</span
              >
            </div>
          </div>

          {
            !isAccessory && (
              <div class="size-selector" id="sizeSelector">
                <p class="section-label">Talla</p>
                <div class="size-selector__grid">
                  {sizeOptions.map((option, index) => (
                    <label
                      class={`size-pill ${!option.available ? "is-disabled" : ""}`}
                    >
                      <input
                        type="radio"
                        name="size"
                        value={option.size}
                        data-stock={option.stock}
                        data-sku={option.sku}
                        disabled={!option.available}
                        checked={index === 0 && option.available}
                      />
                      <span>{option.size}</span>
                    </label>
                  ))}
                </div>
                <p class="size-selector__hint" id="sizeHint">
                  Selecciona una talla disponible
                </p>
              </div>
            )
          }

          <div class="buy-box">
            <label class="quantity">
              <span>Cantidad</span>
              <input
                id="quantityInput"
                type="number"
                min="1"
                max="10"
                value="1"
              />
            </label>
            <button class="btn-primary" type="button" id="addToCartBtn"
              >Añadir al carrito</button
            >
          </div>

          <button
            class="btn-secondary"
            type="button"
            id="toggleWishlistBtn"
            data-product-slug={product.slug}
          >
            ♡ Añadir a wishlist
          </button>

          <ul class="selling-points">
            <li>Envío en 24-48h laborables</li>
            <li>Cambios y devoluciones en 30 días</li>
            <li>Pago 100% seguro</li>
          </ul>
        </div>
      </div>

      <section class="reviews-feed">
        <div class="section-head">
          <h2>Opiniones y valoraciones</h2>
          <p id="reviewCount">Cargando opiniones...</p>
        </div>
        <div class="reviews__list" id="reviewsList">
          <div class="reviews-loading">Cargando opiniones...</div>
        </div>
      </section>

      <section class="reviews-panel">
        <div class="section-head">
          <h2>Escribe tu opinión</h2>
          <p>Comparte cómo talla, cómo cae y qué te ha parecido el acabado.</p>
        </div>
        <div id="reviewFormContainer"></div>
      </section>

      <section class="related">
        <div class="section-head">
          <h2>También te puede gustar</h2>
        </div>
        <div class="related__grid">
          {
            relatedProducts.map((item: Product) => (
              <article
                class="related-card"
                data-slug={item.slug}
                tabindex="0"
                role="link"
                aria-label={`Ver ${item.title}`}
              >
                <div class="related-card__image">
                  {item.image.startsWith("/") ||
                  item.image.startsWith("http") ? (
                    <img src={item.image} alt={item.title} loading="lazy" />
                  ) : (
                    <span class="related-card__image-placeholder">
                      {item.image}
                    </span>
                  )}
                </div>
                <h3>{item.title}</h3>
                <p>{item.price.toFixed(2)}€</p>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </section>

  <script>
    // @ts-nocheck
    // --- Opiniones dinámicas ---
    const productId = Number(
      document.getElementById("productInfo")?.dataset.productId,
    );
    const reviewsListDiv = document.getElementById("reviewsList");
    const reviewCountP = document.getElementById("reviewCount");
    const reviewFormContainer = document.getElementById("reviewFormContainer");
    const productRatingStars = document.getElementById("productRatingStars");
    const productRatingValue = document.getElementById("productRatingValue");
    const productRatingCount = document.getElementById("productRatingCount");
    let currentUser = null;
    let currentUserOpinion = null;

    async function ensureCurrentUser() {
      if (currentUser) {
        return currentUser;
      }

      try {
        const result = await requestApi("perfil.php", {
          credentials: "include",
        });
        if (result.ok && result.data?.usuario?.rol === "cliente") {
          currentUser = result.data.usuario;
        }
      } catch {}

      return currentUser;
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function renderStars(rating) {
      const safeRating = Math.max(0, Math.min(5, Number(rating) || 0));
      const fullStars = Math.round(safeRating);
      return `${"★".repeat(fullStars)}${"☆".repeat(5 - fullStars)}`;
    }

    function updateProductRating(opiniones) {
      const total = Array.isArray(opiniones) ? opiniones.length : 0;
      const average = total
        ? opiniones.reduce(
            (sum, opinion) => sum + Number(opinion.puntuacion || 0),
            0,
          ) / total
        : 0;

      if (productRatingStars) {
        productRatingStars.textContent = renderStars(average);
      }
      if (productRatingValue) {
        productRatingValue.textContent = average.toFixed(1);
      }
      if (productRatingCount) {
        productRatingCount.textContent = `(${total} reseñas)`;
      }
      if (reviewCountP) {
        reviewCountP.textContent = total
          ? `${total} cliente${total === 1 ? "" : "s"} ya han opinado`
          : "Todavía no hay opiniones";
      }
    }

    async function requestApi(endpoint, options) {
      if (typeof window.dmhFetchJson === "function") {
        return window.dmhFetchJson(endpoint, options || {});
      }

      const fallbackBase =
        typeof window.dmhApiUrl === "function"
          ? window.dmhApiUrl(endpoint)
          : `/backend/api/${endpoint}`;
      const response = await fetch(fallbackBase, options || {});
      let data = null;
      try {
        data = await response.json();
      } catch (_error) {
        data = null;
      }
      return {
        ok: response.ok,
        status: response.status,
        data,
        error:
          data?.error ||
          (!response.ok ? `Error HTTP ${response.status}` : null),
      };
    }

    async function fetchOpiniones() {
      if (!productId || !reviewsListDiv) return;

      try {
        await ensureCurrentUser();

        const result = await requestApi(
          `opiniones.php?producto_id=${productId}`,
          {
            credentials: "include",
          },
        );

        if (!result.ok) {
          throw new Error(result.error || "Error cargando opiniones");
        }

        const opiniones = result.data?.opiniones || [];
        const opinionesAprobadas = opiniones.filter(
          (op) => String(op?.estado || "aprobada").toLowerCase() === "aprobada",
        );

        updateProductRating(opinionesAprobadas);

        const currentUserId = Number(currentUser?.id || 0);
        currentUserOpinion =
          opiniones.find(
            (op) => Number(op.usuario_id || 0) === currentUserId,
          ) || null;

        const opinionesOrdenadas =
          currentUserId > 0
            ? [
                ...opiniones.filter(
                  (op) => Number(op.usuario_id || 0) === currentUserId,
                ),
                ...opiniones.filter(
                  (op) => Number(op.usuario_id || 0) !== currentUserId,
                ),
              ]
            : opiniones;

        renderReviewForm();

        let html = "";

        opinionesOrdenadas.forEach((op) => {
          const isOwnOpinion =
            currentUserId > 0 && Number(op.usuario_id || 0) === currentUserId;
          const estadoOpinion = String(op.estado || "aprobada").toLowerCase();

          if (!isOwnOpinion && estadoOpinion !== "aprobada") {
            return;
          }

          const ownInlineStyle = isOwnOpinion
            ? " style='border: 2px solid #C8FF00; border-radius: 1rem; padding: 1.2rem 1.25rem; box-shadow: 0 0 0 1px rgba(200, 255, 0, 0.35), 0 0 20px rgba(200, 255, 0, 0.2);'"
            : "";

          const ownStatusBadge =
            isOwnOpinion && estadoOpinion !== "aprobada"
              ? `<span class='review-card__badge review-card__badge--status'>${estadoOpinion === "pendiente" ? "Pendiente de revisión" : "No publicada"}</span>`
              : "";

          html += `<article class='review-card${isOwnOpinion ? " review-card--own" : ""}'${ownInlineStyle}>
        ${isOwnOpinion ? "<span class='review-card__badge'>Tu opinión</span>" : ""}
        ${ownStatusBadge}
        <header>
          <h3>${escapeHtml(op.nombre)}</h3>
          <span class='review-card__stars' aria-label='${Number(op.puntuacion || 0)} de 5 estrellas'>${renderStars(op.puntuacion)}</span>
        </header>
        <p>${escapeHtml(op.comentario)}</p>
        <footer><span>${escapeHtml(String(op.creado_en || "").split(" ")[0])}</span></footer>
      </article>`;
        });

        reviewsListDiv.innerHTML =
          html ||
          "<article class='review-empty'><p>Aún no hay opiniones para este producto. Sé la primera persona en valorar cómo cae y cómo se siente.</p></article>";
      } catch (_e) {
        reviewsListDiv.innerHTML = `<article class='review-empty review-empty--error'><p>No se pudieron cargar las opiniones.</p></article>`;
        if (reviewCountP) {
          reviewCountP.textContent = "Opiniones no disponibles";
        }
      }
    }
    // --- Formulario solo para miembros ---
    async function renderReviewForm() {
      await ensureCurrentUser();

      if (!currentUser || !reviewFormContainer) {
        reviewFormContainer.innerHTML = "";
        return;
      }

      if (currentUserOpinion) {
        const estadoActual = String(
          currentUserOpinion.estado || "aprobada",
        ).toLowerCase();
        const tituloEstado =
          estadoActual === "pendiente"
            ? "Tu opinión está pendiente"
            : estadoActual === "rechazada"
              ? "Tu opinión no fue aprobada"
              : "Ya has dado tu opinión";

        const textoEstado =
          estadoActual === "pendiente"
            ? "Tu opinión se ha guardado correctamente y quedará visible cuando el equipo la apruebe."
            : estadoActual === "rechazada"
              ? "Tu opinión no está visible públicamente. Si quieres, puedes borrarla y enviar una nueva."
              : "Por ayudarnos con tu valoración. Si quieres escribir otra opinión, primero debemos borrar la anterior.";

        const pieEstado =
          estadoActual === "aprobada"
            ? "Tu opinión actual seguirá visible hasta que la borres."
            : "Tu opinión actual no es pública mientras no esté aprobada.";

        reviewFormContainer.innerHTML = `
    <div class='review-form review-form--done'>
      <div class='review-form__header'>
        <div>
          <p class='review-form__eyebrow'>Solo para miembros</p>
          <h3>${tituloEstado}</h3>
        </div>
      </div>
      <p class='review-form__done-text'>${textoEstado}</p>
      <div class='review-form__footer'>
        <p>${pieEstado}</p>
        <button type='button' class='btn-primary review-form__submit' id='rewriteReviewBtn'>Volver a opinar</button>
      </div>
    </div>
  `;

        const rewriteBtn = document.getElementById("rewriteReviewBtn");
        if (rewriteBtn instanceof HTMLButtonElement) {
          rewriteBtn.addEventListener("click", () => {
            if (!currentUserOpinion) return;
            window.showConfirmToast?.(
              "Vas a borrar tu opinión para poder escribir otra. Esta acción no se puede deshacer.",
              async () => {
                try {
                  const result = await requestApi("opiniones.php", {
                    method: "DELETE",
                    credentials: "include",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ opinion_id: currentUserOpinion.id }),
                  });

                  if (!result.ok) {
                    throw new Error(
                      result.error || "No se pudo borrar la opinión",
                    );
                  }

                  window.showToast?.(
                    "Opinión borrada. Ya puedes escribir una nueva.",
                    "success",
                  );
                  currentUserOpinion = null;
                  await fetchOpiniones();
                  renderReviewForm();
                } catch (error) {
                  window.showToast?.(
                    error instanceof Error
                      ? error.message
                      : "No se pudo borrar la opinión",
                    "error",
                  );
                }
              },
              { confirmText: "Borrar opinión", cancelText: "Cancelar" },
            );
          });
        }

        return;
      }

      reviewFormContainer.innerHTML = `
        <form id='reviewForm' class='review-form'>
          <div class='review-form__header'>
            <div>
              <p class='review-form__eyebrow'>Solo para miembros</p>
              <h3>Deja tu opinión</h3>
            </div>
          </div>
          <div class='review-form__rating'>
            <span class='review-form__label'>Tu puntuación</span>
            <div class='rating-input' id='ratingInput' role='group' aria-label='Selecciona una puntuación'>
              <input type='hidden' name='puntuacion' id='reviewRatingValue' value='0' required>
              <button type='button' class='rating-input__star' data-rating='1' aria-label='1 estrella'>☆</button>
              <button type='button' class='rating-input__star' data-rating='2' aria-label='2 estrellas'>☆</button>
              <button type='button' class='rating-input__star' data-rating='3' aria-label='3 estrellas'>☆</button>
              <button type='button' class='rating-input__star' data-rating='4' aria-label='4 estrellas'>☆</button>
              <button type='button' class='rating-input__star' data-rating='5' aria-label='5 estrellas'>☆</button>
            </div>
            <p class='review-form__rating-hint'>Haz clic directamente sobre la estrella que quieras marcar.</p>
          </div>
          <div class='review-form__field'>
            <span class='review-form__label'>Comentario</span>
            <textarea name='comentario' maxlength='300' required placeholder='¿Qué te ha parecido el producto?'></textarea>
          </div>
          <div class='review-form__footer'>
            <p>Tu valoración aparecerá públicamente con tu nombre.</p>
            <button type='submit' class='btn-primary review-form__submit'>Enviar opinión</button>
          </div>
        </form>
        <div id='reviewFormMsg'></div>
      `;

      const form = document.getElementById("reviewForm");
      const msg = document.getElementById("reviewFormMsg");
      const ratingInput = document.getElementById("ratingInput");
      const ratingValueInput = document.getElementById("reviewRatingValue");
      const ratingButtons = Array.from(
        document.querySelectorAll(".rating-input__star"),
      );
      const fieldContainers = document.querySelectorAll(".review-form__field");

      if (!(form instanceof HTMLFormElement) || !(msg instanceof HTMLElement)) {
        return;
      }

      // Fix textarea container layout
      fieldContainers.forEach((field) => {
        if (!(field instanceof HTMLElement)) return;
        field.style.display = "flex";
        field.style.flexDirection = "column";
        field.style.gap = "0.75rem";
        field.style.width = "100%";
      });

      // Fix textarea styling
      const textarea = form.querySelector("textarea");
      if (textarea) {
        textarea.style.minHeight = "120px";
        textarea.style.borderRadius = "8px";
        textarea.style.border = "1px solid rgba(255, 255, 255, 0.12)";
        textarea.style.background = "rgba(255, 255, 255, 0.03)";
        textarea.style.color = "#fff";
        textarea.style.padding = "0.85rem 1rem";
        textarea.style.font = "inherit";
        textarea.style.width = "100%";
        textarea.style.boxSizing = "border-box";
        textarea.style.display = "block";
        textarea.style.resize = "vertical";
      }

      let selectedRating = 0;

      function paintRating(value) {
        const rating = Math.max(0, Math.min(5, Number(value) || 0));
        selectedRating = rating;

        if (ratingValueInput instanceof HTMLInputElement) {
          ratingValueInput.value = String(rating);
        }

        ratingButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const buttonRating = Number(button.dataset.rating || 0);
          const isActive = buttonRating <= rating && rating > 0;

          // Toggle class
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", isActive ? "true" : "false");

          // Apply inline styles as fallback
          if (isActive) {
            button.style.color = "#C8FF00";
            button.style.textShadow =
              "0 0 12px #C8FF00, 0 0 24px rgba(200, 255, 0, 0.5)";
            button.style.transform = "scale(1.15)";
            button.style.fontSize = "2.5rem";
          } else {
            button.style.color = "rgba(255, 255, 255, 0.32)";
            button.style.textShadow = "none";
            button.style.transform = "scale(1)";
            button.style.fontSize = "2.5rem";
          }
        });
      }

      ratingButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const buttonRating = Number(button.dataset.rating || 0);

        // Set initial styles
        button.style.fontSize = "2.5rem";
        button.style.cursor = "pointer";
        button.style.border = "none";
        button.style.background = "transparent";
        button.style.padding = "0";
        button.style.color = "rgba(255, 255, 255, 0.32)";
        button.style.transition = "all 0.15s ease";

        button.addEventListener("click", () => paintRating(buttonRating));
        button.addEventListener("mouseenter", () => {
          button.style.color = "#C8FF00";
          button.style.textShadow =
            "0 0 10px #C8FF00, 0 0 20px rgba(200, 255, 0, 0.4)";
          button.style.transform = "scale(1.2)";
        });
        button.addEventListener("mouseleave", () =>
          paintRating(selectedRating),
        );
      });

      ratingInput?.addEventListener("mouseleave", () =>
        paintRating(selectedRating),
      );
      paintRating(0);

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        const rating = Number(fd.get("puntuacion") || 0);
        if (!rating) {
          msg.textContent = "Selecciona una puntuación.";
          return;
        }

        msg.textContent = "Enviando...";
        const body = JSON.stringify({
          producto_id: productId,
          puntuacion: rating,
          comentario: fd.get("comentario"),
        });
        try {
          const result = await requestApi("opiniones.php", {
            method: "POST",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body,
          });
          if (!result.ok) throw new Error(result.error || "Error");
          msg.textContent = "Opinión enviada. Pendiente de revisión.";
          form.reset();
          paintRating(0);
          fetchOpiniones();
        } catch (err) {
          const errorText =
            err instanceof Error ? err.message : "No se pudo enviar";
          if (errorText.includes("Ya has opinado")) {
            window.showToast?.(
              "Ya has dado tu opinión. Gracias por tu valoración.",
              "info",
            );
            currentUserOpinion =
              currentUserOpinion ||
              (
                await requestApi(`opiniones.php?producto_id=${productId}`, {
                  credentials: "include",
                })
              ).data?.opiniones?.find(
                (op) =>
                  Number(op.usuario_id || 0) === Number(currentUser?.id || 0),
              ) ||
              null;
            await fetchOpiniones();
            renderReviewForm();
            return;
          }
          msg.textContent = errorText;
        }
      });
    }

    renderReviewForm();
    fetchOpiniones();
    // @ts-nocheck
    const sourceLinks = {
      catalogo: { href: "/catalogo", label: "Catálogo" },
      novedades: { href: "/novedades", label: "Novedades" },
      accesorios: { href: "/accesorios", label: "Accesorios" },
      ofertas: { href: "/ofertas", label: "Ofertas" },
    };
    const currentSourceSlug =
      new URLSearchParams(window.location.search).get("from") || "catalogo";
    const currentSourceLink =
      sourceLinks[currentSourceSlug] || sourceLinks.catalogo;

    const sourceBreadcrumbLink = document.getElementById(
      "sourceBreadcrumbLink",
    );
    if (sourceBreadcrumbLink instanceof HTMLAnchorElement) {
      sourceBreadcrumbLink.href = currentSourceLink.href;
      sourceBreadcrumbLink.textContent = currentSourceLink.label;
    }

    function productUrlWithSource(targetSlug) {
      const suffix = currentSourceSlug
        ? `?from=${encodeURIComponent(currentSourceSlug)}`
        : "";
      return `/producto/${targetSlug}${suffix}`;
    }

    // --- Carrusel ---
    const carouselSlides = document.querySelectorAll(".gallery__slide");
    const dots = document.querySelectorAll(".carousel__dot");
    let currentIndex = 0;

    function goTo(index) {
      currentIndex = (index + carouselSlides.length) % carouselSlides.length;
      carouselSlides.forEach((s, i) =>
        s.classList.toggle("is-active", i === currentIndex),
      );
      dots.forEach((dot, i) =>
        dot.classList.toggle("is-active", i === currentIndex),
      );
    }

    document
      .getElementById("carouselPrev")
      ?.addEventListener("click", () => goTo(currentIndex - 1));
    document
      .getElementById("carouselNext")
      ?.addEventListener("click", () => goTo(currentIndex + 1));
    dots.forEach((dot) => {
      dot.addEventListener("click", () => goTo(Number(dot.dataset.index || 0)));
    });

    const sizeSelector = document.getElementById("sizeSelector");
    const sizeHint = document.getElementById("sizeHint");
    /** @type {HTMLInputElement | null} */
    const quantityInput = document.getElementById("quantityInput");
    const addToCartBtn = document.getElementById("addToCartBtn");
    const productInfo = document.getElementById("productInfo");
    const toggleWishlistBtn = document.getElementById("toggleWishlistBtn");

    /** @returns {HTMLInputElement | null} */
    function getSelectedSizeInput() {
      return document.querySelector('input[name="size"]:checked');
    }

    sizeSelector?.addEventListener("change", () => {
      const selected = getSelectedSizeInput();
      if (!selected || !sizeHint) {
        return;
      }
      const stock = Number(selected.dataset.stock || 0);
      sizeHint.textContent = `Talla ${selected.value}: ${stock} unidades disponibles`;
    });

    addToCartBtn?.addEventListener("click", () => {
      if (!productInfo) {
        return;
      }

      const isAccessory = productInfo.dataset.productType === "accesorio";
      const selected = getSelectedSizeInput();

      if (!isAccessory && !selected) {
        (window as any).showToast?.(
          "Selecciona una talla disponible.",
          "error",
        );
        return;
      }

      const quantity = Math.max(1, Number(quantityInput?.value || 1));
      const stock = isAccessory
        ? Number(productInfo.dataset.productTotalStock || 0)
        : Number(selected?.dataset.stock || 0);
      if (quantity > stock) {
        (window as any).showToast?.(
          "No hay suficiente stock para esa cantidad.",
          "error",
        );
        return;
      }

      const size = isAccessory ? "Única" : selected?.value || "";
      const sku = isAccessory
        ? `DMH-${Number(productInfo.dataset.productId)}-UNICA`
        : selected?.dataset.sku;

      const cartItem = {
        id: Number(productInfo.dataset.productId),
        slug: productInfo.dataset.productSlug,
        title: productInfo.dataset.productTitle,
        price: Number(productInfo.dataset.productPrice),
        image: productInfo.dataset.productImage,
        size,
        sku,
        quantity,
      };

      /** @type {Array<{slug: string, size: string, quantity: number}>} */
      const cart = JSON.parse(localStorage.getItem("cart") || "[]");
      let existingIndex = -1;
      for (let i = 0; i < cart.length; i += 1) {
        if (cart[i].slug === cartItem.slug && cart[i].size === cartItem.size) {
          existingIndex = i;
          break;
        }
      }

      if (existingIndex > -1) {
        cart[existingIndex].quantity += cartItem.quantity;
      } else {
        cart.push(cartItem);
      }

      localStorage.setItem("cart", JSON.stringify(cart));
      window.dispatchEvent(new Event("cart-updated"));

      if (typeof window.dmhFetchJson === "function") {
        window.dmhFetchJson("carrito.php", {
          method: "PUT",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items: cart }),
        });
      }

      (window as any).showToast?.("¡Producto añadido al carrito!", "success");
    });

    async function fetchWishlistState() {
      if (typeof window.dmhFetchJson !== "function") {
        return { authorized: false, slugs: [] };
      }

      const result = await window.dmhFetchJson("favoritos.php", {
        credentials: "include",
      });

      if (result.ok && result.data?.autenticado === false) {
        return { authorized: false, slugs: [] };
      }

      if (!result.ok) {
        if (result.status === 401) {
          return { authorized: false, slugs: [] };
        }
        throw new Error(result.error || "No se pudo cargar favoritos");
      }

      const slugs = result.data?.favoritos || [];
      const normalized =
        window.dmhFavorites?.set?.(slugs, "product-detail-fetch") || slugs;
      return { authorized: true, slugs: normalized };
    }

    async function addFavorite(slug) {
      const result = await window.dmhFetchJson("favoritos.php", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slug }),
      });

      if (result.ok) {
        window.dmhFavorites?.toggleOne?.(slug, true, "product-detail-add");
      }

      return result;
    }

    async function removeFavorite(slug) {
      const result = await window.dmhFetchJson("favoritos.php", {
        method: "DELETE",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slug }),
      });

      if (result.ok) {
        window.dmhFavorites?.toggleOne?.(slug, false, "product-detail-remove");
      }

      return result;
    }

    function paintWishlistButton(isFavorite) {
      if (!(toggleWishlistBtn instanceof HTMLButtonElement)) {
        return;
      }
      toggleWishlistBtn.textContent = isFavorite
        ? "♥ En wishlist"
        : "♡ Añadir a wishlist";
      toggleWishlistBtn.setAttribute(
        "aria-pressed",
        isFavorite ? "true" : "false",
      );
      toggleWishlistBtn.classList.toggle("is-active", isFavorite);
    }

    async function initWishlistButton() {
      if (!(toggleWishlistBtn instanceof HTMLButtonElement)) {
        return;
      }

      const slug = toggleWishlistBtn.dataset.productSlug;
      if (!slug) {
        return;
      }

      let authorized = false;
      let currentSet = window.dmhFavorites?.get?.() || [];

      try {
        const state = await fetchWishlistState();
        authorized = state.authorized;
        currentSet = state.slugs;
      } catch (_error) {
        currentSet = window.dmhFavorites?.get?.() || [];
      }

      paintWishlistButton(currentSet.includes(slug));

      toggleWishlistBtn.addEventListener("click", async () => {
        if (!authorized) {
          window.location.href = "/login";
          return;
        }

        const isFavorite = (window.dmhFavorites?.get?.() || []).includes(slug);
        const result = isFavorite
          ? await removeFavorite(slug)
          : await addFavorite(slug);

        if (!result.ok) {
          if (result.status === 401) {
            window.location.href = "/login";
            return;
          }
          (window as any).showToast?.(
            result.error || "No se pudo actualizar favoritos",
            "error",
          );
          return;
        }

        const nowFav = !isFavorite;
        paintWishlistButton(nowFav);
        (window as any).showToast?.(
          nowFav
            ? "Producto añadido a wishlist"
            : "Producto eliminado de wishlist",
          "success",
        );
      });

      window.addEventListener("wishlist-updated", (event) => {
        const slugs = event?.detail?.slugs;
        if (!Array.isArray(slugs)) return;
        paintWishlistButton(slugs.includes(slug));
      });
    }

    initWishlistButton();

    // --- Related cards navigation ---
    document.querySelectorAll(".related-card").forEach((card) => {
      const slug = card.getAttribute("data-slug");
      if (!slug) return;
      card.addEventListener("click", () => {
        window.location.href = productUrlWithSource(slug);
      });
      card.addEventListener("keydown", (e) => {
        if (!(e instanceof KeyboardEvent)) return;
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          window.location.href = productUrlWithSource(slug);
        }
      });
    });
  </script>
</HomeLayout>

