---
import HomeLayout from "../layouts/HomeLayout.astro";
import CatalogSection from "../components/CatalogSection.astro";
import { fetchCatalogData } from "../lib/catalog-api";
import { cartIcon } from "../components/icons.ts";

type Product = {
  id: number;
  slug: string;
  title: string;
  category: string;
  price: number;
  originalPrice?: number;
  tallaje?: string;
  type: string;
  color: string;
  badge?: string;
  createdAt: string;
  image: string;
};

export async function getStaticPaths() {
  return ["catalogo", "novedades", "accesorios", "ofertas"].map((slug) => ({
    params: { slug },
    props: { slug }
  }));
}

const { products, stock } = await fetchCatalogData();
const allProducts = products as Product[];
const stockBySlug = new Map((stock || []).map((entry) => [entry.productSlug, entry]));
const { slug } = Astro.props;
const isCatalog = slug === "catalogo";

let filteredProducts = allProducts;
let titulo = "Catálogo";

if (slug === "novedades") {
  titulo = "Novedades";
  filteredProducts = allProducts.filter((product) => product.badge === "NEW");
} else if (slug === "accesorios") {
  titulo = "Accesorios";
  filteredProducts = allProducts.filter((product) => product.type === "accesorio");
} else if (slug === "ofertas") {
  titulo = "Ofertas";
  filteredProducts = allProducts.filter(
    (product) => product.badge === "Oferta" || Boolean(product.originalPrice)
  );
}
---

<HomeLayout title={`DMH - ${titulo}`}>
  {isCatalog ? (
    <CatalogSection />
  ) : (
    <section class="categoria">
      <div class="categoria__container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Inicio</a>
          <span>/</span>
          <span>{titulo}</span>
        </nav>

        <div class="categoria__content">
          <div class="categoria__products">
            <h1 class="categoria__title">{titulo}</h1>
            {filteredProducts.length > 0 ? (
              <div class="products-grid" id="productsGrid" data-quick-add-icon={cartIcon}>
                {filteredProducts.map((product) => {
                  const stockEntry = stockBySlug.get(product.slug);
                  const totalStock = stockEntry?.totalStock ?? 0;
                  const sizeOptions = Object.entries(stockEntry?.bySize ?? {}).map(([size, info]) => ({
                    size,
                    stock: Number((info as { stock?: number }).stock ?? 0),
                    sku: (info as { sku?: string }).sku ?? `DMH-${product.id}-${size}`,
                  }));

                  return (
                  <article
                    class="product-card"
                    data-product-id={product.id}
                    data-type={product.type}
                    data-sizing={product.tallaje || "clasico"}
                    data-color={product.color}
                    data-price={product.price}
                    data-product-slug={product.slug}
                    data-product-title={product.title}
                    data-product-image={product.image}
                    data-product-total-stock={totalStock}
                    data-size-options={JSON.stringify(sizeOptions)}
                    tabindex="0"
                    role="link"
                    aria-label={`Ver ${product.title}`}
                  >
                    <div class="product-card__image" aria-hidden="true">
                      {product.badge && <span class="badge">{product.badge}</span>}
                      <button class="icon-fav" type="button" aria-label="Añadir a favoritos">♡</button>
                      {product.image.startsWith('/') || product.image.startsWith('http') ? (
                        <img src={product.image} alt={product.title} loading="lazy" />
                      ) : (
                        <span class="product-card__image-placeholder">{product.image}</span>
                      )}
                    </div>
                    <div class="product-card__content">
                      <p class="product-category">{product.category}</p>
                      <h3>{product.title}</h3>
                      <div class="product-card__footer">
                        {product.originalPrice && (
                          <span class="product-price-original">{product.originalPrice.toFixed(2)}€</span>
                        )}
                        <span class="product-price">{product.price.toFixed(2)}€</span>
                      </div>
                    </div>
                  </article>
                )})}
              </div>
            ) : (
              <div class="categoria-empty" role="status" aria-live="polite">
                <p>No disponemos de este tipo de artículos ahora mismo.</p>
                <a href="/catalogo">Ver catálogo completo</a>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  {!isCatalog && <script src="/catalog-client.js" is:inline></script>}
</HomeLayout>

<style>
  .categoria {
    width: 100%;
    padding: 2rem 3rem;
    background: #1a1a1a;
    min-height: 80vh;
  }

  .categoria__container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .breadcrumb a {
    color: #C8FF00;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: #a4dd00;
  }

  .categoria__content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .categoria__products {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .categoria__title {
    font-size: 1.5rem;
    color: #f5f5f5;
    margin: 0;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 260px));
    gap: 1.2rem;
    align-items: stretch;
    justify-content: flex-start;
  }

  .categoria-empty {
    background: #161616;
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: 14px;
    padding: 1.4rem 1.1rem;
    color: rgba(255, 255, 255, 0.78);
    display: grid;
    gap: 0.85rem;
    justify-items: start;
  }

  .categoria-empty p {
    margin: 0;
    line-height: 1.5;
  }

  .categoria-empty a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 0.95rem;
    border-radius: 999px;
    background: #c8ff00;
    color: #090909;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.86rem;
  }

  .product-card {
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  .product-card:hover {
    border-color: rgba(200, 255, 0, 0.35);
    transform: translateY(-2px);
  }

  .badge {
    position: relative;
    z-index: 1;
    display: inline-flex;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    background: #C8FF00;
    color: #090909;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .icon-fav {
    border: none;
    background: rgba(0, 0, 0, 0.42);
    color: #f5f5f5;
    width: 34px;
    height: 34px;
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .icon-fav:hover {
    background: rgba(0, 0, 0, 0.62);
  }

  .product-card__image {
    position: relative;
    height: 260px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(0, 0, 0, 0.22));
    display: flex;
    align-items: flex-start;
    padding: 0.75rem;
    color: rgba(255, 255, 255, 0.28);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.95rem;
    overflow: hidden;
  }

  .product-card__image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-card__image-placeholder {
    color: rgba(255, 255, 255, 0.28);
  }

  .product-card__content {
    padding: 1rem;
    display: grid;
    gap: 0.3rem;
  }

  .product-category {
    margin: 0;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .product-card h3 {
    margin: 0;
    color: #f5f5f5;
    font-size: 0.98rem;
    font-weight: 500;
    line-height: 1.35;
  }

  .product-card__footer {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.2rem;
    min-height: 34px;
    padding-right: 42px;
  }

  .product-price {
    font-size: 1rem;
    font-weight: 700;
    color: #C8FF00;
  }

  .product-price-original {
    color: rgba(255, 255, 255, 0.38);
    font-size: 0.83rem;
    text-decoration: line-through;
    margin-right: 0.1rem;
  }

  .quick-add-btn {
    position: absolute;
    right: 0;
    bottom: 0;
    z-index: 2;
    border: none;
    background: rgba(200, 255, 0, 0.16);
    color: #d8ff48;
    border-radius: 999px;
    width: 34px;
    height: 34px;
    padding: 0;
    font-weight: 700;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .quick-add-btn:hover {
    background: rgba(200, 255, 0, 0.24);
  }

  .quick-add-btn :global(svg) {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .categoria {
      padding: 1.5rem;
    }

    .products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>