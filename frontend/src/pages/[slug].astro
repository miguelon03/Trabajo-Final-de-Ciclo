---
import HomeLayout from "../layouts/HomeLayout.astro";
import CatalogSection from "../components/CatalogSection.astro";
import { fetchCatalogData } from "../lib/catalog-api";
import { cartIcon } from "../components/icons.ts";

type Product = {
  id: number;
  slug: string;
  title: string;
  category: string;
  price: number;
  originalPrice?: number;
  type: string;
  color: string;
  badge?: string;
  createdAt: string;
  image: string;
};

export async function getStaticPaths() {
  return ["catalogo", "novedades", "accesorios", "ofertas"].map((slug) => ({
    params: { slug },
    props: { slug }
  }));
}

const { products } = await fetchCatalogData();
const allProducts = products as Product[];
const { slug } = Astro.props;
const isCatalog = slug === "catalogo";

let filteredProducts = allProducts;
let titulo = "Catálogo";

if (slug === "novedades") {
  titulo = "Novedades";
  filteredProducts = allProducts.filter((product) => product.badge === "NEW");
} else if (slug === "accesorios") {
  titulo = "Accesorios";
  filteredProducts = allProducts.filter((product) => product.type === "accesorio");
} else if (slug === "ofertas") {
  titulo = "Ofertas";
  filteredProducts = allProducts.filter(
    (product) => product.badge === "Oferta" || Boolean(product.originalPrice)
  );
}
---

<HomeLayout title={`DMH - ${titulo}`}>
  {isCatalog ? (
    <CatalogSection />
  ) : (
    <section class="categoria">
      <div class="categoria__container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Inicio</a>
          <span>/</span>
          <span>{titulo}</span>
        </nav>

        <div class="categoria__content">
          {slug === "novedades" && (
            <div class="novedades__hero">
              <div class="novedades__images">
                <div class="placeholder-image">Imagen Marca 1</div>
                <div class="placeholder-image">Imagen Marca 2</div>
              </div>
              <div class="novedades__text">
                <h2>Nueva Colección Primavera</h2>
                <p>Descubre nuestras últimas prendas con diseños exclusivos y materiales de alta calidad.</p>
                <p>Nueva Sudadera Urban Style - Disponible ahora en negro y gris.</p>
              </div>
            </div>
          )}

          <div class="categoria__products">
            <h1 class="categoria__title">{titulo}</h1>
            <div class="products-grid">
              {filteredProducts.map((product) => (
                <article
                  class="product-card"
                  data-product-id={product.id}
                  data-type={product.type}
                  data-color={product.color}
                  data-price={product.price}
                  data-product-slug={product.slug}
                  data-product-title={product.title}
                  data-product-image={product.image}
                  tabindex="0"
                  role="link"
                  aria-label={`Ver ${product.title}`}
                >
                  <div class="product-card__top">
                    {product.badge && <span class="badge">{product.badge}</span>}
                    <button class="icon-fav" type="button" aria-label="Añadir a favoritos">♡</button>
                  </div>
                  <div class="product-card__image" aria-hidden="true">
                    {product.image.startsWith('/') || product.image.startsWith('http') ? (
                      <img src={product.image} alt={product.title} loading="lazy" />
                    ) : (
                      <span class="product-card__image-placeholder">{product.image}</span>
                    )}
                  </div>
                  <div class="product-card__content">
                    <h3>{product.title}</h3>
                    <p class="product-category">{product.category}</p>
                    <div class="product-card__footer">
                      {product.originalPrice && (
                        <span class="product-price-original">{product.originalPrice.toFixed(2)}€</span>
                      )}
                      <span class="product-price">{product.price.toFixed(2)}€</span>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {!isCatalog && (
    <script define:vars={{ sourceSlug: slug, quickAddIcon: cartIcon }}>
      // @ts-nocheck
      const buildProductUrl = (productSlug) =>
        `/producto/${productSlug}?from=${encodeURIComponent(sourceSlug)}`;
      let currentFavorites = window.dmhFavorites?.get?.() || [];

      const cards = document.querySelectorAll(".product-card");

      async function fetchWishlist() {
        const result = await window.dmhFetchJson("favoritos.php", {
          credentials: "include",
        });

        if (!result.ok) {
          if (result.status === 401) {
            return { authorized: false, slugs: [], error: "Debes iniciar sesión" };
          }

          return {
            authorized: false,
            slugs: currentFavorites,
            error: result.error || "No se pudo cargar favoritos",
          };
        }

        const slugs = result.data?.favoritos || [];
        currentFavorites = window.dmhFavorites?.set?.(slugs, "collection-fetch") || slugs;
        return { authorized: true, slugs: currentFavorites, error: null };
      }

      async function addFavorite(slug) {
        const result = await window.dmhFetchJson("favoritos.php", {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ slug }),
        });

        if (result.ok) {
          currentFavorites =
            window.dmhFavorites?.toggleOne?.(slug, true, "collection-add") || currentFavorites;
        }

        return result;
      }

      async function removeFavorite(slug) {
        const result = await window.dmhFetchJson("favoritos.php", {
          method: "DELETE",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ slug }),
        });

        if (result.ok) {
          currentFavorites =
            window.dmhFavorites?.toggleOne?.(slug, false, "collection-remove") || currentFavorites;
        }

        return result;
      }

      function updateFavButton(card, isFavorite) {
        const button = card.querySelector(".icon-fav");
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        button.textContent = isFavorite ? "♥" : "♡";
        button.setAttribute(
          "aria-label",
          isFavorite ? "Quitar de favoritos" : "Añadir a favoritos",
        );
      }

      async function initCards() {
        const { authorized, slugs, error } = await fetchWishlist();

        cards.forEach((card) => {
        const productSlug = card.getAttribute("data-product-slug");
        const favButton = card.querySelector(".icon-fav");

        if (!productSlug) {
          return;
        }

        if (favButton instanceof HTMLButtonElement) {
          updateFavButton(card, slugs.includes(productSlug));

          favButton.addEventListener("click", async (event) => {
            event.preventDefault();
            event.stopPropagation();

            if (!authorized) {
              setTimeout(() => {
                window.location.href = "/login";
              }, 500);
              return;
            }

            const isFavorite = favButton.textContent === "♥";
            const result = isFavorite
              ? await removeFavorite(productSlug)
              : await addFavorite(productSlug);

            if (!result.ok) {
              if (result.status === 401) {
                setTimeout(() => {
                  window.location.href = "/login";
                }, 500);
                return;
              }

              window.showToast?.(result.error || "No se pudo actualizar favoritos", "error");
              return;
            }

            updateFavButton(card, !isFavorite);
            window.showToast?.(
              isFavorite ? "Producto eliminado de favoritos" : "Producto añadido a favoritos",
              "success",
            );
          });
        }

        if (card.getAttribute("data-type") === "accesorio") {
          const footer = card.querySelector(".product-card__footer");
          if (footer instanceof HTMLElement && !footer.querySelector(".quick-add-btn")) {
            const quickAddBtn = document.createElement("button");
            quickAddBtn.type = "button";
            quickAddBtn.className = "quick-add-btn";
            quickAddBtn.innerHTML = quickAddIcon;
            quickAddBtn.setAttribute("aria-label", "Añadir accesorio al carrito");

            quickAddBtn.addEventListener("click", (event) => {
              event.preventDefault();
              event.stopPropagation();

              const id = Number(card.getAttribute("data-product-id") || 0);
              const title = card.getAttribute("data-product-title") || "Producto";
              const image = card.getAttribute("data-product-image") || "";
              const color = card.getAttribute("data-color") || "";
              const price = Number(card.getAttribute("data-price") || 0);

              if (!id || !price) {
                return;
              }

              const cart = JSON.parse(localStorage.getItem("cart") || "[]");
              const existingIndex = cart.findIndex(
                (item) => item.slug === productSlug && item.size === "Única",
              );

              if (existingIndex >= 0) {
                cart[existingIndex].quantity += 1;
              } else {
                cart.push({
                  id,
                  slug: productSlug,
                  title,
                  price,
                  image,
                  color,
                  size: "Única",
                  sku: `DMH-${id}-UNICA`,
                  quantity: 1,
                });
              }

              localStorage.setItem("cart", JSON.stringify(cart));
              window.dispatchEvent(new Event("cart-updated"));
              window.showToast?.("Accesorio añadido al carrito", "success");
            });

            footer.appendChild(quickAddBtn);
          }
        }

        card.addEventListener("click", (event) => {
          const target = event.target;
          if (
            target instanceof Element &&
            (target.closest(".icon-fav") || target.closest(".quick-add-btn"))
          ) {
            return;
          }
          window.location.href = buildProductUrl(productSlug);
        });

        card.addEventListener("keydown", (event) => {
          if (!(event instanceof KeyboardEvent)) {
            return;
          }
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            window.location.href = buildProductUrl(productSlug);
          }
        });
        });
      }

      window.addEventListener("wishlist-updated", (event) => {
        const detailSlugs = event?.detail?.slugs;
        if (Array.isArray(detailSlugs)) {
          currentFavorites = detailSlugs;
        }

        cards.forEach((card) => {
          const productSlug = card.getAttribute("data-product-slug");
          if (!productSlug) {
            return;
          }
          updateFavButton(card, currentFavorites.includes(productSlug));
        });
      });

      initCards();
    </script>
  )}
</HomeLayout>

<style>
  .categoria {
    width: 100%;
    padding: 2rem 3rem;
    background: #1a1a1a;
    min-height: 80vh;
  }

  .categoria__container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .breadcrumb a {
    color: #C8FF00;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: #a4dd00;
  }

  .categoria__content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .novedades__hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  .novedades__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .placeholder-image {
    aspect-ratio: 1;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(0, 0, 0, 0.22));
    border-radius: var(--border-radius-card);
    display: grid;
    place-items: center;
    color: rgba(255, 255, 255, 0.28);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.95rem;
  }

  .novedades__text h2 {
    color: #C8FF00;
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .novedades__text p {
    color: #f5f5f5;
    margin-bottom: 0.5rem;
  }

  .categoria__products {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .categoria__title {
    font-size: 1.5rem;
    color: #f5f5f5;
    margin: 0;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
    align-items: stretch;
  }

  .product-card {
    background: #111111;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--border-radius-card);
    overflow: hidden;
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 1rem;
    padding: 1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    min-height: 420px;
    cursor: pointer;
  }

  .product-card:hover {
    border-color: rgba(200, 255, 0, 0.3);
  }

  .product-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 0.5rem;
    min-height: 38px;
  }

  .badge {
    display: inline-flex;
    padding: 0.4rem 0.75rem;
    border-radius: var(--border-radius-sm);
    background: #C8FF00;
    color: #090909;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .icon-fav {
    border: none;
    background: rgba(255, 255, 255, 0.04);
    color: #f5f5f5;
    width: 38px;
    height: 38px;
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .icon-fav:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .product-card__image {
    height: 260px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(0, 0, 0, 0.22));
    border-radius: var(--border-radius-card);
    display: grid;
    place-items: center;
    color: rgba(255, 255, 255, 0.28);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.95rem;
    overflow: hidden;
  }

  .product-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-card__image-placeholder {
    color: rgba(255, 255, 255, 0.28);
  }

  .product-card__content {
    display: grid;
    gap: 0.5rem;
  }

  .product-category {
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .product-card h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.4;
  }

  .product-card__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
  }

  .product-price {
    font-size: 1.1rem;
    font-weight: 700;
    color: #C8FF00;
  }

  .product-price-original {
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: line-through;
    margin-right: 0;
  }

  .quick-add-btn {
    border: none;
    background: rgba(200, 255, 0, 0.16);
    color: #d8ff48;
    border-radius: 999px;
    width: 34px;
    height: 34px;
    padding: 0;
    font-weight: 700;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .quick-add-btn:hover {
    background: rgba(200, 255, 0, 0.24);
  }

  .quick-add-btn :global(svg) {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .categoria {
      padding: 1.5rem;
    }

    .novedades__hero {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .novedades__images {
      grid-template-columns: 1fr;
    }

    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>