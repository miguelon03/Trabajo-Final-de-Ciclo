---
import HomeLayout from "../layouts/HomeLayout.astro";
---

<HomeLayout title="DMH - Carrito" description="Tu carrito de compras en DripMode Hood">
  <section class="cart-page">
    <div class="cart-container">

      <!-- Encabezado -->
      <div class="cart-heading">
        <h1>Tu carrito</h1>
        <button class="cart-clear-btn" id="cartClearBtn" type="button">Vaciar carrito</button>
      </div>

      <!-- Contenido principal -->
      <div class="cart-layout" id="cartLayout">

        <!-- Lista de productos -->
        <div class="cart-items" id="cartItems"></div>

        <!-- Resumen del pedido -->
        <aside class="cart-summary" id="cartSummary" style="display:none">
          <h2>Resumen del pedido</h2>

          <div class="cart-summary__lines">
            <div class="cart-summary__line">
              <span>Subtotal</span>
              <span id="summarySubtotal">0,00 €</span>
            </div>
            <div class="cart-summary__line">
              <span>Envío</span>
              <span id="summaryShipping">—</span>
            </div>
            <div class="cart-summary__line cart-summary__line--total">
              <strong>Total</strong>
              <strong id="summaryTotal">0,00 €</strong>
            </div>
          </div>

          <p class="cart-summary__shipping-note" id="shippingNote"></p>

          <button class="cart-checkout-btn" id="cartCheckoutBtn" type="button">
            Finalizar compra
          </button>

          <a class="cart-continue-link" href="/catalogo">← Seguir comprando</a>
        </aside>

      </div>

      <!-- Estado vacío -->
      <div class="cart-empty" id="cartEmpty">
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/>
          <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
        </svg>
        <p>Tu carrito está vacío.</p>
        <a class="cart-empty__cta" href="/catalogo">Explorar catálogo</a>
      </div>

    </div>
  </section>

  <!-- Modal de checkout -->
  <div id="checkoutOverlay" class="checkout-overlay" hidden aria-modal="true" role="dialog" aria-labelledby="checkoutTitle">
    <div class="checkout-modal">
      <button class="checkout-modal__close" id="checkoutClose" aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>

      <h2 id="checkoutTitle">Finalizar compra</h2>

      <p class="checkout-modal__hint checkout-modal__hint--soft" id="checkoutModeHint"></p>

      <div id="guestFields" class="checkout-modal__guest-note" hidden>
        <p class="checkout-modal__hint">
          Compras como invitado. Si creas una cuenta tendrás beneficios de miembro: seguimiento de pedidos, historial y checkout más rápido.
        </p>
        <a class="checkout-modal__link" href="/registro">Crear cuenta ahora</a>
      </div>

      <label>
        <span>Nombre completo</span>
        <input type="text" id="checkoutNombre" autocomplete="name" placeholder="Nombre y apellidos" />
      </label>

      <label>
        <span>Email</span>
        <input type="email" id="checkoutEmail" autocomplete="email" placeholder="tu@email.com" />
      </label>

      <div class="checkout-modal__grid-2">
        <label>
          <span>Teléfono</span>
          <input type="tel" id="checkoutTelefono" autocomplete="tel" placeholder="600123123" />
        </label>
        <label>
          <span>Código postal</span>
          <input type="text" id="checkoutCodigoPostal" autocomplete="postal-code" placeholder="28001" />
        </label>
      </div>

      <div class="checkout-modal__grid-2">
        <label>
          <span>Dirección de envío</span>
          <input type="text" id="checkoutDireccion" autocomplete="street-address" placeholder="Calle, número" />
        </label>
        <label>
          <span>Ciudad</span>
          <input type="text" id="checkoutCiudad" autocomplete="address-level2" placeholder="Madrid" />
        </label>
      </div>

      <div class="checkout-modal__paybox">
        <strong>Método de pago: Bizum</strong>
        <label>
          <span>Número Bizum (9 dígitos)</span>
          <input type="tel" id="checkoutBizum" inputmode="numeric" placeholder="600123123" />
        </label>
        <p class="checkout-modal__hint">Al confirmar, procesaremos el pedido y te mostraremos el resumen del pago por Bizum.</p>
      </div>

      <p id="checkoutProfileMissing" class="checkout-modal__warn" hidden></p>

      <label class="checkout-modal__checkline">
        <input type="checkbox" id="checkoutPolicy" />
        <span>Acepto las condiciones de compra y la política de privacidad.</span>
      </label>

      <p id="checkoutError" class="checkout-modal__error" hidden></p>

      <button class="btn-checkout-confirm" id="checkoutConfirm" type="button">Confirmar pedido</button>
    </div>
  </div>

  <script>
    // @ts-nocheck
    const FREE_SHIPPING_THRESHOLD = 80;
    const SHIPPING_COST = 4.95;

    type CartItem = {
      id: number;
      slug: string;
      title: string;
      price: number;
      image: string;
      color: string;
      size: string;
      sku: string;
      quantity: number;
    };

    function getCart(): CartItem[] {
      return JSON.parse(localStorage.getItem('cart') || '[]');
    }

    function saveCart(cart: CartItem[]) {
      localStorage.setItem('cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart-updated'));
    }

    function fmt(n: number) {
      return n.toFixed(2).replace('.', ',') + ' €';
    }

    function escHtml(str: string) {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function render() {
      const cart = getCart();
      const cartItems = document.getElementById('cartItems');
      const cartEmpty = document.getElementById('cartEmpty');
      const cartLayout = document.getElementById('cartLayout');
      const cartClearBtn = document.getElementById('cartClearBtn');
      const cartHeading = document.querySelector('.cart-heading');

      if (!cartItems || !cartEmpty || !cartLayout) return;

      if (cart.length === 0) {
        cartEmpty.style.display = 'flex';
        cartLayout.style.display = 'none';
        const cartSummaryEl = document.getElementById('cartSummary');
        if (cartSummaryEl) cartSummaryEl.style.display = 'none';
        if (cartClearBtn) cartClearBtn.style.display = 'none';
        return;
      }

      cartEmpty.style.display = 'none';
      cartLayout.style.display = 'grid';
      const cartSummary = document.getElementById('cartSummary');
      if (cartSummary) cartSummary.style.display = 'grid';
      if (cartClearBtn) cartClearBtn.style.display = 'inline-flex';

      cartItems.innerHTML = cart.map((item, index) => `
        <article class="cart-item" data-index="${index}">
          <button class="cart-item__remove" data-index="${index}" aria-label="Eliminar ${escHtml(item.title)}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
          </button>
          <div class="cart-item__img" aria-hidden="true">
            ${item.image && (item.image.startsWith('/') || item.image.startsWith('http'))
              ? `<img src="${escHtml(item.image)}" alt="${escHtml(item.title)}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;display:block;"/>`
              : `<span style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-size:0.7rem;color:rgba(255,255,255,0.2);text-transform:uppercase;letter-spacing:0.1em;background:repeating-linear-gradient(45deg,rgba(255,255,255,0.015) 0px,rgba(255,255,255,0.015) 1px,transparent 1px,transparent 10px);">IMG</span>`
            }
          </div>
          <div class="cart-item__info">
            <h3 class="cart-item__title">${escHtml(item.title)}</h3>
            <p class="cart-item__details">${escHtml(item.size)} · ${escHtml(item.color)}</p>
            <p class="cart-item__sku">SKU: ${escHtml(item.sku)}</p>
            <div class="cart-item__bottom">
              <div class="cart-item__qty">
                <button class="qty-btn" data-action="dec" data-index="${index}" aria-label="Reducir cantidad">−</button>
                <span class="qty-value">${item.quantity}</span>
                <button class="qty-btn" data-action="inc" data-index="${index}" aria-label="Aumentar cantidad">+</button>
              </div>
              <span class="cart-item__price">${fmt(item.price * item.quantity)}</span>
            </div>
          </div>
        </article>
      `).join('');

      // Listeners botones eliminar
      cartItems.querySelectorAll('.cart-item__remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const i = Number(btn.dataset.index);
          const c = getCart();
          c.splice(i, 1);
          saveCart(c);
          render();
        });
      });

      // Listeners botones cantidad
      cartItems.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const i = Number(btn.dataset.index);
          const c = getCart();
          if (btn.dataset.action === 'inc') {
            c[i].quantity += 1;
          } else {
            c[i].quantity -= 1;
            if (c[i].quantity <= 0) { c.splice(i, 1); }
          }
          saveCart(c);
          render();
        });
      });

      // Resumen
      const subtotal = cart.reduce((s, item) => s + item.price * item.quantity, 0);
      const shipping = subtotal >= FREE_SHIPPING_THRESHOLD ? 0 : SHIPPING_COST;
      const total = subtotal + shipping;

      const subEl = document.getElementById('summarySubtotal');
      const shipEl = document.getElementById('summaryShipping');
      const totalEl = document.getElementById('summaryTotal');
      const noteEl = document.getElementById('shippingNote');

      if (subEl) subEl.textContent = fmt(subtotal);
      if (shipEl) shipEl.textContent = shipping === 0 ? 'Gratis' : fmt(shipping);
      if (totalEl) totalEl.textContent = fmt(total);
      if (noteEl) {
        if (shipping === 0) {
          noteEl.textContent = '¡Envío gratuito aplicado!';
          noteEl.className = 'cart-summary__shipping-note cart-summary__shipping-note--free';
        } else {
          const diff = FREE_SHIPPING_THRESHOLD - subtotal;
          noteEl.textContent = `Añade ${fmt(diff)} más para envío gratuito.`;
          noteEl.className = 'cart-summary__shipping-note';
        }
      }
    }

    // Vaciar carrito
    document.getElementById('cartClearBtn')?.addEventListener('click', () => {
      window.showConfirmToast?.('¿Seguro que quieres vaciar el carrito?', () => {
        saveCart([]);
        render();
        window.showToast?.('Carrito vaciado correctamente.', 'success');
      });
    });

    // ── Checkout modal ─────────────────────────────────────────────────────
    const overlay       = document.getElementById('checkoutOverlay');
    const checkoutClose = document.getElementById('checkoutClose');
    const guestFields   = document.getElementById('guestFields');
    const checkoutError = document.getElementById('checkoutError');
    const checkoutBtn   = document.getElementById('cartCheckoutBtn');
    const confirmBtn    = document.getElementById('checkoutConfirm');
    const modeHintEl    = document.getElementById('checkoutModeHint');
    const missingEl     = document.getElementById('checkoutProfileMissing');
    const policyEl      = document.getElementById('checkoutPolicy');

    const nombreEl      = document.getElementById('checkoutNombre');
    const emailEl       = document.getElementById('checkoutEmail');
    const telefonoEl    = document.getElementById('checkoutTelefono');
    const direccionEl   = document.getElementById('checkoutDireccion');
    const ciudadEl      = document.getElementById('checkoutCiudad');
    const cpEl          = document.getElementById('checkoutCodigoPostal');
    const bizumEl       = document.getElementById('checkoutBizum');

    let isLoggedIn = false;
    let profileData = null;

    async function checkSession() {
      try {
        const res = await fetch('/backend/session.php', { credentials: 'include' });
        const data = await res.json();
        isLoggedIn = !!(data.autenticado && data.usuario);
      } catch (_) {
        isLoggedIn = false;
      }
    }

    function inputVal(el) {
      return el instanceof HTMLInputElement ? el.value.trim() : '';
    }

    function assignVal(el, value) {
      if (el instanceof HTMLInputElement) {
        el.value = value || '';
      }
    }

    function setModeTexts() {
      if (modeHintEl) {
        modeHintEl.textContent = isLoggedIn
          ? 'Compra como miembro. Revisa tus datos y paga por Bizum.'
          : 'Compra como invitado. Te pediremos todos los datos para completar el pedido.';
      }

      if (guestFields) {
        guestFields.hidden = isLoggedIn;
      }
    }

    function getMissingProfileFields(data) {
      const missing = [];
      if (!data?.telefono) missing.push('teléfono');
      if (!data?.direccion) missing.push('dirección');
      if (!data?.ciudad) missing.push('ciudad');
      if (!data?.codigo_postal) missing.push('código postal');
      return missing;
    }

    async function loadProfileForCheckout() {
      if (!isLoggedIn) {
        profileData = null;
        return;
      }

      const profileRes = await window.dmhFetchJson('perfil.php', {
        credentials: 'include',
      });

      if (!profileRes.ok) {
        throw new Error(profileRes.error || 'No se pudo cargar tu perfil');
      }

      profileData = profileRes.data?.usuario || null;

      assignVal(nombreEl, profileData?.nombre || '');
      assignVal(emailEl, profileData?.email || '');
      assignVal(telefonoEl, profileData?.telefono || '');
      assignVal(direccionEl, profileData?.direccion || '');
      assignVal(ciudadEl, profileData?.ciudad || '');
      assignVal(cpEl, profileData?.codigo_postal || '');

      if (emailEl instanceof HTMLInputElement) {
        emailEl.readOnly = true;
      }
    }

    function resetGuestEditableFields() {
      if (emailEl instanceof HTMLInputElement) {
        emailEl.readOnly = false;
      }
      assignVal(nombreEl, '');
      assignVal(emailEl, '');
      assignVal(telefonoEl, '');
      assignVal(direccionEl, '');
      assignVal(ciudadEl, '');
      assignVal(cpEl, '');
    }

    function showMissingFieldsHint() {
      if (!missingEl) return;

      if (!isLoggedIn || !profileData) {
        missingEl.hidden = true;
        missingEl.textContent = '';
        return;
      }

      const missing = getMissingProfileFields(profileData);
      if (!missing.length) {
        missingEl.hidden = true;
        missingEl.textContent = '';
        return;
      }

      missingEl.hidden = false;
      missingEl.textContent = 'Te faltan datos de perfil: ' + missing.join(', ') + '. Complétalos para finalizar la compra.';
    }

    async function prepareCheckoutState() {
      await checkSession();
      setModeTexts();

      if (isLoggedIn) {
        await loadProfileForCheckout();
      } else {
        profileData = null;
        resetGuestEditableFields();
      }

      if (checkoutError) {
        checkoutError.hidden = true;
        checkoutError.textContent = '';
      }
      if (policyEl instanceof HTMLInputElement) {
        policyEl.checked = false;
      }
      assignVal(bizumEl, '');
      showMissingFieldsHint();
    }

    function openCheckout() {
      if (!overlay) return;
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function closeCheckout() {
      if (!overlay) return;
      overlay.hidden = true;
      document.body.style.overflow = '';
    }

    checkoutBtn?.addEventListener('click', async () => {
      try {
        await prepareCheckoutState();
        openCheckout();
      } catch (error) {
        window.showToast?.(error?.message || 'No se pudo preparar el checkout', 'error');
      }
    });

    checkoutClose?.addEventListener('click', closeCheckout);
    overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeCheckout(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay && !overlay.hidden) closeCheckout();
    });

    confirmBtn?.addEventListener('click', async () => {
      if (checkoutError) { checkoutError.hidden = true; checkoutError.textContent = ''; }

      const nombre = inputVal(nombreEl);
      const email = inputVal(emailEl);
      const telefono = inputVal(telefonoEl);
      const direccion = inputVal(direccionEl);
      const ciudad = inputVal(ciudadEl);
      const codigoPostal = inputVal(cpEl);
      const bizum = inputVal(bizumEl);

      if (!nombre || !email || !telefono || !direccion || !ciudad || !codigoPostal) {
        showCheckoutError('Completa todos los campos obligatorios para finalizar la compra');
        return;
      }

      if (!/^\S+@\S+\.\S+$/.test(email)) {
        showCheckoutError('Introduce un email válido');
        return;
      }

      if (!/^\d{9}$/.test(bizum)) {
        showCheckoutError('El número de Bizum debe tener 9 dígitos');
        return;
      }

      if (!(policyEl instanceof HTMLInputElement) || !policyEl.checked) {
        showCheckoutError('Debes aceptar las condiciones de compra para continuar');
        return;
      }

      const direccionCompleta = `${direccion}, ${codigoPostal} ${ciudad}`;

      const payload = { items: getCart(), direccion_envio: direccionCompleta };

      if (!isLoggedIn) {
        payload.nombre = nombre;
        payload.email  = email;
      } else {
        const profileUpdate = await window.dmhFetchJson('perfil.php', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nombre,
            telefono,
            direccion,
            ciudad,
            codigo_postal: codigoPostal,
          }),
        });

        if (!profileUpdate.ok) {
          showCheckoutError(profileUpdate.error || 'No se pudo actualizar tu perfil para el pedido');
          return;
        }

        profileData = profileUpdate.data?.usuario || profileData;
        showMissingFieldsHint();
      }

      if (confirmBtn instanceof HTMLButtonElement) {
        confirmBtn.disabled = true;
        confirmBtn.textContent = 'Enviando...';
      }

      try {
        const result = await window.dmhFetchJson('pedidos.php', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!result.ok) { showCheckoutError(result.error || 'No se pudo realizar el pedido'); return; }

        saveCart([]);
        closeCheckout();
        render();
        window.showToast?.(`¡Pedido #${result.data.pedido_id} confirmado! Total: ${Number(result.data.total).toFixed(2).replace('.', ',')} €. Te contactaremos en Bizum ${bizum}.`, 'success');
      } finally {
        if (confirmBtn instanceof HTMLButtonElement) {
          confirmBtn.disabled = false;
          confirmBtn.textContent = 'Confirmar pedido';
        }
      }
    });

    function showCheckoutError(msg) {
      if (!checkoutError) return;
      checkoutError.textContent = msg;
      checkoutError.hidden = false;
    }

    render();
  </script>

  <style is:global>
    /* ── Checkout modal ─────────────────────────── */
    .checkout-overlay {
      position: fixed;
      inset: 0;
      z-index: 9000;
      background: rgba(8, 8, 8, 0.55);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .checkout-modal {
      background: #181818;
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 16px;
      padding: 2rem;
      width: 100%;
      max-width: 640px;
      max-height: min(90vh, 860px);
      overflow: auto;
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      box-shadow: 0 28px 60px rgba(0,0,0,.55), 0 0 0 1px rgba(200,255,0,.08);
    }

    .checkout-modal h2 {
      font-size: 1.4rem;
      font-weight: 800;
      color: #fff;
      margin: 0;
      letter-spacing: 0.01em;
      padding-right: 2rem;
    }

    .checkout-modal__close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 10px;
      cursor: pointer;
      color: rgba(255,255,255,.68);
      padding: 0.35rem;
      line-height: 1;
    }

    .checkout-modal__close:hover {
      color: #fff;
      border-color: rgba(200,255,0,.55);
    }

    .checkout-modal label {
      display: flex;
      flex-direction: column;
      gap: .45rem;
      font-size: .83rem;
      color: rgba(255,255,255,.67);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 600;
    }

    .checkout-modal label input {
      background: #101010;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 10px;
      padding: .7rem .9rem;
      color: #fff;
      font-size: .95rem;
      outline: none;
      text-transform: none;
      letter-spacing: 0;
      font-weight: 500;
      transition: border-color .2s, box-shadow .2s;
    }

    .checkout-modal label input:focus {
      border-color: #c8ff00;
      box-shadow: 0 0 0 3px rgba(200,255,0,.12);
    }

    .checkout-modal__hint {
      font-size: .82rem;
      color: rgba(255,255,255,.6);
      margin: 0;
      line-height: 1.45;
      text-transform: none;
      letter-spacing: 0;
      font-weight: 500;
    }

    .checkout-modal__hint--soft {
      color: rgba(200,255,0,.82);
      background: rgba(200,255,0,.08);
      border: 1px solid rgba(200,255,0,.22);
      border-radius: 10px;
      padding: 0.65rem 0.8rem;
    }

    .checkout-modal__guest-note {
      border: 1px dashed rgba(255,255,255,.22);
      border-radius: 12px;
      background: rgba(255,255,255,.03);
      padding: 0.75rem;
      display: grid;
      gap: 0.6rem;
    }

    .checkout-modal__link {
      display: inline-flex;
      align-self: flex-start;
      border-radius: 999px;
      padding: 0.45rem 0.9rem;
      font-size: 0.82rem;
      font-weight: 700;
      text-decoration: none;
      background: rgba(200,255,0,.16);
      color: #d6ff59;
      border: 1px solid rgba(200,255,0,.3);
    }

    .checkout-modal__grid-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .checkout-modal__paybox {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 12px;
      padding: 0.75rem;
      display: grid;
      gap: 0.65rem;
    }

    .checkout-modal__paybox strong {
      color: #fff;
      font-size: .9rem;
    }

    .checkout-modal__warn {
      margin: 0;
      font-size: .82rem;
      color: #ffd174;
      background: rgba(255, 209, 116, 0.12);
      border: 1px solid rgba(255, 209, 116, 0.28);
      border-radius: 8px;
      padding: .55rem .75rem;
    }

    .checkout-modal__checkline {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 0.55rem;
      color: rgba(255,255,255,.72);
      font-size: 0.84rem;
      text-transform: none;
      letter-spacing: 0;
      font-weight: 500;
    }

    .checkout-modal__checkline input {
      margin-top: 0.15rem;
      accent-color: #c8ff00;
    }

    .checkout-modal__error {
      font-size: .84rem;
