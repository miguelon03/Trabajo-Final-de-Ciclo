---
import HomeLayout from "../layouts/HomeLayout.astro";
import { fetchCatalogData } from "../lib/catalog-api";

type Product = {
  id: number;
  slug: string;
  title: string;
  category: string;
  price: number;
  originalPrice?: number;
  image: string;
  badge?: string;
  type: string;
};

const { products: productsRaw } = await fetchCatalogData();
const allProducts = productsRaw as Product[];
---

<HomeLayout title="DMH - Búsqueda" description="Resultados de búsqueda en DripMode Hood">
  <section class="buscar-page">
    <div class="buscar-container">

      <div class="buscar-header">
        <h1 id="buscarHeading">Buscando…</h1>
        <p id="buscarCount" class="buscar-count"></p>
      </div>

      <div class="buscar-form-wrap">
        <form class="buscar-form" id="buscarForm" role="search">
          <input
            type="search"
            id="buscarInput"
            class="buscar-input"
            placeholder="Buscar productos…"
            autocomplete="off"
            aria-label="Refinar búsqueda"
          />
          <button type="submit" class="buscar-submit" aria-label="Buscar">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </form>
        <ul class="buscar-suggestions" id="buscarSuggestions" role="listbox"></ul>
      </div>

      <div class="buscar-grid" id="buscarGrid"></div>

      <p class="buscar-empty" id="buscarEmpty">
        No se encontraron productos para esta búsqueda.
      </p>

    </div>
  </section>

  <script define:vars={{ allProducts }}>
    // @ts-nocheck
    const q = new URLSearchParams(window.location.search).get('q') || '';

    const headingEl = document.getElementById('buscarHeading');
    const countEl   = document.getElementById('buscarCount');
    const grid      = document.getElementById('buscarGrid');
    const empty     = document.getElementById('buscarEmpty');
    const input     = document.getElementById('buscarInput');
    const form      = document.getElementById('buscarForm');

    if (input && q) input.value = q;
    if (headingEl) headingEl.textContent = q ? `Resultados para "${q}"` : 'Todos los productos';

    const lq = q.toLowerCase();
    const filtered = lq
      ? allProducts.filter(p =>
          p.title.toLowerCase().includes(lq) ||
          p.category?.toLowerCase().includes(lq)
        )
      : allProducts;

    if (countEl) {
      const n = filtered.length;
      countEl.textContent = n
        ? `${n} producto${n !== 1 ? 's' : ''} encontrado${n !== 1 ? 's' : ''}`
        : '';
    }

    if (filtered.length === 0) {
      empty.style.display = 'block';
      grid.style.display  = 'none';
    } else {
      empty.style.display = 'none';
      grid.innerHTML = filtered.map(p => `
        <article class="srp-card" data-slug="${p.slug}" tabindex="0" role="link" aria-label="Ver ${p.title}">
          <div class="srp-card__img">
            ${p.badge ? `<span class="srp-badge">${p.badge}</span>` : ''}
            ${String(p.image || '').startsWith('/') || String(p.image || '').startsWith('http')
              ? `<img src="${p.image}" alt="${p.title}" loading="lazy" />`
              : ''}
          </div>
          <div class="srp-card__info">
            <p class="srp-card__cat">${p.category}</p>
            <h3 class="srp-card__title">${p.title}</h3>
            <div class="srp-card__price">
              ${p.originalPrice ? `<s class="srp-old">${p.originalPrice.toFixed(2)}€</s>` : ''}
              <strong class="srp-current">${p.price.toFixed(2)}€</strong>
            </div>
          </div>
        </article>
      `).join('');

      grid.querySelectorAll('.srp-card').forEach(card => {
        const slug = card.getAttribute('data-slug');
        card.addEventListener('click', () => { if (slug) window.location.href = `/producto/${slug}`; });
        card.addEventListener('keydown', e => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); if (slug) window.location.href = `/producto/${slug}`; }
        });
      });
    }

    form?.addEventListener('submit', e => {
      e.preventDefault();
      const newQ = input?.value.trim();
      if (newQ) window.location.href = '/buscar?q=' + encodeURIComponent(newQ);
    });

    // --- Sugerencias ---
    const suggestions = document.getElementById('buscarSuggestions');

    function escRe(str) {
      return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function renderSuggestions(val) {
      if (!val.trim()) { hideSuggestions(); return; }
      const lv = val.toLowerCase();
      const matches = allProducts.filter(p =>
        p.title.toLowerCase().includes(lv) ||
        p.category?.toLowerCase().includes(lv)
      ).slice(0, 6);
      if (!matches.length) { hideSuggestions(); return; }
      const re = new RegExp(escRe(val), 'gi');
      suggestions.innerHTML = matches
        .map(p => `<li data-slug="${p.slug}" role="option">${p.title.replace(re, m => '<mark>' + m + '</mark>')}</li>`)
        .join('');
      suggestions.style.display = 'block';
      suggestions.querySelectorAll('li').forEach(li => {
        li.addEventListener('mousedown', e => {
          e.preventDefault();
          window.location.href = '/producto/' + li.dataset.slug;
        });
      });
    }

    function hideSuggestions() {
      suggestions.style.display = 'none';
      suggestions.innerHTML = '';
    }

    input?.addEventListener('input', () => renderSuggestions(input.value));
    input?.addEventListener('blur', () => setTimeout(hideSuggestions, 150));
    input?.addEventListener('keydown', e => {
      if (e.key === 'Escape') { input.blur(); hideSuggestions(); }
    });
  </script>

  <style is:global>
    .buscar-page {
      padding: 2.5rem 3rem 5rem;
      background: #1a1a1a;
      min-height: 70vh;
    }

    .buscar-container {
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      gap: 2rem;
    }

    .buscar-header {
      display: grid;
      gap: 0.35rem;
    }

    .buscar-header h1 {
      font-size: 1.85rem;
      color: #f5f5f5;
      margin: 0;
    }

    .buscar-count {
      color: rgba(255, 255, 255, 0.45);
      font-size: 0.88rem;
      margin: 0;
    }

    .buscar-form-wrap {
      position: relative;
      max-width: 480px;
    }

    .buscar-form {
      display: flex;
      gap: 0;
    }

    .buscar-suggestions {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      width: 100%;
      background: #1e1e1e;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      list-style: none;
      padding: 0.35rem 0;
      margin: 0;
      z-index: 100;
      display: none;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
    }

    .buscar-suggestions li {
      padding: 0.6rem 1rem;
      cursor: pointer;
      font-size: 0.88rem;
      color: rgba(255, 255, 255, 0.75);
      transition: background 0.15s;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .buscar-suggestions li:hover {
      background: rgba(200, 255, 0, 0.07);
      color: #f5f5f5;
    }

    .buscar-suggestions mark {
      background: transparent;
      color: #c8ff00;
      font-weight: 600;
    }

    .buscar-input {
      flex: 1;
      height: 44px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-right: none;
      border-radius: 999px 0 0 999px;
      color: #f5f5f5;
      padding: 0 1.1rem;
      font-size: 0.92rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .buscar-input:focus {
      border-color: rgba(200, 255, 0, 0.4);
    }

    .buscar-input::-webkit-search-cancel-button {
      display: none;
    }

    .buscar-submit {
      height: 44px;
      padding: 0 1.1rem;
      background: #c8ff00;
      border: none;
      border-radius: 0 999px 999px 0;
      color: #0f0f0f;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }

    .buscar-submit:hover {
      background: #d9ff33;
    }

    .buscar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.5rem;
    }

    .srp-card {
      background: #111;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      cursor: pointer;
      overflow: hidden;
      transition: border-color 0.2s ease, transform 0.2s ease;
      display: grid;
    }

    .srp-card:hover {
      border-color: rgba(200, 255, 0, 0.35);
      transform: translateY(-2px);
    }

    .srp-card:focus-visible {
      outline: 2px solid #c8ff00;
      outline-offset: 3px;
    }

    .srp-card__img {
      position: relative;
      height: 260px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(0, 0, 0, 0.2));
      display: flex;
      align-items: flex-start;
      padding: 0.75rem;
      overflow: hidden;
    }

    .srp-card__img img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .srp-badge {
      position: relative;
      z-index: 1;
      background: #c8ff00;
      color: #0f0f0f;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 0.2rem 0.55rem;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .srp-card__info {
      padding: 1rem;
      display: grid;
      gap: 0.3rem;
    }

    .srp-card__cat {
      color: rgba(255, 255, 255, 0.4);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin: 0;
    }

    .srp-card__title {
      color: #f5f5f5;
      font-size: 0.98rem;
      margin: 0;
      font-weight: 500;
    }

    .srp-card__price {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.2rem;
    }

    .srp-old {
      color: rgba(255, 255, 255, 0.38);
      font-size: 0.83rem;
    }

    .srp-current {
      color: #c8ff00;
      font-size: 1rem;
    }

    .buscar-empty {
      display: none;
      color: rgba(255, 255, 255, 0.45);
      text-align: center;
      padding: 4rem 1rem;
      font-size: 1.05rem;
    }

    @media (max-width: 640px) {
      .buscar-page {
        padding: 1.5rem 1rem 3rem;
      }

      .buscar-header h1 {
        font-size: 1.4rem;
      }

      .buscar-form {
        max-width: 100%;
      }

      .buscar-form-wrap {
        max-width: 100%;
      }

      .buscar-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</HomeLayout>
