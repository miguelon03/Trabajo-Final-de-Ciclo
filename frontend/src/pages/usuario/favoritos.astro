---
import HomeLayout from "../../layouts/HomeLayout.astro";
import { fetchCatalogData } from "../../lib/catalog-api";
import { cartIcon } from "../../components/icons";

const { products } = await fetchCatalogData();

const allProducts = products as Array<{
  id: number;
  slug: string;
  title: string;
  category: string;
  price: number;
  originalPrice?: number;
  badge?: string;
  type: string;
  color: string;
  image: string;
}>;
---

<HomeLayout title="DMH - Favoritos">
  <section class="wishlist-page">
    <div class="wishlist-container">
      <header class="wishlist-header">
        <p class="wishlist-kicker">Perfil</p>
        <h1>Mi wishlist</h1>
        <p>Guarda aquí tus prendas favoritas y añádelas al carrito cuando quieras.</p>
      </header>

      <div class="page-indicator" id="wishlistPageIndicator">Página nº 1</div>

      <div id="wishlistEmpty" class="wishlist-empty" hidden>
        <p>Aún no tienes favoritos guardados.</p>
        <a href="/catalogo">Explorar catálogo</a>
      </div>

      <div id="wishlistLoading" class="wishlist-loading" hidden>
        <div class="wishlist-skeleton"></div>
        <div class="wishlist-skeleton"></div>
        <div class="wishlist-skeleton"></div>
      </div>

      <div class="catalog__grid-wrapper">
        <button class="pagination__side pagination__prev" id="wishlistPrevPage" type="button" aria-label="Página anterior">←</button>
        <div id="wishlistGrid" class="products-grid"></div>
        <button class="pagination__side pagination__next" id="wishlistNextPage" type="button" aria-label="Página siguiente">→</button>
      </div>
    </div>
  </section>

  <script define:vars={{ allProducts, quickAddIcon: cartIcon }}>
    // @ts-nocheck
    const PAGE_SIZE = 6;
    let currentPage = 1;
    let currentFavorites = window.dmhFavorites?.get?.() || [];

    async function fetchWishlist() {
      const result = await window.dmhFetchJson("favoritos.php", {
        credentials: "include",
      });

      if (!result.ok) {
        if (result.status === 401) {
          return { authorized: false, slugs: [], error: "Debes iniciar sesión" };
        }
        return {
          authorized: false,
          slugs: currentFavorites,
          error: result.error || "No se pudo cargar favoritos",
        };
      }

      const slugs = result.data?.favoritos || [];
      // Evitamos emitir eventos aquí para no crear bucles de re-render en esta vista.
      currentFavorites = slugs;
      return { authorized: true, slugs: currentFavorites, error: null };
    }

    async function removeFavorite(slug) {
      const result = await window.dmhFetchJson("favoritos.php", {
        method: "DELETE",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ slug }),
      });

      if (result.ok) {
        currentFavorites =
          window.dmhFavorites?.toggleOne?.(slug, false, "favorites-page-remove") || currentFavorites;
      }

      return result;
    }

    function getCart() {
      return JSON.parse(localStorage.getItem("cart") || "[]");
    }

    function saveCart(cart) {
      localStorage.setItem("cart", JSON.stringify(cart));
      window.dispatchEvent(new Event("cart-updated"));
    }

    function setWishlistLoading(isLoading) {
      const loading = document.getElementById("wishlistLoading");
      const grid = document.getElementById("wishlistGrid");
      const empty = document.getElementById("wishlistEmpty");

      if (loading) {
        loading.hidden = !isLoading;
      }

      if (grid) {
        grid.classList.toggle("is-loading", isLoading);
      }

      if (empty && isLoading) {
        empty.hidden = true;
      }
    }

    function updatePagination(totalItems) {
      const prevBtn = document.getElementById("wishlistPrevPage");
      const nextBtn = document.getElementById("wishlistNextPage");
      const indicator = document.getElementById("wishlistPageIndicator");

      if (!prevBtn || !nextBtn || !indicator) {
        return;
      }

      const totalPages = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));

      indicator.textContent = `Página nº ${currentPage}`;

      prevBtn.style.visibility = currentPage === 1 ? "hidden" : "visible";
      nextBtn.style.visibility = currentPage === totalPages ? "hidden" : "visible";

      if (totalItems <= PAGE_SIZE) {
        prevBtn.style.visibility = "hidden";
        nextBtn.style.visibility = "hidden";
      }

      prevBtn.onclick = () => {
        if (currentPage > 1) {
          currentPage -= 1;
          renderWishlist();
        }
      };

      nextBtn.onclick = () => {
        if (currentPage < totalPages) {
          currentPage += 1;
          renderWishlist();
        }
      };
    }

    async function renderWishlist() {
      const grid = document.getElementById("wishlistGrid");
      const empty = document.getElementById("wishlistEmpty");
      const prevBtn = document.getElementById("wishlistPrevPage");
      const nextBtn = document.getElementById("wishlistNextPage");
      const pageIndicator = document.getElementById("wishlistPageIndicator");
      if (!grid || !empty) {
        return;
      }

      setWishlistLoading(true);
      try {
        const { authorized, slugs, error } = await fetchWishlist();
        if (!authorized) {
          grid.innerHTML = "";
          empty.hidden = false;
          if (prevBtn) prevBtn.style.visibility = "hidden";
          if (nextBtn) nextBtn.style.visibility = "hidden";
          if (pageIndicator) pageIndicator.textContent = "Página nº 1";
          empty.innerHTML =
            '<p>Necesitas iniciar sesión para ver tu wishlist.</p><a href="/login">Ir a login</a>';
          if (error && error !== "Debes iniciar sesión" && error !== "Inicia sesión para continuar") {
            window.showToast?.(error, "error");
          }
          return;
        }

        const wishlist = slugs;
        const favoriteProducts = allProducts.filter((product) => wishlist.includes(product.slug));

        if (!favoriteProducts.length) {
          grid.innerHTML = "";
          empty.hidden = false;
          if (prevBtn) prevBtn.style.visibility = "hidden";
          if (nextBtn) nextBtn.style.visibility = "hidden";
          if (pageIndicator) pageIndicator.textContent = "Página nº 1";
          return;
        }

        const totalPages = Math.max(1, Math.ceil(favoriteProducts.length / PAGE_SIZE));
        if (currentPage > totalPages) {
          currentPage = totalPages;
        }

        const start = (currentPage - 1) * PAGE_SIZE;
        const paginatedProducts = favoriteProducts.slice(start, start + PAGE_SIZE);

        empty.hidden = true;
        grid.innerHTML = paginatedProducts
          .map((product) => {
            return (
              '<article class="product-card" data-slug="' +
              product.slug +
              '" data-product-id="' +
              product.id +
              '" data-type="' +
              product.type +
              '" data-color="' +
              product.color +
              '" data-price="' +
              product.price +
              '" data-product-slug="' +
              product.slug +
              '" data-product-title="' +
              product.title +
              '" data-product-image="' +
              product.image +
              '" tabindex="0" role="link" aria-label="Ver ' +
              product.title +
              '">' +
              '<div class="product-card__top">' +
              (product.badge ? '<span class="badge">' + product.badge + '</span>' : '') +
              '<button class="icon-fav" type="button" data-action="remove" data-slug="' +
              product.slug +
              '" aria-label="Quitar de favoritos">♥</button>' +
              '</div>' +
              '<div class="product-card__image" aria-hidden="true">' +
              ((String(product.image || '').startsWith('/') || String(product.image || '').startsWith('http'))
                ? ('<img src="' + product.image + '" alt="' + product.title + '" loading="lazy" />')
                : ('<span class="product-card__image-placeholder">' + product.image + '</span>')) +
              '</div>' +
              '<div class="product-card__content">' +
              '<h3>' + product.title + '</h3>' +
              '<p class="product-category">' + product.category + '</p>' +
              '<div class="product-card__footer">' +
              (product.originalPrice ? '<span class="product-price-original">' + product.originalPrice.toFixed(2) + '€</span>' : '') +
              '<span class="product-price">' + product.price.toFixed(2) + '€</span>' +
              '</div>' +
              '</div>' +
              '</article>'
            );
          })
          .join("");

        updatePagination(favoriteProducts.length);

        grid.querySelectorAll("button[data-action='remove']").forEach((btn) => {
          btn.addEventListener("click", () => {
            const slug = btn.getAttribute("data-slug");
            if (!slug) {
              return;
            }

            window.showConfirmToast?.(
              "¿Quieres quitar este producto de tu wishlist?",
              () => {
                removeFavorite(slug).then((result) => {
                  if (!result.ok) {
                    if (result.status === 401) {
                      setTimeout(() => {
                        window.location.href = "/login";
                      }, 500);
                      return;
                    }

                    window.showToast?.(result.error || "No se pudo actualizar favoritos", "error");
                    return;
                  }

                  renderWishlist();
                  window.showToast?.("Producto eliminado de favoritos", "success");
                });
              },
              {
                confirmText: "Sí, quitar",
                cancelText: "Cancelar",
              },
            );
          });
        });

        setupCardNavigation(grid);
        setupAccessoryQuickAdd(grid);
      } catch (error) {
        empty.hidden = false;
        empty.innerHTML =
          '<p>No se pudo cargar la wishlist en este momento.</p><a href="/catalogo">Explorar catálogo</a>';
        window.showToast?.(error?.message || "Error cargando wishlist", "error");
      } finally {
        setWishlistLoading(false);
      }
    }

    function setupAccessoryQuickAdd(container) {
      const cards = Array.from(container.querySelectorAll(".product-card"));

      cards.forEach((card) => {
        const type = card.getAttribute("data-type");
        if (type !== "accesorio") {
          return;
        }

        const footer = card.querySelector(".product-card__footer");
        if (!(footer instanceof HTMLElement) || footer.querySelector(".quick-add-btn")) {
          return;
        }

        const quickAddBtn = document.createElement("button");
        quickAddBtn.type = "button";
        quickAddBtn.className = "quick-add-btn";
        quickAddBtn.innerHTML = quickAddIcon;
        quickAddBtn.setAttribute("aria-label", "Añadir accesorio al carrito");

        quickAddBtn.addEventListener("click", (event) => {
          event.preventDefault();
          event.stopPropagation();

          const slug = card.getAttribute("data-product-slug");
          const id = Number(card.getAttribute("data-product-id") || 0);
          const title = card.getAttribute("data-product-title") || "";
          const image = card.getAttribute("data-product-image") || "";
          const color = card.getAttribute("data-color") || "";
          const price = Number(card.getAttribute("data-price") || 0);

          if (!id || !slug || !price) {
            return;
          }

          const cart = getCart();
          const sku = `DMH-${id}-UNICA`;
          const existingIndex = cart.findIndex(
            (item) => item.slug === slug && item.size === "Única",
          );

          if (existingIndex >= 0) {
            cart[existingIndex].quantity += 1;
          } else {
            cart.push({
              id,
              slug,
              title,
              price,
              image,
              color,
              size: "Única",
              sku,
              quantity: 1,
            });
          }

          saveCart(cart);
          window.showToast?.("Accesorio añadido al carrito", "success");
        });

        footer.appendChild(quickAddBtn);
      });
    }

    function setupCardNavigation(container) {
      const cards = Array.from(container.querySelectorAll(".product-card"));
      const sourceSlug = "catalogo";

      cards.forEach((card) => {
        const slug = card.getAttribute("data-product-slug");
        if (!slug) {
          return;
        }

        const openProduct = () => {
          window.location.href = `/producto/${slug}?from=${encodeURIComponent(sourceSlug)}`;
        };

        card.addEventListener("click", (event) => {
          const target = event.target;
          if (
            target instanceof Element &&
            (target.closest(".icon-fav") || target.closest(".quick-add-btn"))
          ) {
            return;
          }
          openProduct();
        });

        card.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            openProduct();
          }
        });
      });
    }

    renderWishlist();
  </script>

  <style is:global>
    .wishlist-page {
      width: 100%;
      min-height: 80vh;
      padding: 2rem 3rem;
      background: #1a1a1a;
    }

    .wishlist-container {
      width: 1200px;
      max-width: 100%;
      margin: 0 auto;
      display: grid;
      gap: 1.5rem;
    }

    .wishlist-header {
      background: linear-gradient(150deg, rgba(200, 255, 0, 0.12), rgba(255, 255, 255, 0.04));
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      padding: 1.8rem;
      color: #fff;
    }

    .wishlist-kicker {
      margin: 0 0 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.26em;
      color: #c8ff00;
      font-size: 0.75rem;
    }

    .wishlist-header h1 {
      margin: 0;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
    }

    .wishlist-header p {
      margin: 0.8rem 0 0;
      color: rgba(255, 255, 255, 0.75);
    }

    .page-indicator {
      margin-top: 0.5rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: #C8FF00;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .wishlist-empty {
      background: #1c1c1c;
      border: 1px dashed rgba(255, 255, 255, 0.2);
      border-radius: 18px;
      padding: 2rem;
      text-align: center;
      color: #fff;
    }

    .wishlist-empty a {
      display: inline-flex;
      margin-top: 1rem;
      padding: 0.7rem 1rem;
      border-radius: 999px;
      text-decoration: none;
      background: #c8ff00;
      color: #111;
      font-weight: 700;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.2rem;
      align-items: stretch;
      width: 100%;
    }

    .catalog__grid-wrapper {
      display: grid;
      grid-template-columns: 48px 1fr 48px;
      align-items: center;
      gap: 1rem;
      width: 100%;
    }

    .pagination__side {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.08);
      color: #f5f5f5;
      font-size: 1.2rem;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s ease, border-color 0.2s ease;
    }

    .pagination__side:hover {
      background: rgba(255, 255, 255, 0.12);
    }

    .pagination__side:disabled {
      opacity: 0.35;
      cursor: not-allowed;
    }

    .products-grid.is-loading {
      opacity: 0;
      pointer-events: none;
      min-height: 0;
    }

    .wishlist-loading {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1rem;
    }

    .wishlist-skeleton {
      height: 310px;
      border-radius: 18px;
      background: linear-gradient(
        100deg,
        rgba(255, 255, 255, 0.04) 10%,
        rgba(255, 255, 255, 0.12) 28%,
        rgba(255, 255, 255, 0.04) 46%
      );
      background-size: 220% 100%;
      animation: skeleton 1.15s ease-in-out infinite;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    @keyframes skeleton {
      from {
        background-position: 100% 0;
      }
      to {
        background-position: -100% 0;
      }
    }

    .product-card {
      background: #111111;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: var(--border-radius-card);
      overflow: hidden;
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 1rem;
      padding: 1rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      min-height: 420px;
      cursor: pointer;
      color: #fff;
    }

    .product-card:hover {
      border-color: rgba(200, 255, 0, 0.3);
    }

    .product-card__top {
      display: flex;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 0.5rem;
      min-height: 38px;
    }

    .badge {
      display: inline-flex;
      padding: 0.4rem 0.75rem;
      border-radius: var(--border-radius-sm);
      background: #C8FF00;
      color: #090909;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .icon-fav {
      border: none;
      background: rgba(255, 255, 255, 0.04);
      color: #f5f5f5;
      width: 38px;
      height: 38px;
      position: absolute;
      top: 1rem;
      right: 1rem;
      z-index: 2;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .icon-fav:hover {
      background: rgba(255, 255, 255, 0.08);
    }

    .product-card__image {
      height: 260px;
      display: grid;
      place-items: center;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(0, 0, 0, 0.22));
      border-radius: var(--border-radius-card);
      color: rgba(255, 255, 255, 0.36);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-size: 0.95rem;
      overflow: hidden;
    }

    .product-card__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .product-card__image-placeholder {
      color: rgba(255, 255, 255, 0.36);
    }

    .product-card__content {
      display: grid;
      gap: 0.5rem;
    }

    .product-card h3 {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
      color: #ffffff;
      line-height: 1.4;
    }

    .product-category {
      margin: 0;
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .product-card__footer {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.4rem;
    }

    .product-price {
      font-size: 1.1rem;
      font-weight: 700;
      color: #C8FF00;
    }

    .product-price-original {
      font-size: 0.9rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.5);
      text-decoration: line-through;
      margin-right: 0;
    }

    .quick-add-btn {
      border: none;
      background: rgba(200, 255, 0, 0.16);
      color: #d8ff48;
      border-radius: 999px;
      width: 34px;
      height: 34px;
      padding: 0;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .quick-add-btn {
      transition: background 0.2s ease;
    }

    .quick-add-btn:hover {
      background: rgba(200, 255, 0, 0.24);
    }

    .quick-add-btn :global(svg) {
      width: 16px;
      height: 16px;
    }

    @media (max-width: 1024px) {
      .products-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .wishlist-page {
        padding: 1.5rem;
      }

      .catalog__grid-wrapper {
        grid-template-columns: 40px 1fr 40px;
      }

      .products-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .pagination__side {
        width: 40px;
        height: 40px;
      }
    }

    @media (max-width: 640px) {
      .catalog__grid-wrapper {
        grid-template-columns: 36px 1fr 36px;
      }

      .products-grid {
        grid-template-columns: 1fr;
      }

      .pagination__side {
        width: 36px;
        height: 36px;
      }

      .page-indicator {
        font-size: 0.9rem;
        margin-top: 0.5rem;
      }
    }
  </style>
</HomeLayout>
